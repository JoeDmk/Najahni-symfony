<div style="font-family:'Helvetica Neue',Arial,sans-serif;max-width:600px;margin:0 auto;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.1)">
    <div style="background:linear-gradient(135deg,#4361ee,#7209b7);padding:32px;text-align:center">
        <h1 style="color:#fff;margin:0;font-size:28px">Najahni</h1>
        <p style="color:rgba(255,255,255,.8);margin:8px 0 0;font-size:14px">{{ subject }}</p>
    </div>
    <div style="padding:32px">
        {{ body|raw }}
    </div>
    <div style="background:#f5f5f5;padding:16px;text-align:center">
        <p style="color:#999;font-size:12px;margin:0">Cet email a été envoyé par l'équipe Najahni</p>
    </div>
</div>
