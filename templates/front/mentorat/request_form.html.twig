{% extends 'front/layout.html.twig' %}

{% block title %}Demande de mentorat - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-send me-2"></i>Nouvelle demande de mentorat</h2>
    <a href="{{ path('app_mentorat_mentors') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">Envoyer une demande à <a href="{{ path('app_user_profile', {id: mentor.id}) }}" class="text-decoration-none">{{ mentor.firstname }} {{ mentor.lastname }}</a></h5>
                <form method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('mentorat_request') }}">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Projet (optionnel)</label>
                        <select name="project_id" class="form-select">
                            <option value="">Aucun projet spécifique</option>
                            {% for p in projets %}
                            <option value="{{ p.id }}">{{ p.titre }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Date souhaitée</label>
                            <input type="date" name="date" class="form-control" required value="{{ prefillDate|default('') }}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Heure</label>
                            <input type="time" name="time" class="form-control" required value="{{ prefillTime|default('') }}">
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label fw-semibold">Motivation</label>
                        <textarea name="motivation" id="motivationText" class="form-control" rows="3" placeholder="Pourquoi souhaitez-vous ce mentorat ?" required></textarea>
                        {# Voice recording option #}
                        <div class="mt-2">
                            <button type="button" id="voiceRecordBtn" class="btn btn-sm btn-outline-secondary" onclick="toggleRecording()">
                                <i class="bi bi-mic me-1"></i><span id="voiceBtnLabel">Enregistrer vocalement</span>
                            </button>
                            <span id="voiceStatus" class="ms-2 small text-muted"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Objectifs</label>
                        <textarea name="goals" id="goalsText" class="form-control" rows="3" placeholder="Quels sont vos objectifs ?"></textarea>
                        <div class="mt-2">
                            <button type="button" id="voiceGoalsBtn" class="btn btn-sm btn-outline-secondary" onclick="toggleGoalsRecording()">
                                <i class="bi bi-mic me-1"></i><span id="voiceGoalsBtnLabel">Enregistrer vocalement</span>
                            </button>
                            <span id="voiceGoalsStatus" class="ms-2 small text-muted"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-nj btn-lg"><i class="bi bi-send me-2"></i>Envoyer la demande</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <div class="text-center mb-3">
                <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center" style="width:80px;height:80px;background:var(--nj-gradient);color:#fff;font-size:2rem">
                    {{ mentor.firstname|first|upper }}{{ mentor.lastname|first|upper }}
                </div>
            </div>
            <h5 class="fw-bold text-center"><a href="{{ path('app_user_profile', {id: mentor.id}) }}" class="text-decoration-none text-dark">{{ mentor.firstname }} {{ mentor.lastname }}</a></h5>
            {% if mentor.bio %}<p class="text-muted small">{{ mentor.bio }}</p>{% endif %}
            {% if mentor.companyName %}<p class="small"><i class="bi bi-building me-1"></i>{{ mentor.companyName }}</p>{% endif %}
            {% if mentor.linkedinUrl %}<p class="small"><a href="{{ mentor.linkedinUrl }}" target="_blank"><i class="bi bi-linkedin me-1"></i>LinkedIn</a></p>{% endif %}
        </div>

        <div class="card border-0 shadow-sm p-4 mt-3" style="border-radius:1rem">
            <h6 class="fw-bold mb-2"><i class="bi bi-info-circle me-1"></i>Comment ça marche ?</h6>
            <ul class="small text-muted mb-0">
                <li>Un score de compatibilité est calculé automatiquement</li>
                <li>Si le score ≥ 70%, la demande est auto-acceptée</li>
                <li>Sinon, le mentor reçoit votre demande et peut l'accepter ou la refuser</li>
                <li>Une session est créée automatiquement lors de l'acceptation</li>
            </ul>
        </div>
    </div>
</div>

<script>
/* ── Web Speech API – Reconnaissance vocale temps réel ── */
const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

function createVoiceRecorder(opts) {
    const btnId      = opts.btnId;
    const labelId    = opts.labelId;
    const statusId   = opts.statusId;
    const fieldId    = opts.fieldId;
    let recognition  = null;
    let active       = false;

    function setUI(recording) {
        const btn   = document.getElementById(btnId);
        const label = document.getElementById(labelId);
        const status = document.getElementById(statusId);
        if (recording) {
            btn.classList.replace('btn-outline-secondary', 'btn-danger');
            label.textContent = 'Arrêter l\'enregistrement';
            status.innerHTML  = '<i class="bi bi-soundwave text-danger"></i> Parlez maintenant...';
        } else {
            btn.classList.replace('btn-danger', 'btn-outline-secondary');
            label.textContent = 'Enregistrer vocalement';
        }
    }

    function start() {
        if (!SpeechRecognition) {
            document.getElementById(statusId).textContent = 'Votre navigateur ne supporte pas la reconnaissance vocale. Utilisez Chrome ou Edge.';
            return;
        }
        recognition = new SpeechRecognition();
        recognition.lang = 'fr-FR';
        recognition.continuous = true;
        recognition.interimResults = true;

        let finalTranscript = '';
        const field = document.getElementById(fieldId);
        const startValue = field.value;

        recognition.onresult = function(e) {
            let interim = '';
            finalTranscript = '';
            for (let i = 0; i < e.results.length; i++) {
                if (e.results[i].isFinal) {
                    finalTranscript += e.results[i][0].transcript;
                } else {
                    interim += e.results[i][0].transcript;
                }
            }
            // Show interim text in grey, final in normal
            field.value = (startValue ? startValue + ' ' : '') + finalTranscript + interim;
            document.getElementById(statusId).innerHTML = '<i class="bi bi-soundwave text-danger"></i> Parlez maintenant... <span class="text-muted">(' + (finalTranscript.length + interim.length) + ' car.)</span>';
        };

        recognition.onerror = function(e) {
            active = false;
            setUI(false);
            if (e.error === 'not-allowed') {
                document.getElementById(statusId).textContent = 'Accès au microphone refusé. Autorisez le micro dans votre navigateur.';
            } else if (e.error === 'no-speech') {
                document.getElementById(statusId).textContent = 'Aucune voix détectée. Réessayez.';
            } else {
                document.getElementById(statusId).textContent = 'Erreur : ' + e.error;
            }
        };

        recognition.onend = function() {
            if (active) {
                // Ended naturally (timeout) — finalize
                active = false;
                setUI(false);
                if (finalTranscript) {
                    field.value = (startValue ? startValue + ' ' : '') + finalTranscript;
                    document.getElementById(statusId).innerHTML = '<i class="bi bi-check-circle text-success"></i> Transcription ajoutée !';
                } else {
                    document.getElementById(statusId).textContent = 'Aucun texte détecté.';
                }
            }
        };

        recognition.start();
        active = true;
        setUI(true);
    }

    function stop() {
        if (recognition) {
            active = false;
            recognition.stop();
            setUI(false);
            document.getElementById(statusId).innerHTML = '<i class="bi bi-check-circle text-success"></i> Transcription ajoutée !';
        }
    }

    return function toggle() {
        if (active) { stop(); } else { start(); }
    };
}

/* Create two independent voice recorders */
const toggleRecording = createVoiceRecorder({
    btnId: 'voiceRecordBtn',
    labelId: 'voiceBtnLabel',
    statusId: 'voiceStatus',
    fieldId: 'motivationText'
});

const toggleGoalsRecording = createVoiceRecorder({
    btnId: 'voiceGoalsBtn',
    labelId: 'voiceGoalsBtnLabel',
    statusId: 'voiceGoalsStatus',
    fieldId: 'goalsText'
});
</script>
{% endblock %}
