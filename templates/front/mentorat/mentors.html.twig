{% extends 'front/layout.html.twig' %}

{% block title %}Trouver un mentor - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-search me-2"></i>Trouver un mentor</h2>
    <a href="{{ path('app_mentorat_requests') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Mes demandes</a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

{% if availabilities|length > 0 %}
<div class="row g-4">
    {% for avail in availabilities %}
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width:56px;height:56px;min-width:56px;background:var(--nj-gradient);color:#fff;font-size:1.3rem;font-weight:700">
                        {{ avail.mentor.firstname|first|upper }}{{ avail.mentor.lastname|first|upper }}
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">{{ avail.mentor.firstname }} {{ avail.mentor.lastname }}</h6>
                        <span class="badge bg-info bg-opacity-10 text-info"><i class="bi bi-mortarboard me-1"></i>Mentor</span>
                    </div>
                </div>
                {% if avail.mentor.bio %}
                    <p class="text-muted small mb-2">{{ avail.mentor.bio|length > 80 ? avail.mentor.bio|slice(0,80) ~ '...' : avail.mentor.bio }}</p>
                {% endif %}
                {% if avail.mentor.companyName %}
                    <p class="small mb-2"><i class="bi bi-building me-1 text-muted"></i>{{ avail.mentor.companyName }}</p>
                {% endif %}
                <hr class="my-2">
                <div class="d-flex align-items-center mb-2">
                    <i class="bi bi-calendar-event text-primary me-2"></i>
                    <span class="fw-semibold">{{ avail.date|date('d/m/Y') }}</span>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-clock text-primary me-2"></i>
                    <span>{{ avail.startTime|date('H:i') }} → {{ avail.endTime|date('H:i') }}</span>
                </div>
                <a href="{{ path('app_mentorat_request_new', {mentorId: avail.mentor.id, date: avail.date|date('Y-m-d'), time: avail.startTime|date('H:i')}) }}" class="btn btn-nj w-100">
                    <i class="bi bi-send me-1"></i>Envoyer une demande
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="text-center py-5">
    <i class="bi bi-calendar-x" style="font-size:4rem;color:var(--nj-primary)"></i>
    <h4 class="fw-bold mt-3">Aucune disponibilité de mentor</h4>
    <p class="text-muted">Les mentors n'ont pas encore publié de créneaux disponibles.</p>
</div>
{% endif %}
{% endblock %}
