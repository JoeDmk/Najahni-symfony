{% extends 'front/layout.html.twig' %}

{% block title %}Trouver un mentor - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-search me-2"></i>Trouver un mentor</h2>
    <a href="{{ path('app_mentorat_requests') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Mes demandes</a>
</div>

{% if mentors|length > 0 %}
<div class="row g-4">
    {% for mentor in mentors %}
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:1rem">
            <div class="card-body p-4 text-center">
                <div class="rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:80px;height:80px;background:var(--nj-gradient);color:#fff;font-size:2rem">
                    {{ mentor.firstname|first|upper }}{{ mentor.lastname|first|upper }}
                </div>
                <h5 class="fw-bold mb-1">{{ mentor.firstname }} {{ mentor.lastname }}</h5>
                <span class="badge bg-info bg-opacity-10 text-info mb-2"><i class="bi bi-mortarboard me-1"></i>Mentor</span>
                {% if mentor.bio %}<p class="text-muted small mb-3">{{ mentor.bio|length > 100 ? mentor.bio|slice(0,100) ~ '...' : mentor.bio }}</p>{% endif %}
                {% if mentor.companyName %}<p class="small mb-2"><i class="bi bi-building me-1"></i>{{ mentor.companyName }}</p>{% endif %}
                <a href="{{ path('app_mentorat_request_new', {mentorId: mentor.id}) }}" class="btn btn-nj w-100">
                    <i class="bi bi-send me-1"></i>Demander un mentorat
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="text-center py-5">
    <div class="text-center"><i class="bi bi-mortarboard" style="font-size:4rem;color:var(--nj-primary)"></i></div>
    <h4 class="fw-bold mt-3">Aucun mentor disponible</h4>
</div>
{% endif %}
{% endblock %}
