{% extends 'base.html.twig' %}

{% block body %}
{# Announcement Bar #}
<div class="nj-announce-bar" id="njAnnounceBar">
    <span class="nj-announce-msg active">Najahni connecte entrepreneurs et investisseurs en Tunisie</span>
    <span class="nj-announce-msg">Nouveau : Contrats sign&eacute;s num&eacute;riquement avec SHA-256</span>
    <span class="nj-announce-msg">Rejoignez {{ njPlatformUserCount|default(0)|number_format(0, ',', ' ') }} membres actifs sur la plateforme</span>
    <button class="nj-announce-close" id="njAnnounceClose" aria-label="Fermer"><i class="bi bi-x"></i></button>
</div>

{# Top Navbar #}
<nav class="navbar navbar-expand-lg navbar-nj navbar-dark sticky-top">
    <div class="container-fluid px-4">
        <a class="navbar-brand nj-brand-gradient" href="{{ path('app_home') }}">Najahni</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_home' ? 'active' }}" href="{{ path('app_home') }}"><i class="bi bi-house-door me-1"></i>Accueil</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_community' ? 'active' }}" href="{{ path('app_community_posts') }}"><i class="bi bi-people me-1"></i>Communauté</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_projet' ? 'active' }}" href="{{ path('app_projet_index') }}"><i class="bi bi-kanban me-1"></i>Projets</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_invest' ? 'active' }}" href="{{ path('app_invest_opportunities') }}"><i class="bi bi-graph-up-arrow me-1"></i>Investissement</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_mentorat' ? 'active' }}" href="{{ path('app_mentorat_requests') }}"><i class="bi bi-mortarboard me-1"></i>Mentorat</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_apprentissage' ? 'active' }}" href="{{ path('app_apprentissage_cours') }}"><i class="bi bi-book me-1"></i>Apprentissage</a></li>
            </ul>
            <ul class="navbar-nav">
                {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}"><i class="bi bi-shield-lock me-1"></i>Admin</a></li>
                {% endif %}
                <li class="nav-item dropdown" id="notifDropdown">
                    <a class="nav-link position-relative" href="#" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" id="notifBell">
                        <i class="bi bi-bell me-1"></i>
                        <span class="badge rounded-pill bg-danger position-absolute top-0 start-100 translate-middle d-none" id="notifBadge" style="font-size:.6rem"></span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end p-0 shadow-lg" style="width:360px;max-height:440px;border-radius:1rem;overflow:hidden">
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom" style="background:var(--nj-gradient)">
                            <span class="fw-bold text-white small">Notifications</span>
                            <button class="btn btn-sm btn-link text-white text-decoration-none p-0" id="notifReadAll" style="font-size:.75rem">Tout marquer lu</button>
                        </div>
                        <div id="notifList" style="max-height:340px;overflow-y:auto">
                            <div class="text-center text-muted small py-4">Chargement...</div>
                        </div>
                        <div class="border-top text-center py-2">
                            <a href="{{ path('app_profile_notifications') }}" class="small text-decoration-none" style="color:var(--nj-primary)">Voir toutes les notifications</a>
                        </div>
                    </div>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>{{ app.user.firstname }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="bi bi-person me-2"></i>Mon Profil</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a></li>
                    </ul>
                </li>
                {% else %}
                <li class="nav-item"><a class="nav-link btn-nj-ghost ms-lg-2" href="{{ path('app_login') }}"><i class="bi bi-box-arrow-in-right me-1"></i>Connexion</a></li>
                <li class="nav-item"><a class="nav-link btn-nj-signup ms-lg-2" href="{{ path('app_register') }}"><i class="bi bi-person-plus me-1"></i>Inscription</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="container-fluid py-4 px-4 fade-in" style="min-height:calc(100vh - 200px)">
    {% block main %}{% endblock %}
</main>

{# Footer #}
<footer class="nj-footer mt-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold text-white mb-3">Najahni</h5>
                <p class="small mb-0">La plateforme tunisienne qui connecte entrepreneurs, mentors et investisseurs pour bâtir l'avenir.</p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-bold text-white mb-3">Modules</h6>
                <div class="d-flex flex-column gap-1">
                    <a href="{{ path('app_projet_index') }}"><i class="bi bi-rocket-takeoff me-2"></i>Projets</a>
                    <a href="{{ path('app_invest_opportunities') }}"><i class="bi bi-graph-up-arrow me-2"></i>Investissement</a>
                    <a href="{{ path('app_community_posts') }}"><i class="bi bi-people me-2"></i>Communauté</a>
                    <a href="{{ path('app_mentorat_requests') }}"><i class="bi bi-mortarboard me-2"></i>Mentorat</a>
                    <a href="{{ path('app_apprentissage_cours') }}"><i class="bi bi-book me-2"></i>Apprentissage</a>
                </div>
            </div>
            <div class="col-md-4">
                <h6 class="fw-bold text-white mb-3">Contact</h6>
                <p class="small mb-1"><i class="bi bi-geo-alt me-2"></i>Esprit, Ariana, Tunisie</p>
                <p class="small mb-1"><i class="bi bi-envelope me-2"></i>contact@najahni.tn</p>
                <p class="small mb-3"><i class="bi bi-telephone me-2"></i>+216 XX XXX XXX</p>
                <div class="d-flex gap-3">
                    <a href="#" class="text-white"><i class="bi bi-facebook" style="font-size:1.2rem"></i></a>
                    <a href="#" class="text-white"><i class="bi bi-linkedin" style="font-size:1.2rem"></i></a>
                    <a href="#" class="text-white"><i class="bi bi-instagram" style="font-size:1.2rem"></i></a>
                </div>
            </div>
        </div>
        <hr style="border-color:rgba(255,255,255,.15)">
        <p class="text-center small mb-0">&copy; {{ "now"|date('Y') }} Najahni — Projet PIDEV 3A Esprit. Tous droits réservés.</p>
    </div>
</footer>

{% if app.user %}
<script>
(function(){
    const badge = document.getElementById('notifBadge');
    const list = document.getElementById('notifList');
    const readAllBtn = document.getElementById('notifReadAll');
    if (!badge || !list) return;

    function renderNotifs(data) {
        if (data.unreadCount > 0) {
            badge.textContent = data.unreadCount > 9 ? '9+' : data.unreadCount;
            badge.classList.remove('d-none');
            document.getElementById('notifBell').classList.add('nj-bell-pulse');
        } else {
            badge.classList.add('d-none');
            document.getElementById('notifBell').classList.remove('nj-bell-pulse');
        }
        if (!data.notifications.length) {
            list.innerHTML = '<div class="text-center text-muted small py-4"><i class="bi bi-bell-slash" style="font-size:1.5rem"></i><p class="mt-2 mb-0">Aucune notification</p></div>';
            return;
        }
        list.innerHTML = data.notifications.map(n => `
            <div class="d-flex align-items-start gap-2 px-3 py-2 border-bottom ${!n.isRead ? 'bg-light' : ''}" style="cursor:pointer">
                <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle mt-1" style="width:32px;height:32px;background:var(--bs-${n.typeColor})20">
                    <i class="bi bi-${n.typeIcon}" style="color:var(--bs-${n.typeColor});font-size:.85rem"></i>
                </div>
                <div class="flex-grow-1 min-width-0">
                    <div class="d-flex justify-content-between">
                        <span class="small fw-semibold text-truncate ${!n.isRead ? '' : 'text-muted'}">${n.title}</span>
                        <small class="text-muted flex-shrink-0 ms-2" style="font-size:.7rem">${n.createdAt}</small>
                    </div>
                    <p class="mb-0 text-muted" style="font-size:.78rem;line-height:1.3">${n.message}</p>
                </div>
                ${!n.isRead ? '<span class="badge rounded-pill bg-primary mt-1" style="font-size:.4rem">&bull;</span>' : ''}
            </div>
        `).join('');
    }

    function loadNotifs() {
        fetch('{{ path("app_api_notifications") }}')
            .then(r => r.json())
            .then(renderNotifs)
            .catch(() => {});
    }

    // Load on dropdown open
    document.getElementById('notifBell').addEventListener('click', loadNotifs);

    // Mark all read
    readAllBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        fetch('{{ path("app_api_notifications_read_all") }}', {method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}})
            .then(() => loadNotifs());
    });

    // Poll every 30s for badge count
    loadNotifs();
    setInterval(loadNotifs, 30000);
})();
</script>
{% endif %}

<script>
(function(){
    /* ── 1. Scroll-reactive navbar (homepage only) ── */
    if(document.body.dataset.page==='home'){
        var nav=document.querySelector('.navbar-nj');
        if(nav){
            nav.classList.add('nj-nav-transparent');
            window.addEventListener('scroll',function(){
                if(window.scrollY>10){nav.classList.remove('nj-nav-transparent')}else{nav.classList.add('nj-nav-transparent')}
            },{passive:true});
        }
    }

    /* ── 7. Announcement bar rotation + dismiss ── */
    var bar=document.getElementById('njAnnounceBar');
    if(bar){
        if(localStorage.getItem('nj_announce_dismissed')){
            bar.remove();
            return;
        }
        var msgs=bar.querySelectorAll('.nj-announce-msg'),cur=0;
        setInterval(function(){
            msgs[cur].classList.remove('active');
            cur=(cur+1)%msgs.length;
            msgs[cur].classList.add('active');
        },4000);
        document.getElementById('njAnnounceClose').addEventListener('click',function(){
            bar.style.transition='height .3s ease,opacity .3s ease';
            bar.style.height='0';
            bar.style.opacity='0';
            bar.style.overflow='hidden';
            localStorage.setItem('nj_announce_dismissed','1');
            setTimeout(function(){bar.remove()},300);
        });
    }
})();
</script>
{% endblock %}
