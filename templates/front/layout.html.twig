{% extends 'base.html.twig' %}

{% block body %}
{# Top Navbar #}
<nav class="navbar navbar-expand-lg navbar-nj navbar-dark sticky-top">
    <div class="container-fluid px-4">
        <a class="navbar-brand text-white" href="{{ path('app_home') }}">Najahni</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_home' ? 'active' }}" href="{{ path('app_home') }}"><i class="bi bi-house-door me-1"></i>Accueil</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_community' ? 'active' }}" href="{{ path('app_community_posts') }}"><i class="bi bi-people me-1"></i>Communauté</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_projet' ? 'active' }}" href="{{ path('app_projet_index') }}"><i class="bi bi-kanban me-1"></i>Projets</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_invest' ? 'active' }}" href="{{ path('app_invest_opportunities') }}"><i class="bi bi-graph-up-arrow me-1"></i>Investissement</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_mentorat' ? 'active' }}" href="{{ path('app_mentorat_requests') }}"><i class="bi bi-mortarboard me-1"></i>Mentorat</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_apprentissage' ? 'active' }}" href="{{ path('app_apprentissage_cours') }}"><i class="bi bi-book me-1"></i>Apprentissage</a></li>
            </ul>
            <ul class="navbar-nav">
                {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}"><i class="bi bi-shield-lock me-1"></i>Admin</a></li>
                {% endif %}
                <li class="nav-item dropdown" id="notifDropdown">
                    <a class="nav-link position-relative" href="#" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" id="notifBell">
                        <i class="bi bi-bell me-1"></i>
                        <span class="badge rounded-pill bg-danger position-absolute top-0 start-100 translate-middle d-none" id="notifBadge" style="font-size:.6rem"></span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end p-0 shadow-lg" style="width:360px;max-height:440px;border-radius:1rem;overflow:hidden">
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom" style="background:var(--nj-gradient)">
                            <span class="fw-bold text-white small">Notifications</span>
                            <button class="btn btn-sm btn-link text-white text-decoration-none p-0" id="notifReadAll" style="font-size:.75rem">Tout marquer lu</button>
                        </div>
                        <div id="notifList" style="max-height:340px;overflow-y:auto">
                            <div class="text-center text-muted small py-4">Chargement...</div>
                        </div>
                        <div class="border-top text-center py-2">
                            <a href="{{ path('app_profile_notifications') }}" class="small text-decoration-none" style="color:var(--nj-primary)">Voir toutes les notifications</a>
                        </div>
                    </div>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>{{ app.user.firstname }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="bi bi-person me-2"></i>Mon Profil</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a></li>
                    </ul>
                </li>
                {% else %}
                <li class="nav-item"><a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#loginModal"><i class="bi bi-box-arrow-in-right me-1"></i>Connexion</a></li>
                <li class="nav-item"><a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#registerModal"><i class="bi bi-person-plus me-1"></i>Inscription</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="container-fluid py-4 px-4 fade-in" style="min-height:calc(100vh - 200px)">
    {% block main %}{% endblock %}
</main>

{% if not app.user %}
{% set recaptcha_on = recaptcha_site_key is not empty and recaptcha_site_key not in ['your_recaptcha_site_key', 'your_recaptcha_secret_key'] %}

{# ========== LOGIN MODAL ========== #}
<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:860px">
        <div class="modal-content border-0 overflow-hidden" style="border-radius:1.5rem">
            <div class="row g-0">
                {# Left — Image #}
                <div class="col-md-5 d-none d-md-block position-relative" style="min-height:520px">
                    <img src="{{ asset('uploads/auth-banner.avif') }}" alt="" class="w-100 h-100 position-absolute top-0 start-0" style="object-fit:cover">
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column justify-content-end p-4" style="background:linear-gradient(0deg,rgba(58,12,163,.85) 0%,rgba(67,97,238,.4) 50%,transparent 100%)">
                        <h4 class="text-white fw-bold mb-2">Bienvenue sur Najahni</h4>
                        <p class="text-white small opacity-90 mb-0">Connectez-vous pour accéder à votre espace personnel et développer vos projets.</p>
                    </div>
                </div>
                {# Right — Form #}
                <div class="col-md-7">
                    <div class="p-4 p-md-5 position-relative">
                        <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Fermer"></button>
                        <div class="text-center mb-4">
                            <h3 class="fw-bold" id="loginModalLabel" style="font-size:1.65rem">Connexion</h3>
                            <p class="text-muted small">Accédez à votre espace Najahni</p>
                        </div>
                        <div class="alert alert-danger d-none rounded-3 py-2" id="loginError" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i><span></span>
                        </div>
                        <form method="post" action="{{ path('app_login') }}" id="loginModalForm" novalidate>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                                    <input type="email" name="_username" class="form-control border-start-0 ps-0" placeholder="votre@email.com" required autofocus>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Mot de passe</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock"></i></span>
                                    <input type="password" name="_password" id="loginModalPw" class="form-control border-start-0 border-end-0 ps-0" placeholder="••••••••" required>
                                    <button class="btn btn-outline-secondary border-start-0" type="button" onclick="(function(b){var i=document.getElementById('loginModalPw'),c=b.querySelector('i');if(i.type==='password'){i.type='text';c.className='bi bi-eye-slash'}else{i.type='password';c.className='bi bi-eye'}})(this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMeModal">
                                    <label class="form-check-label small" for="rememberMeModal">Se souvenir de moi</label>
                                </div>
                                <a href="{{ path('app_forgot_password') }}" class="small text-decoration-none" style="color:var(--nj-primary)">Mot de passe oublié ?</a>
                            </div>
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                            {% if recaptcha_on %}
                            <div class="d-flex justify-content-center mb-3">
                                <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
                            </div>
                            {% endif %}
                            <button type="submit" class="btn btn-nj w-100 py-2 mb-3">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                            </button>
                        </form>
                        <div class="d-flex align-items-center my-2">
                            <hr class="flex-grow-1"><span class="px-3 text-muted small">ou</span><hr class="flex-grow-1">
                        </div>
                        <div class="d-grid gap-2 mb-3">
                            <a href="{{ path('app_google_connect') }}" class="btn btn-outline-secondary py-2 d-flex align-items-center justify-content-center" style="border-radius:.75rem">
                                <svg width="18" height="18" viewBox="0 0 24 24" class="me-2"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                                Continuer avec Google
                            </a>
                            <a href="{{ path('app_face_login') }}" class="btn btn-outline-secondary py-2 d-flex align-items-center justify-content-center" style="border-radius:.75rem">
                                <i class="bi bi-person-bounding-box me-2" style="font-size:1.1rem"></i>Connexion Face ID
                            </a>
                        </div>
                        <p class="text-center text-muted small mb-0">Pas encore de compte ?
                            <a href="#" class="fw-semibold text-decoration-none" style="color:var(--nj-primary)" onclick="bootstrap.Modal.getInstance(document.getElementById('loginModal')).hide();new bootstrap.Modal(document.getElementById('registerModal')).show()">S'inscrire</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ========== REGISTER MODAL ========== #}
<div class="modal fade" id="registerModal" tabindex="-1" aria-labelledby="registerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:920px">
        <div class="modal-content border-0 overflow-hidden" style="border-radius:1.5rem">
            <div class="row g-0">
                {# Left — Image #}
                <div class="col-lg-5 d-none d-lg-block position-relative" style="min-height:620px">
                    <img src="{{ asset('uploads/auth-banner.avif') }}" alt="" class="w-100 h-100 position-absolute top-0 start-0" style="object-fit:cover">
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column justify-content-end p-4" style="background:linear-gradient(0deg,rgba(114,9,183,.85) 0%,rgba(67,97,238,.4) 50%,transparent 100%)">
                        <h4 class="text-white fw-bold mb-2">Rejoignez Najahni</h4>
                        <p class="text-white small opacity-90 mb-3">Faites partie de la communauté d'innovation tunisienne.</p>
                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-items-center gap-2 text-white">
                                <i class="bi bi-check-circle-fill" style="font-size:.8rem"></i>
                                <small class="opacity-90">Lancez vos projets innovants</small>
                            </div>
                            <div class="d-flex align-items-center gap-2 text-white">
                                <i class="bi bi-check-circle-fill" style="font-size:.8rem"></i>
                                <small class="opacity-90">Trouvez mentors & investisseurs</small>
                            </div>
                            <div class="d-flex align-items-center gap-2 text-white">
                                <i class="bi bi-check-circle-fill" style="font-size:.8rem"></i>
                                <small class="opacity-90">Développez votre business</small>
                            </div>
                        </div>
                    </div>
                </div>
                {# Right — Form #}
                <div class="col-lg-7">
                    <div class="p-4 p-lg-4 position-relative">
                        <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Fermer"></button>
                        <div class="text-center mb-3">
                            <h3 class="fw-bold" id="registerModalLabel" style="font-size:1.5rem">Créer un compte</h3>
                            <p class="text-muted small mb-0">Remplissez vos informations pour commencer</p>
                        </div>
                        <form method="post" action="{{ path('app_register') }}" id="registerModalForm" novalidate>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label class="form-label fw-semibold small mb-1">Prénom</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                                        <input type="text" name="firstname" class="form-control border-start-0 ps-0" placeholder="Votre prénom" required minlength="2" maxlength="100">
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small mb-1">Nom</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-fill"></i></span>
                                        <input type="text" name="lastname" class="form-control border-start-0 ps-0" placeholder="Votre nom" required minlength="2" maxlength="100">
                                    </div>
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label fw-semibold small mb-1">Email</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                                    <input type="email" name="email" class="form-control border-start-0 ps-0" placeholder="votre@email.com" required>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label class="form-label fw-semibold small mb-1">Téléphone</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-phone"></i></span>
                                        <input type="tel" name="phone" class="form-control border-start-0 ps-0" placeholder="+216 XX XXX XXX" pattern="^\+?[0-9\s\-]{7,20}$" maxlength="20">
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small mb-1">Rôle</label>
                                    <select name="role" class="form-select form-select-sm" required>
                                        <option value="ENTREPRENEUR">Entrepreneur</option>
                                        <option value="MENTOR">Mentor</option>
                                        <option value="INVESTISSEUR">Investisseur</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label class="form-label fw-semibold small mb-1">Mot de passe</label>
                                    <div class="input-group input-group-sm">
                                        <input type="password" name="password" id="regModalPw" class="form-control border-end-0" placeholder="Min. 6 caractères" required minlength="6" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{6,}">
                                        <button class="btn btn-outline-secondary border-start-0 btn-sm" type="button" onclick="(function(b){var i=document.getElementById('regModalPw'),c=b.querySelector('i');if(i.type==='password'){i.type='text';c.className='bi bi-eye-slash'}else{i.type='password';c.className='bi bi-eye'}})(this)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small mb-1">Confirmer</label>
                                    <div class="input-group input-group-sm">
                                        <input type="password" name="confirm_password" id="regModalConfirm" class="form-control border-end-0" placeholder="Confirmer" required minlength="6">
                                        <button class="btn btn-outline-secondary border-start-0 btn-sm" type="button" onclick="(function(b){var i=document.getElementById('regModalConfirm'),c=b.querySelector('i');if(i.type==='password'){i.type='text';c.className='bi bi-eye-slash'}else{i.type='password';c.className='bi bi-eye'}})(this)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-2">
                                <div class="progress mb-1" style="height:3px">
                                    <div class="progress-bar" id="pwModalStrength" role="progressbar" style="width:0%"></div>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    <small id="mrLen" class="text-muted" style="font-size:.7rem"><i class="bi bi-circle"></i> 6+ car.</small>
                                    <small id="mrUp" class="text-muted" style="font-size:.7rem"><i class="bi bi-circle"></i> Majuscule</small>
                                    <small id="mrLow" class="text-muted" style="font-size:.7rem"><i class="bi bi-circle"></i> Minuscule</small>
                                    <small id="mrDig" class="text-muted" style="font-size:.7rem"><i class="bi bi-circle"></i> Chiffre</small>
                                </div>
                            </div>
                            {% if recaptcha_on %}
                            <div class="d-flex justify-content-center mb-2">
                                <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
                            </div>
                            {% endif %}
                            <button type="submit" class="btn btn-nj w-100 py-2 mb-2">
                                <i class="bi bi-person-plus me-2"></i>Créer mon compte
                            </button>
                        </form>
                        <div class="d-flex align-items-center my-2">
                            <hr class="flex-grow-1"><span class="px-3 text-muted small">ou</span><hr class="flex-grow-1">
                        </div>
                        <div class="d-grid mb-2">
                            <a href="{{ path('app_google_connect') }}" class="btn btn-outline-secondary py-2 d-flex align-items-center justify-content-center" style="border-radius:.75rem">
                                <svg width="18" height="18" viewBox="0 0 24 24" class="me-2"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                                S'inscrire avec Google
                            </a>
                        </div>
                        <p class="text-center text-muted small mb-0">Déjà un compte ?
                            <a href="#" class="fw-semibold text-decoration-none" style="color:var(--nj-primary)" onclick="bootstrap.Modal.getInstance(document.getElementById('registerModal')).hide();new bootstrap.Modal(document.getElementById('loginModal')).show()">Se connecter</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# Footer #}
