{% extends 'front/layout.html.twig' %}

{% block title %}Modifier mon profil - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>Modifier mon profil</h2>
    <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-4">Informations personnelles</h5>
            <form method="post" enctype="multipart/form-data" novalidate>
                {% set e = fieldErrors|default({}) %}
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Prénom</label>
                        <input type="text" name="firstname" class="form-control {{ e.firstname is defined ? 'is-invalid' }}" value="{{ app.user.firstname }}" required minlength="2" maxlength="100">
                        {% if e.firstname is defined %}<div class="invalid-feedback d-block">{{ e.firstname }}</div>{% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nom</label>
                        <input type="text" name="lastname" class="form-control {{ e.lastname is defined ? 'is-invalid' }}" value="{{ app.user.lastname }}" required minlength="2" maxlength="100">
                        {% if e.lastname is defined %}<div class="invalid-feedback d-block">{{ e.lastname }}</div>{% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" name="email" class="form-control {{ e.email is defined ? 'is-invalid' }}" value="{{ app.user.email }}" required maxlength="255">
                        {% if e.email is defined %}<div class="invalid-feedback d-block">{{ e.email }}</div>{% endif %}
                        {% if not app.user.verified %}
                            <div class="mt-1" id="emailVerifZone">
                                <small class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Non vérifié</small>
                                <button type="button" class="btn btn-sm btn-outline-warning ms-2" id="sendVerifBtn">
                                    <i class="bi bi-envelope-check me-1"></i>Vérifier maintenant
                                </button>
                                <div id="verifCodeForm" class="mt-2 d-none">
                                    <div class="input-group input-group-sm">
                                        <input type="text" id="verifCodeInput" class="form-control" placeholder="Code à 4 chiffres" maxlength="4" pattern="\d{4}">
                                        <button type="button" class="btn btn-success" id="confirmVerifBtn">
                                            <i class="bi bi-check-lg me-1"></i>Confirmer
                                        </button>
                                    </div>
                                    <small class="text-muted">Vérifiez votre boîte mail.</small>
                                </div>
                            </div>
                        {% else %}
                            <small class="text-success"><i class="bi bi-check-circle me-1"></i>Vérifié</small>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Téléphone</label>
                        <input type="tel" name="phone" class="form-control {{ e.phone is defined ? 'is-invalid' }}" value="{{ app.user.phone }}" pattern="^\+?[0-9\s\-]{7,20}$" maxlength="20" title="Numéro de téléphone valide (7-20 chiffres)">
                        {% if e.phone is defined %}<div class="invalid-feedback d-block">{{ e.phone }}</div>{% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Date de naissance</label>
                        <input type="date" name="date_of_birth" class="form-control {{ e.dateOfBirth is defined ? 'is-invalid' }}" value="{{ app.user.dateOfBirth ? app.user.dateOfBirth|date('Y-m-d') }}" max="{{ 'now'|date('Y-m-d') }}">
                        {% if e.dateOfBirth is defined %}<div class="invalid-feedback d-block">{{ e.dateOfBirth }}</div>{% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Langue préférée</label>
                        <select name="preferred_language" class="form-select">
                            <option value="fr" {{ app.user.preferredLanguage == 'fr' ? 'selected' }}>🇫🇷 Français</option>
                            <option value="en" {{ app.user.preferredLanguage == 'en' ? 'selected' }}>🇬🇧 English</option>
                            <option value="ar" {{ app.user.preferredLanguage == 'ar' ? 'selected' }}>🇹🇳 العربية</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Bio</label>
                        <textarea name="bio" class="form-control {{ e.bio is defined ? 'is-invalid' }}" rows="3" maxlength="1000">{{ app.user.bio }}</textarea>
                        {% if e.bio is defined %}<div class="invalid-feedback d-block">{{ e.bio }}</div>{% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Entreprise</label>
                        <input type="text" name="company_name" class="form-control {{ e.companyName is defined ? 'is-invalid' }}" value="{{ app.user.companyName }}" maxlength="200">
                        {% if e.companyName is defined %}<div class="invalid-feedback d-block">{{ e.companyName }}</div>{% endif %}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">LinkedIn</label>
                        <input type="url" name="linkedin_url" class="form-control {{ e.linkedinUrl is defined ? 'is-invalid' }}" value="{{ app.user.linkedinUrl }}">
                        {% if e.linkedinUrl is defined %}<div class="invalid-feedback d-block">{{ e.linkedinUrl }}</div>{% endif %}
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Adresse</label>
                        <input type="text" name="address" class="form-control {{ e.address is defined ? 'is-invalid' }}" value="{{ app.user.address }}" maxlength="300">
                        {% if e.address is defined %}<div class="invalid-feedback d-block">{{ e.address }}</div>{% endif %}
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Photo de profil</label>
                        <input type="file" name="profile_picture" class="form-control" accept="image/*">
                        {% if app.user.profilePicture %}
                            <div class="mt-2 d-flex align-items-center gap-2">
                                <img src="{{ app.user.profilePicture }}" class="rounded-circle" width="40" height="40" style="object-fit:cover" alt="">
                                <small class="text-muted">Photo actuelle</small>
                            </div>
                        {% endif %}
                    </div>
                </div>
                <button type="submit" class="btn btn-nj mt-4"><i class="bi bi-check-lg me-2"></i>Enregistrer</button>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        {# Change Password #}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-4"><i class="bi bi-shield-lock me-2"></i>Changer le mot de passe</h5>
            <form method="post" action="{{ path('app_profile_password') }}" novalidate>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Mot de passe actuel</label>
                    <div class="input-group">
                        <input type="password" name="current_password" id="curPw" class="form-control border-end-0" required>
                        <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePw('curPw',this)"><i class="bi bi-eye"></i></button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nouveau mot de passe</label>
                    <div class="input-group">
                        <input type="password" name="new_password" id="newPw" class="form-control border-end-0" required minlength="6">
                        <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePw('newPw',this)"><i class="bi bi-eye"></i></button>
                    </div>
                    <div class="progress mt-1" style="height:3px">
                        <div class="progress-bar" id="pwBar" style="width:0%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Confirmer</label>
                    <input type="password" name="confirm_password" class="form-control" required minlength="6">
                </div>
                <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-key me-2"></i>Modifier</button>
            </form>
        </div>

        {# Face ID Registration #}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-person-bounding-box me-2"></i>Face ID</h5>
            {% if app.user.faceRegistered %}
                <div class="alert alert-success d-flex align-items-center mb-3" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <span>Visage enregistré. Vous pouvez vous connecter avec Face ID.</span>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary btn-sm" id="faceReRegisterBtn" data-bs-toggle="modal" data-bs-target="#faceModal">
                        <i class="bi bi-arrow-repeat me-1"></i>Ré-enregistrer mon visage
                    </button>
                    <button class="btn btn-outline-danger btn-sm" id="faceRemoveBtn">
                        <i class="bi bi-trash me-1"></i>Supprimer Face ID
                    </button>
                </div>
            {% else %}
                <p class="text-muted small mb-3">Enregistrez votre visage pour vous connecter sans mot de passe.</p>
                <button class="btn btn-outline-primary w-100" id="faceRegisterBtn" data-bs-toggle="modal" data-bs-target="#faceModal">
                    <i class="bi bi-camera me-2"></i>Enregistrer mon visage
                </button>
            {% endif %}
        </div>

        {# Face ID Modal #}
        <div class="modal fade" id="faceModal" tabindex="-1" aria-labelledby="faceModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:1.25rem;border:none">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold" id="faceModalLabel">
                            <i class="bi bi-person-bounding-box me-2" style="color:var(--nj-accent)"></i>Enregistrement Face ID
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small mb-3">Placez votre visage bien en face de la caméra, dans un endroit bien éclairé.</p>
                        <div class="rounded-4 overflow-hidden bg-dark mb-3 position-relative" style="height:300px">
                            <video id="faceVideo" autoplay playsinline muted class="w-100 h-100" style="object-fit:cover;transform:scaleX(-1)"></video>
                            <canvas id="faceOverlay" class="position-absolute top-0 start-0 w-100 h-100 d-none" style="pointer-events:none;transform:scaleX(-1)"></canvas>
                            <div id="facePlaceholder" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center text-white">
                                <div class="text-center">
                                    <div class="spinner-border text-light mb-2" role="status"></div>
                                    <p class="mb-0 opacity-75 small">Initialisation de la caméra...</p>
                                </div>
                            </div>
                        </div>
                        <div id="faceStatus" class="text-center mb-3"></div>
                        <div class="d-grid">
                            <button class="btn btn-nj py-2" id="faceScanBtn" disabled>
                                <i class="bi bi-person-check me-2"></i>Scanner et enregistrer
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Quick Links #}
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-link-45deg me-2"></i>Liens rapides</h5>
            <div class="d-grid gap-2">
                <a href="{{ path('app_profile_login_history') }}" class="btn btn-outline-secondary btn-sm text-start">
                    <i class="bi bi-clock-history me-2"></i>Historique de connexion
                </a>
                <a href="{{ path('app_profile_notifications') }}" class="btn btn-outline-secondary btn-sm text-start">
                    <i class="bi bi-bell me-2"></i>Notifications
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
function togglePw(id, btn) {
    const inp = document.getElementById(id);
    const icon = btn.querySelector('i');
    if (inp.type === 'password') { inp.type = 'text'; icon.className = 'bi bi-eye-slash'; }
    else { inp.type = 'password'; icon.className = 'bi bi-eye'; }
}
document.getElementById('newPw').addEventListener('input', function() {
    const v = this.value;
    let score = (v.length >= 6 ? 1 : 0) + (/[A-Z]/.test(v) ? 1 : 0) + (/[a-z]/.test(v) ? 1 : 0) + (/\d/.test(v) ? 1 : 0);
    const bar = document.getElementById('pwBar');
    bar.style.width = (score * 25) + '%';
    bar.className = 'progress-bar ' + ['', 'bg-danger', 'bg-warning', 'bg-info', 'bg-success'][score];
});

// Email verification
(function(){
    const sendBtn = document.getElementById('sendVerifBtn');
    if (!sendBtn) return;
    const codeForm = document.getElementById('verifCodeForm');
    const codeInput = document.getElementById('verifCodeInput');
    const confirmBtn = document.getElementById('confirmVerifBtn');
    const zone = document.getElementById('emailVerifZone');
    const url = '{{ path("app_profile_verify_email") }}';

    sendBtn.addEventListener('click', function(){
        sendBtn.disabled = true;
        sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Envoi...';
        fetch(url, {
            method: 'POST',
            headers: {'X-Requested-With':'XMLHttpRequest','Content-Type':'application/x-www-form-urlencoded'},
            body: 'action=send'
        }).then(r => r.json()).then(data => {
            if (data.success) {
                codeForm.classList.remove('d-none');
                sendBtn.classList.add('d-none');
                codeInput.focus();
            } else {
                sendBtn.disabled = false;
                sendBtn.innerHTML = '<i class="bi bi-envelope-check me-1"></i>Vérifier maintenant';
                alert(data.message);
            }
        }).catch(() => {
            sendBtn.disabled = false;
            sendBtn.innerHTML = '<i class="bi bi-envelope-check me-1"></i>Vérifier maintenant';
        });
    });

    confirmBtn.addEventListener('click', function(){
        const code = codeInput.value.trim();
        if (!/^\d{4}$/.test(code)) { codeInput.classList.add('is-invalid'); return; }
        confirmBtn.disabled = true;
        confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        fetch(url, {
            method: 'POST',
            headers: {'X-Requested-With':'XMLHttpRequest','Content-Type':'application/x-www-form-urlencoded'},
            body: 'action=verify&code=' + encodeURIComponent(code)
        }).then(r => r.json()).then(data => {
            if (data.success) {
                zone.innerHTML = '<small class="text-success"><i class="bi bi-check-circle me-1"></i>Vérifié</small>';
            } else {
                codeInput.classList.add('is-invalid');
                confirmBtn.disabled = false;
                confirmBtn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Confirmer';
            }
        }).catch(() => {
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Confirmer';
        });
    });

    codeInput.addEventListener('input', () => codeInput.classList.remove('is-invalid'));
    codeInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); confirmBtn.click(); } });
})();

// Face ID Registration (modal)
(function(){
    var MODEL_URL = '/models';
    var faceVideo   = document.getElementById('faceVideo');
    var faceOverlay = document.getElementById('faceOverlay');
    var placeholder = document.getElementById('facePlaceholder');
    var faceStatus  = document.getElementById('faceStatus');
    var scanBtn     = document.getElementById('faceScanBtn');
    var removeBtn   = document.getElementById('faceRemoveBtn');
    var modalEl     = document.getElementById('faceModal');
    var faceStream  = null;
    var modelsReady = false;

    function setStatus(html, cls) {
        faceStatus.innerHTML = '<div class="' + (cls || '') + ' small">' + html + '</div>';
    }

    async function initCameraAndModels() {
        setStatus('<div class="spinner-border spinner-border-sm me-1" role="status"></div> Chargement des modèles...', 'text-muted');
        placeholder.classList.remove('d-none');
        scanBtn.disabled = true;

        try {
            // Load models
            if (!modelsReady) {
                await Promise.all([
                    faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL),
                    faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL),
                    faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL),
                ]);
                modelsReady = true;
            }
        } catch(e) {
            setStatus('<i class="bi bi-exclamation-triangle me-1"></i>Erreur de chargement des modèles. Rechargez la page.', 'text-danger');
            placeholder.innerHTML = '<div class="text-center text-white"><i class="bi bi-exclamation-triangle" style="font-size:3rem;opacity:.5"></i><p class="mt-2 mb-0 opacity-75 small">Modèles indisponibles</p></div>';
            return;
        }

        setStatus('<div class="spinner-border spinner-border-sm me-1" role="status"></div> Activation de la caméra...', 'text-muted');

        try {
            faceStream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: 'user', width: { ideal: 640 }, height: { ideal: 480 } }
            });
            faceVideo.srcObject = faceStream;
            await faceVideo.play();
            placeholder.classList.add('d-none');
            scanBtn.disabled = false;
            setStatus('<i class="bi bi-check-circle text-success me-1"></i>Caméra activée. Placez votre visage bien en face puis cliquez le bouton.', 'text-muted');
        } catch(e) {
            var msg = 'Impossible d\'accéder à la caméra.';
            if (e.name === 'NotAllowedError') msg += ' Autorisez l\'accès dans votre navigateur.';
            else if (e.name === 'NotFoundError') msg += ' Aucune caméra détectée.';
            else if (e.name === 'NotReadableError') msg += ' La caméra est utilisée par une autre application.';
            setStatus('<i class="bi bi-exclamation-triangle me-1"></i>' + msg, 'text-danger');
            placeholder.innerHTML = '<div class="text-center text-white"><i class="bi bi-camera-video-off" style="font-size:3rem;opacity:.5"></i><p class="mt-2 mb-0 opacity-75 small">Caméra indisponible</p></div>';
        }
    }

    function stopCamera() {
        if (faceStream) { faceStream.getTracks().forEach(function(t){ t.stop(); }); faceStream = null; }
        faceVideo.srcObject = null;
        faceOverlay.classList.add('d-none');
        placeholder.classList.remove('d-none');
        placeholder.innerHTML = '<div class="text-center"><div class="spinner-border text-light mb-2" role="status"></div><p class="mb-0 opacity-75 small text-white">Initialisation de la caméra...</p></div>';
        scanBtn.disabled = true;
        faceStatus.innerHTML = '';
    }

    // Open modal → start camera
    if (modalEl) {
        modalEl.addEventListener('shown.bs.modal', function() { initCameraAndModels(); });
        modalEl.addEventListener('hidden.bs.modal', function() { stopCamera(); });
    }

    // Remove Face ID
    if (removeBtn) {
        removeBtn.addEventListener('click', async function() {
            if (!confirm('Supprimer votre Face ID ?')) return;
            removeBtn.disabled = true;
            try {
                var res = await fetch('/api/face-unregister', { method:'POST', headers:{'Content-Type':'application/json'} });
                var data = await res.json();
                if (data.success) location.reload();
                else { alert(data.message || 'Erreur'); removeBtn.disabled = false; }
            } catch(e) { alert('Erreur réseau'); removeBtn.disabled = false; }
        });
    }

    // Scan face
    if (scanBtn) {
        scanBtn.addEventListener('click', async function() {
            scanBtn.disabled = true;
            scanBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Analyse en cours...';
            setStatus('<div class="spinner-border spinner-border-sm me-1" role="status"></div> Détection du visage...', 'text-muted');

            try {
                var detection = await faceapi
                    .detectSingleFace(faceVideo, new faceapi.TinyFaceDetectorOptions({ inputSize: 416, scoreThreshold: 0.5 }))
                    .withFaceLandmarks()
                    .withFaceDescriptor();

                if (!detection) {
                    setStatus('<i class="bi bi-exclamation-triangle me-1"></i>Aucun visage détecté. Vérifiez l\'éclairage et réessayez.', 'text-danger');
                    scanBtn.disabled = false;
                    scanBtn.innerHTML = '<i class="bi bi-person-check me-2"></i>Scanner et enregistrer';
                    return;
                }

                // Draw face detection on overlay
                var dims = faceapi.matchDimensions(faceOverlay, faceVideo, true);
                faceOverlay.classList.remove('d-none');
                faceapi.draw.drawDetections(faceOverlay, faceapi.resizeResults(detection, dims));
                faceapi.draw.drawFaceLandmarks(faceOverlay, faceapi.resizeResults(detection, dims));

                setStatus('<div class="spinner-border spinner-border-sm me-1" role="status"></div> Enregistrement du visage...', 'text-muted');

                var descriptor = Array.from(detection.descriptor);
                var res = await fetch('/api/face-register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ descriptor: descriptor })
                });
                var data = await res.json();

                if (data.success) {
                    setStatus('<i class="bi bi-check-circle-fill me-1"></i>' + data.message, 'text-success fw-semibold');
                    scanBtn.innerHTML = '<i class="bi bi-check-lg me-2"></i>Enregistré !';
                    setTimeout(function(){ bootstrap.Modal.getInstance(modalEl).hide(); location.reload(); }, 1500);
                } else {
                    setStatus('<i class="bi bi-exclamation-triangle me-1"></i>' + (data.message || 'Erreur'), 'text-danger');
                    scanBtn.disabled = false;
                    scanBtn.innerHTML = '<i class="bi bi-person-check me-2"></i>Scanner et enregistrer';
                }
            } catch(e) {
                setStatus('<i class="bi bi-exclamation-triangle me-1"></i>Erreur lors de l\'analyse. Réessayez.', 'text-danger');
                scanBtn.disabled = false;
                scanBtn.innerHTML = '<i class="bi bi-person-check me-2"></i>Scanner et enregistrer';
            }
        });
    }

    window.addEventListener('beforeunload', stopCamera);
})();
</script>
{% endblock %}
