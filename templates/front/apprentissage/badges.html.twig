{% extends 'front/layout.html.twig' %}

{% block title %}Badges - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-award me-2"></i>Badges</h2>
    <a href="{{ path('app_apprentissage_cours') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Cours</a>
</div>

{% if badges|length > 0 %}
<div class="row g-4">
    {% for badge in badges %}
    <div class="col-md-4 col-lg-3">
        <div class="card border-0 shadow-sm h-100 text-center" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="mb-3" style="font-size:3rem">{{ badge.icone ?? '' }}</div>
                <h5 class="fw-bold mb-1">{{ badge.nom }}</h5>
                <span class="badge mb-2 {{ badge.rarete == 'LEGENDAIRE' ? 'bg-warning text-dark' : (badge.rarete == 'EPIQUE' ? 'bg-danger' : (badge.rarete == 'RARE' ? 'bg-primary' : 'bg-secondary')) }}">
                    {{ badge.rarete }}
                </span>
                <p class="text-muted small mb-2">{{ badge.description }}</p>
                <div class="small text-muted">
                    {% if badge.pointsRequis %}<p class="mb-0"><i class="bi bi-star me-1"></i>{{ badge.pointsRequis }} XP requis</p>{% endif %}
                    {% if badge.coursRequis %}<p class="mb-0"><i class="bi bi-book me-1"></i>{{ badge.coursRequis }} cours requis</p>{% endif %}
                    {% if badge.niveauRequis %}<p class="mb-0"><i class="bi bi-bar-chart me-1"></i>Niveau {{ badge.niveauRequis }}</p>{% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="text-center py-5">
    <div class="text-center"><i class="bi bi-trophy" style="font-size:4rem;color:var(--nj-primary)"></i></div>
    <h4 class="fw-bold mt-3">Aucun badge disponible</h4>
</div>
{% endif %}
{% endblock %}
