{% extends 'front/layout.html.twig' %}

{% block title %}Cours - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-book me-2"></i>Cours</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('app_apprentissage_progression') }}" class="btn btn-outline-primary"><i class="bi bi-bar-chart me-1"></i>Ma Progression</a>
        <a href="{{ path('app_apprentissage_badges') }}" class="btn btn-outline-secondary"><i class="bi bi-award me-1"></i>Badges</a>
    </div>
</div>

{# Search #}
<div class="card border-0 shadow-sm mb-4" style="border-radius:1rem">
    <div class="card-body p-3">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="q" class="form-control" placeholder="Rechercher un cours..." value="{{ search }}">
            <button class="btn btn-nj px-4"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>

{% if cours|length > 0 %}
<div class="row g-4">
    {% for c in cours %}
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:1rem">
            {% if c.imageUrl %}
            <img src="{{ c.imageUrl }}" class="card-img-top" style="height:160px;object-fit:cover;border-radius:1rem 1rem 0 0" alt="{{ c.titre }}">
            {% else %}
            <div class="text-center py-4" style="background:var(--nj-gradient);border-radius:1rem 1rem 0 0">
                <i class="bi bi-book text-white" style="font-size:3rem"></i>
            </div>
            {% endif %}
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="fw-bold mb-0">{{ c.titre }}</h5>
                    {% if c.certification %}<span class="badge bg-success">🎓 Certifiant</span>{% endif %}
                </div>
                <p class="text-muted small mb-3">{{ c.description|length > 100 ? c.description|slice(0,100) ~ '...' : c.description }}</p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge bg-primary bg-opacity-10 text-primary">{{ c.categorie }}</span>
                    <span class="badge bg-info bg-opacity-10 text-info">{{ c.niveauDifficulte }}</span>
                    <span class="badge bg-warning bg-opacity-10 text-dark">{{ c.pointsXp }} XP</span>
                </div>
                {% if c.dureeEstimee %}<p class="small text-muted mb-3"><i class="bi bi-clock me-1"></i>{{ c.dureeEstimee }} min</p>{% endif %}
                <a href="{{ path('app_apprentissage_cours_show', {id: c.id}) }}" class="btn btn-sm btn-nj w-100">
                    <i class="bi bi-play-circle me-1"></i>Voir le cours
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="text-center py-5">
    <div style="font-size:5rem">📚</div>
    <h4 class="fw-bold mt-3">Aucun cours disponible</h4>
</div>
{% endif %}
{% endblock %}
