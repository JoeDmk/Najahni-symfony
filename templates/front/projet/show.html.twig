{% extends 'front/layout.html.twig' %}

{% block title %}{{ projet.titre }} - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="{{ path('app_projet_index') }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Mes Projets</a>
        <h2 class="fw-bold mt-2 mb-0">{{ projet.titre }}</h2>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('app_projet_edit', {id: projet.id}) }}" class="btn btn-nj"><i class="bi bi-pencil me-1"></i>Modifier</a>
        <form method="post" action="{{ path('app_projet_delete', {id: projet.id}) }}" onsubmit="return confirm('Supprimer ce projet ?')">
            <button class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        {# Project Details #}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge rounded-pill {{ projet.statutProjet == 'EVALUE' ? 'bg-success' : (projet.statutProjet == 'SOUMIS' ? 'bg-warning text-dark' : 'bg-secondary') }}">{{ projet.statutProjet }}</span>
                {% if projet.secteur %}<span class="badge bg-primary bg-opacity-10 text-primary">{{ projet.secteur }}</span>{% endif %}
                {% if projet.etape %}<span class="badge bg-info bg-opacity-10 text-info">{{ projet.etape }}</span>{% endif %}
            </div>
            <h5 class="fw-bold">Description</h5>
            <p>{{ projet.description }}</p>
        </div>

        {# Business Data #}
        {% if projet.donneesBusiness %}
        {% set db = projet.donneesBusiness %}
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-4"><i class="bi bi-graph-up me-2"></i>Données Business</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background:rgba(67,97,238,.05)">
                        <p class="text-muted small mb-1">Taille du marché</p>
                        <h5 class="fw-bold mb-0">{{ db.tailleMarche|number_format(0, ',', ' ') }} DT</h5>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background:rgba(114,9,183,.05)">
                        <p class="text-muted small mb-1">Coûts estimés</p>
                        <h5 class="fw-bold mb-0">{{ db.coutsEstimes|number_format(0, ',', ' ') }} DT</h5>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background:rgba(247,37,133,.05)">
                        <p class="text-muted small mb-1">Revenus attendus</p>
                        <h5 class="fw-bold mb-0">{{ db.revenusAttendus|number_format(0, ',', ' ') }} DT</h5>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background:rgba(67,97,238,.05)">
                        <p class="text-muted small mb-1">Modèle de revenu</p>
                        <h6 class="fw-semibold mb-0">{{ db.modeleRevenu }}</h6>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background:rgba(114,9,183,.05)">
                        <p class="text-muted small mb-1">Niveau de risque</p>
                        <h6 class="fw-semibold mb-0">{{ db.niveauRisque }}</h6>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background:rgba(247,37,133,.05)">
                        <p class="text-muted small mb-1">Force d'équipe</p>
                        <h6 class="fw-semibold mb-0">{{ db.forceEquipe }}/10</h6>
                    </div>
                </div>
            </div>

            {% if db.scoreFinancier %}
            <hr>
            <h6 class="fw-bold mb-3">Scores calculés</h6>
            <div class="row g-3">
                {% for label, val in {
                    'Score Financier': db.scoreFinancier,
                    'Score Marché': db.scoreMarche,
                    'Score Équipe': db.scoreEquipeCalcule,
                    'Score Risque': db.scoreRisqueCalcule
                } %}
                <div class="col-md-3">
                    <p class="text-muted small mb-1">{{ label }}</p>
                    <div class="progress" style="height:8px">
                        <div class="progress-bar" style="width:{{ val }}%;background:var(--nj-gradient)"></div>
                    </div>
                    <small>{{ val|number_format(1) }}%</small>
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
        {% endif %}
    </div>

    {# Sidebar #}
    <div class="col-md-4">
        {% if projet.scoreGlobal %}
        <div class="card border-0 shadow-sm p-4 text-center mb-4" style="border-radius:1rem">
            <h6 class="fw-bold text-muted">Score Global</h6>
            <div class="display-3 fw-bold" style="color:var(--nj-primary)">{{ projet.scoreGlobal|number_format(1) }}</div>
            <div class="progress mt-2" style="height:10px">
                <div class="progress-bar" style="width:{{ projet.scoreGlobal }}%;background:var(--nj-gradient)"></div>
            </div>
        </div>
        {% endif %}

        {% if projet.diagnosticIa %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h6 class="fw-bold"><i class="bi bi-robot me-2"></i>Diagnostic IA</h6>
            <p class="text-muted small">{{ projet.diagnosticIa }}</p>
        </div>
        {% endif %}

        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h6 class="fw-bold mb-3">Informations</h6>
            <ul class="list-unstyled mb-0">
                <li class="mb-2"><i class="bi bi-calendar text-muted me-2"></i>Créé le {{ projet.dateCreation|date('d/m/Y') }}</li>
                {% if projet.dateSoumission %}<li class="mb-2"><i class="bi bi-send text-muted me-2"></i>Soumis le {{ projet.dateSoumission|date('d/m/Y') }}</li>{% endif %}
                {% if projet.dateEvaluation %}<li class="mb-2"><i class="bi bi-check-circle text-muted me-2"></i>Évalué le {{ projet.dateEvaluation|date('d/m/Y') }}</li>{% endif %}
                <li><i class="bi bi-person text-muted me-2"></i>{% if projet.user %}<a href="{{ path('app_user_profile', {id: projet.user.id}) }}" class="text-decoration-none">{{ projet.user.firstname }} {{ projet.user.lastname }}</a>{% else %}Non assigné{% endif %}</li>
            </ul>
        </div>
    </div>
</div>
{% endblock %}
