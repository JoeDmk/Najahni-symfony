<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #333; line-height: 1.6; }
        h1 { color: #4361ee; font-size: 22px; border-bottom: 3px solid #4361ee; padding-bottom: 8px; }
        h2 { color: #7209b7; font-size: 14px; margin-top: 20px; }
        .header { text-align: center; margin-bottom: 25px; padding: 20px; background: #f8f9fa; border-radius: 8px; }
        .header h1 { border: none; margin-bottom: 5px; }
        .header p { color: #666; margin: 3px 0; }
        .section { margin-bottom: 15px; }
        .box { background: #f8f9fa; padding: 10px; border-radius: 6px; margin-bottom: 8px; border-left: 3px solid #4361ee; }
        table { width: 100%; border-collapse: collapse; margin: 10px 0; }
        th, td { border: 1px solid #dee2e6; padding: 6px; text-align: left; }
        th { background: #4361ee; color: white; text-align: center; }
        .grid { display: table; width: 100%; }
        .grid-cell { display: table-cell; width: 33%; padding: 5px; }
        .metric { text-align: center; background: #f8f9fa; padding: 10px; border-radius: 6px; }
        .metric .value { font-size: 20px; font-weight: bold; color: #4361ee; }
        .metric .label { font-size: 9px; color: #666; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 10px; background: #e8edff; color: #4361ee; }
        .footer { text-align: center; margin-top: 25px; padding-top: 10px; border-top: 1px solid #ddd; color: #999; font-size: 9px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Fiche Projet</h1>
        <p style="font-size: 18px; font-weight: bold;">{{ projet.titre }}</p>
        <p>
            <span class="badge">{{ projet.secteur }}</span>
            <span class="badge" style="background:#e0f7fa;color:#0097a7">{{ projet.etape }}</span>
            <span class="badge" style="background:{{ projet.statutProjet == 'EVALUE' ? '#d1fae5;color:#065f46' : (projet.statutProjet == 'SOUMIS' ? '#fef3cd;color:#856404' : '#e2e3e5;color:#41464b') }}">{{ projet.statutProjet }}</span>
        </p>
    </div>

    <div class="section">
        <h2>Description</h2>
        <p>{{ projet.description }}</p>
    </div>

    {% if projet.scoreGlobal %}
    <div class="section">
        <div class="grid">
            <div class="grid-cell">
                <div class="metric">
                    <div class="value">{{ projet.scoreGlobal|number_format(1) }}</div>
                    <div class="label">SCORE GLOBAL /100</div>
                </div>
            </div>
            <div class="grid-cell">
                <div class="metric">
                    <div class="value">{{ projet.statut }}</div>
                    <div class="label">STATUT</div>
                </div>
            </div>
            <div class="grid-cell">
                <div class="metric">
                    <div class="value">{{ projet.dateCreation|date('d/m/Y') }}</div>
                    <div class="label">DATE CRÉATION</div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {% if projet.donneesBusiness %}
    {% set db = projet.donneesBusiness %}
    <div class="section">
        <h2>Données Business</h2>
        <table>
            <tr><th>Indicateur</th><th>Valeur</th></tr>
            <tr><td>Taille du marché</td><td>{{ db.tailleMarche|number_format(0, ',', ' ') }} DT</td></tr>
            <tr><td>Modèle de revenu</td><td>{{ db.modeleRevenu }}</td></tr>
            <tr><td>Coûts estimés</td><td>{{ db.coutsEstimes|number_format(0, ',', ' ') }} DT</td></tr>
            <tr><td>Revenus attendus</td><td>{{ db.revenusAttendus|number_format(0, ',', ' ') }} DT</td></tr>
            <tr><td>Marge estimée</td><td style="color:{{ db.margeEstimee >= 0 ? '#198754' : '#dc3545' }}">{{ db.margeEstimee|number_format(0, ',', ' ') }} DT</td></tr>
            <tr><td>Niveau de risque</td><td>{{ db.niveauRisque }}</td></tr>
            <tr><td>Force d'équipe</td><td>{{ db.forceEquipe }}/10</td></tr>
        </table>

        {% if db.scoreFinancier %}
        <h2>Scores Détaillés</h2>
        <table>
            <tr><th>Score Financier</th><th>Score Marché</th><th>Score Équipe</th><th>Score Risque</th></tr>
            <tr>
                <td style="text-align:center">{{ db.scoreFinancier|number_format(1) }}%</td>
                <td style="text-align:center">{{ db.scoreMarche|number_format(1) }}%</td>
                <td style="text-align:center">{{ db.scoreEquipeCalcule|number_format(1) }}%</td>
                <td style="text-align:center">{{ db.scoreRisqueCalcule|number_format(1) }}%</td>
            </tr>
        </table>
        {% endif %}
    </div>
    {% endif %}

    {% if projet.diagnosticIa %}
    <div class="section">
        <h2>Diagnostic IA</h2>
        <div class="box">
            {{ projet.diagnosticIa|nl2br }}
        </div>
    </div>
    {% endif %}

    <div class="footer">
        <p>Fiche projet générée par Najahni | {{ "now"|date("d/m/Y H:i") }} | Confidentiel</p>
    </div>
</body>
</html>
