{% extends 'front/layout.html.twig' %}

{% block title %}Business Plan - {{ projet.titre }} - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="{{ path('app_projet_show', {id: projet.id}) }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Retour au projet</a>
        <h2 class="fw-bold mt-2 mb-0"><i class="bi bi-file-earmark-text me-2"></i>Business Plan</h2>
        <p class="text-muted mb-0">{{ projet.titre }}</p>
    </div>
    <a href="{{ path('app_projet_business_plan_pdf', {id: projet.id}) }}" class="btn btn-nj" target="_blank">
        <i class="bi bi-file-pdf me-1"></i>Télécharger PDF
    </a>
</div>

{# Executive Summary #}
<div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
    <h4 class="fw-bold mb-3" style="color:var(--nj-primary)"><i class="bi bi-bookmark-star me-2"></i>Résumé Exécutif</h4>
    <p class="lead">{{ plan.resume_executif }}</p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        {# Problem & Solution #}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-lightbulb me-2"></i>Problème & Solution</h5>
            <div class="mb-3">
                <h6 class="fw-semibold text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Problème</h6>
                <p>{{ plan.probleme_solution.probleme }}</p>
            </div>
            <div class="mb-3">
                <h6 class="fw-semibold text-success"><i class="bi bi-check-circle me-1"></i>Solution</h6>
                <p>{{ plan.probleme_solution.solution }}</p>
            </div>
            <div>
                <h6 class="fw-semibold" style="color:var(--nj-primary)"><i class="bi bi-star me-1"></i>Proposition de valeur</h6>
                <p class="mb-0">{{ plan.probleme_solution.proposition_valeur }}</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        {# Market Analysis #}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-globe me-2"></i>Analyse de Marché</h5>
            <div class="row g-3">
                <div class="col-6">
                    <div class="p-3 rounded-3" style="background:rgba(67,97,238,.05)">
                        <p class="text-muted small mb-1">Taille du marché</p>
                        <h6 class="fw-bold mb-0">{{ plan.analyse_marche.taille }}</h6>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 rounded-3" style="background:rgba(114,9,183,.05)">
                        <p class="text-muted small mb-1">Cible</p>
                        <h6 class="fw-bold mb-0">{{ plan.analyse_marche.cible }}</h6>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <p class="text-muted small mb-1"><strong>Tendances :</strong></p>
                <p>{{ plan.analyse_marche.tendances }}</p>
                <p class="text-muted small mb-1"><strong>Concurrence :</strong></p>
                <p class="mb-0">{{ plan.analyse_marche.concurrence }}</p>
            </div>
        </div>
    </div>
</div>

{# Business Model #}
<div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
    <h5 class="fw-bold mb-3"><i class="bi bi-cash-coin me-2"></i>Modèle Économique</h5>
    <div class="row g-3">
        <div class="col-md-3">
            <div class="p-3 rounded-3" style="background:rgba(67,97,238,.05)">
                <p class="text-muted small mb-1">Sources de revenus</p>
                <p class="fw-semibold small mb-0">{{ plan.modele_economique.sources_revenus }}</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 rounded-3" style="background:rgba(247,37,133,.05)">
                <p class="text-muted small mb-1">Structure de coûts</p>
                <p class="fw-semibold small mb-0">{{ plan.modele_economique.structure_couts }}</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 rounded-3" style="background:rgba(114,9,183,.05)">
                <p class="text-muted small mb-1">Pricing</p>
                <p class="fw-semibold small mb-0">{{ plan.modele_economique.prix }}</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 rounded-3" style="background:rgba(16,185,129,.08)">
                <p class="text-muted small mb-1">Rentabilité</p>
                <p class="fw-semibold small mb-0">{{ plan.modele_economique.rentabilite }}</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        {# Marketing Strategy #}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-megaphone me-2"></i>Stratégie Marketing</h5>
            <p><strong>Positionnement :</strong> {{ plan.strategie_marketing.positionnement }}</p>
            <p><strong>Canaux :</strong> {{ plan.strategie_marketing.canaux }}</p>
            <h6 class="fw-semibold mt-3">Actions clés :</h6>
            <ul class="mb-0">
                {% for action in plan.strategie_marketing.actions %}
                <li>{{ action }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="col-md-6">
        {# Operational Plan #}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-gear me-2"></i>Plan Opérationnel</h5>
            <h6 class="fw-semibold">Étapes clés :</h6>
            <div class="timeline">
                {% for etape in plan.plan_operationnel.etapes_cles %}
                <div class="d-flex align-items-start mb-3">
                    <span class="badge rounded-pill me-2" style="background:var(--nj-gradient);min-width:28px;height:28px;display:flex;align-items:center;justify-content:center">{{ loop.index }}</span>
                    <span>{{ etape }}</span>
                </div>
                {% endfor %}
            </div>
            <p class="mt-2"><strong>Ressources :</strong> {{ plan.plan_operationnel.ressources }}</p>
            <p class="mb-0"><strong>Timeline :</strong> {{ plan.plan_operationnel.timeline }}</p>
        </div>
    </div>
</div>

{# Risk Analysis #}
<div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
    <h5 class="fw-bold mb-3"><i class="bi bi-shield-exclamation me-2"></i>Analyse des Risques</h5>
    <div class="table-responsive">
        <table class="table table-hover mb-3">
            <thead>
                <tr><th>Risque</th><th>Mitigation</th></tr>
            </thead>
            <tbody>
                {% for r in plan.analyse_risques.risques %}
                <tr>
                    <td><span class="text-danger"><i class="bi bi-exclamation-diamond me-1"></i></span>{{ r.risque }}</td>
                    <td><span class="text-success"><i class="bi bi-shield-check me-1"></i></span>{{ r.mitigation }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <p class="mb-0"><strong>Plan B :</strong> {{ plan.analyse_risques.plan_b }}</p>
</div>

{# Financial Projections #}
<div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
    <h5 class="fw-bold mb-3"><i class="bi bi-graph-up me-2"></i>Projections Financières</h5>
    <div class="table-responsive">
        <table class="table table-bordered text-center">
            <thead class="table-light">
                <tr><th></th><th>Année 1</th><th>Année 2</th><th>Année 3</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-semibold">Revenus (DT)</td>
                    <td>{{ plan.projections_financieres.annee_1.revenus|number_format(0, ',', ' ') }}</td>
                    <td>{{ plan.projections_financieres.annee_2.revenus|number_format(0, ',', ' ') }}</td>
                    <td>{{ plan.projections_financieres.annee_3.revenus|number_format(0, ',', ' ') }}</td>
                </tr>
                <tr>
                    <td class="fw-semibold">Coûts (DT)</td>
                    <td>{{ plan.projections_financieres.annee_1.couts|number_format(0, ',', ' ') }}</td>
                    <td>{{ plan.projections_financieres.annee_2.couts|number_format(0, ',', ' ') }}</td>
                    <td>{{ plan.projections_financieres.annee_3.couts|number_format(0, ',', ' ') }}</td>
                </tr>
                <tr class="fw-bold">
                    <td>Bénéfice (DT)</td>
                    <td style="color:{{ plan.projections_financieres.annee_1.benefice >= 0 ? '#10b981' : '#ef4444' }}">
                        {{ plan.projections_financieres.annee_1.benefice|number_format(0, ',', ' ') }}
                    </td>
                    <td style="color:{{ plan.projections_financieres.annee_2.benefice >= 0 ? '#10b981' : '#ef4444' }}">
                        {{ plan.projections_financieres.annee_2.benefice|number_format(0, ',', ' ') }}
                    </td>
                    <td style="color:{{ plan.projections_financieres.annee_3.benefice >= 0 ? '#10b981' : '#ef4444' }}">
                        {{ plan.projections_financieres.annee_3.benefice|number_format(0, ',', ' ') }}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    <p class="mb-0"><strong>Point d'équilibre :</strong> {{ plan.projections_financieres.point_equilibre }}</p>
</div>

{# Conclusion #}
<div class="card border-0 shadow-sm p-4" style="border-radius:1rem;background:linear-gradient(135deg,rgba(67,97,238,.05),rgba(114,9,183,.05))">
    <h5 class="fw-bold mb-3"><i class="bi bi-flag me-2"></i>Conclusion</h5>
    <p class="mb-0">{{ plan.conclusion }}</p>
</div>
{% endblock %}
