{% extends 'front/layout.html.twig' %}

{% block title %}Recommandations IA - {{ projet.titre }} - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="{{ path('app_projet_show', {id: projet.id}) }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Retour au projet</a>
        <h2 class="fw-bold mt-2 mb-0"><i class="bi bi-robot me-2"></i>Recommandations IA</h2>
        <p class="text-muted mb-0">{{ projet.titre }}</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        {# Readiness Score #}
        {% if recommendations.score_readiness is defined %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-speedometer me-2"></i>Score de Maturité</h5>
            <div class="row g-3">
                {% set readiness = recommendations.score_readiness %}
                {% for label, val in {
                    'Investissement': readiness.investissement|default(0),
                    'Marché': readiness.marche|default(0),
                    'Équipe': readiness.equipe|default(0)
                } %}
                <div class="col-md-4">
                    <p class="text-muted small mb-1">{{ label }}</p>
                    <div class="progress mb-1" style="height:10px">
                        <div class="progress-bar" style="width:{{ val }}%;background:{{ val >= 70 ? '#10b981' : (val >= 40 ? '#f59e0b' : '#ef4444') }}"></div>
                    </div>
                    <small class="fw-bold">{{ val }}%</small>
                </div>
                {% endfor %}
            </div>
            {% if readiness.commentaire is defined %}
            <div class="mt-3 p-3 rounded-3" style="background:rgba(67,97,238,.05)">
                <p class="mb-0 small"><i class="bi bi-info-circle me-1"></i>{{ readiness.commentaire }}</p>
            </div>
            {% endif %}
        </div>
        {% endif %}

        {# Priority Actions #}
        {% if recommendations.actions_prioritaires is defined %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-list-check me-2"></i>Actions Prioritaires</h5>
            {% for action in recommendations.actions_prioritaires %}
            <div class="d-flex align-items-start mb-3 p-3 rounded-3" style="background:rgba({{ action.priorite == 'haute' ? '239,68,68' : (action.priorite == 'moyenne' ? '245,158,11' : '16,185,129') }},.05)">
                <span class="badge me-3 {{ action.priorite == 'haute' ? 'bg-danger' : (action.priorite == 'moyenne' ? 'bg-warning text-dark' : 'bg-success') }}">
                    {{ action.priorite|upper }}
                </span>
                <div>
                    <p class="fw-semibold mb-1">{{ action.action }}</p>
                    <small class="text-muted"><i class="bi bi-clock me-1"></i>{{ action.delai }}</small>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# KPIs to Track #}
        {% if recommendations.kpi_a_suivre is defined %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-graph-up me-2"></i>KPIs à Suivre</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead><tr><th>Indicateur</th><th>Objectif</th><th>Fréquence</th></tr></thead>
                    <tbody>
                        {% for kpi in recommendations.kpi_a_suivre %}
                        <tr>
                            <td class="fw-semibold">{{ kpi.kpi }}</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">{{ kpi.objectif }}</span></td>
                            <td><span class="badge bg-info bg-opacity-10 text-info">{{ kpi.frequence }}</span></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-md-4">
        {# Mentor Profile #}
        {% if recommendations.mentor_profile is defined %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-mortarboard me-2"></i>Profil Mentor Idéal</h5>
            <p><strong>Expertise :</strong> {{ recommendations.mentor_profile.expertise_requise }}</p>
            <p><strong>Expérience :</strong> {{ recommendations.mentor_profile.experience_secteur }}</p>
            <h6 class="fw-semibold mt-3">Compétences :</h6>
            <ul class="mb-3">
                {% for comp in recommendations.mentor_profile.competences %}
                <li>{{ comp }}</li>
                {% endfor %}
            </ul>
            <a href="{{ path('app_mentorat_requests') }}" class="btn btn-outline-primary btn-sm w-100">
                <i class="bi bi-search me-1"></i>Trouver un mentor
            </a>
        </div>
        {% endif %}

        {# Investor Profile #}
        {% if recommendations.investor_profile is defined %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-cash-coin me-2"></i>Profil Investisseur</h5>
            <p><strong>Type :</strong> {{ recommendations.investor_profile.type_investisseur }}</p>
            <p><strong>Montant :</strong> {{ recommendations.investor_profile.montant_recherche }}</p>
            <h6 class="fw-semibold mt-3">Critères :</h6>
            <ul class="mb-3">
                {% for c in recommendations.investor_profile.criteres %}
                <li>{{ c }}</li>
                {% endfor %}
            </ul>
            <a href="{{ path('app_invest_opportunities') }}" class="btn btn-outline-success btn-sm w-100">
                <i class="bi bi-graph-up-arrow me-1"></i>Voir les investissements
            </a>
        </div>
        {% endif %}

        {# Resources #}
        {% if recommendations.ressources_suggerees is defined %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-bookmark-star me-2"></i>Ressources Suggérées</h5>
            <ul class="list-unstyled mb-0">
                {% for res in recommendations.ressources_suggerees %}
                <li class="mb-2"><i class="bi bi-arrow-right-circle me-1" style="color:var(--nj-primary)"></i>{{ res }}</li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {# Similar Projects #}
        {% if similarProjects|length > 0 %}
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-collection me-2"></i>Projets Similaires</h5>
            {% for p in similarProjects %}
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="small">{{ p.titre|length > 20 ? p.titre|slice(0,20) ~ '...' : p.titre }}</span>
                <span class="badge bg-success bg-opacity-10 text-success">{{ p.scoreGlobal|number_format(1) }}</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
