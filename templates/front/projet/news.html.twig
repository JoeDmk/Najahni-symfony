{% extends 'front/layout.html.twig' %}

{% block title %}Actualités {{ projet.secteur }} en Tunisie - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="{{ path('app_projet_show', {id: projet.id}) }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Retour au projet</a>
        <h2 class="fw-bold mt-2 mb-0"><i class="bi bi-newspaper me-2"></i>Actualités du Secteur en Tunisie</h2>
        <p class="text-muted mb-0">{{ projet.titre }} — <span class="badge bg-primary bg-opacity-10 text-primary">{{ projet.secteur ?? 'Général' }}</span></p>
    </div>
</div>

{% if news|length > 0 %}
<div class="row g-4">
    {% for article in news %}
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-radius:1rem;overflow:hidden">
            <div class="d-flex align-items-center justify-content-center" style="height:140px;background:linear-gradient(135deg,rgba(67,97,238,.08),rgba(114,9,183,.08))">
                <i class="bi bi-newspaper display-3 text-muted"></i>
            </div>
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge bg-primary bg-opacity-10 text-primary small">
                        {{ article.source }}
                    </span>
                    {% if article.publishedAt %}
                    <small class="text-muted">{{ article.publishedAt|date('d/m/Y') }}</small>
                    {% endif %}
                </div>
                <h6 class="fw-bold mb-2">{{ article.title }}</h6>
                <p class="text-muted small mb-3 flex-grow-1">{{ article.description|length > 200 ? article.description|slice(0, 200) ~ '...' : article.description }}</p>
                <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary mt-auto">
                    <i class="bi bi-box-arrow-up-right me-1"></i>Lire l'article
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="card border-0 shadow-sm p-5 text-center" style="border-radius:1rem">
    <i class="bi bi-newspaper display-3 text-muted mb-3"></i>
    <h5 class="fw-bold text-muted">Aucune actualité disponible</h5>
    <p class="text-muted">Vérifiez votre connexion internet et réessayez.</p>
</div>
{% endif %}
{% endblock %}
