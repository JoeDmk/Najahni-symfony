{% extends 'front/layout.html.twig' %}

{% block title %}Fil d'actualité - Najahni{% endblock %}

{% block main %}
<div class="row g-4">
    <div class="col-md-8">
        <h2 class="fw-bold mb-4"><i class="bi bi-chat-square-text me-2"></i>Fil d'actualité</h2>

        {# New Post Form #}
        <div class="card border-0 shadow-sm mb-4" style="border-radius:1rem">
            <div class="card-body p-4">
                <form method="post" action="{{ path('app_community_post_new') }}">
                    <textarea name="content" class="form-control mb-3" rows="3" placeholder="Quoi de neuf ? Partagez avec la communauté..." maxlength="500" required></textarea>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Max 500 caractères</small>
                        <button type="submit" class="btn btn-nj"><i class="bi bi-send me-2"></i>Publier</button>
                    </div>
                </form>
            </div>
        </div>

        {# Posts Feed #}
        {% for post in posts %}
        <div class="card border-0 shadow-sm mb-3" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" style="width:42px;height:42px;background:var(--nj-gradient);color:#fff">
                        {{ post.user.firstname|first|upper }}{{ post.user.lastname|first|upper }}
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">{{ post.user.firstname }} {{ post.user.lastname }}</h6>
                        <small class="text-muted">{{ post.createdAt|date('d/m/Y H:i') }}</small>
                    </div>
                    {% if post.user == app.user or is_granted('ROLE_ADMIN') %}
                    <form method="post" action="{{ path('app_community_post_delete', {id: post.id}) }}" class="ms-auto">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                    {% endif %}
                </div>
                <p class="mb-3">{{ post.content }}</p>

                {# Reactions #}
                <div class="d-flex gap-1 flex-wrap">
                    {% for type in ['LIKE', 'LOVE', 'HAHA', 'WOW', 'SAD', 'ANGRY'] %}
                    {% set emoji = {'LIKE': '👍', 'LOVE': '❤️', 'HAHA': '😂', 'WOW': '😮', 'SAD': '😢', 'ANGRY': '😡'} %}
                    <form method="post" action="{{ path('app_community_post_react', {id: post.id}) }}" class="d-inline">
                        <input type="hidden" name="type" value="{{ type }}">
                        <button class="btn btn-sm btn-outline-secondary rounded-pill px-2 py-1">
                            {{ emoji[type] }}
                            {% set count = post.reactions|filter(r => r.reactionType == type)|length %}
                            {% if count > 0 %}<small>{{ count }}</small>{% endif %}
                        </button>
                    </form>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% else %}
        <div class="text-center py-5">
            <div class="text-center"><i class="bi bi-chat-left-text" style="font-size:3rem;color:var(--nj-primary)"></i></div>
            <p class="text-muted mt-2">Aucune publication. Soyez le premier à partager !</p>
        </div>
        {% endfor %}
    </div>

    {# Sidebar #}
    <div class="col-md-4">
        <div class="card border-0 shadow-sm mb-3" style="border-radius:1rem">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-grid me-2"></i>Navigation</h6>
                <div class="d-grid gap-2">
                    <a href="{{ path('app_community_groups') }}" class="btn btn-outline-primary text-start"><i class="bi bi-people me-2"></i>Groupes</a>
                    <a href="{{ path('app_community_events') }}" class="btn btn-outline-primary text-start"><i class="bi bi-calendar-event me-2"></i>Événements</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
