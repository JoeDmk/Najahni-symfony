{% extends 'front/layout.html.twig' %}

{% block title %}Événements - Najahni{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .community-nav-card {
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .community-nav-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 1.25rem 2.5rem rgba(15, 23, 42, .12) !important;
    }
</style>
{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-calendar-event me-2"></i>Événements</h2>
        <p class="text-muted mb-0">Retrouvez les evenements a venir, leurs participants et leur fiche detaillee.</p>
    </div>
    <a href="{{ path('app_community_event_new') }}" class="btn btn-nj"><i class="bi bi-plus-lg me-2"></i>Créer un événement</a>
</div>

<form method="get" action="{{ path('app_community_events') }}" class="card border-0 shadow-sm mb-4" style="border-radius:1rem">
    <div class="card-body p-3">
        <div class="row g-3">
            <div class="col-md-7">
                <input type="search" name="q" value="{{ search }}" class="form-control" placeholder="Rechercher un titre ou une description..." data-live-event-search>
                <div class="form-text">Le filtrage se fait en direct pendant la frappe.</div>
            </div>
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="upcoming" {{ sort == 'upcoming' ? 'selected' }}>Plus proches</option>
                    <option value="recent" {{ sort == 'recent' ? 'selected' }}>Plus lointains</option>
                    <option value="capacity" {{ sort == 'capacity' ? 'selected' }}>Plus de places</option>
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button class="btn btn-outline-nj" type="submit">Filtrer</button>
            </div>
        </div>
    </div>
</form>

{% if events|length > 0 %}
<div class="row g-4">
    {% for event in events %}
    {% set isCreator = event.createdBy == app.user or is_granted('ROLE_ADMIN') %}
    {% set isParticipant = event.hasParticipant(app.user) %}
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100 community-nav-card" style="border-radius:1rem" data-live-event-card data-live-event-text="{{ (event.title ~ ' ' ~ event.description ~ ' ' ~ event.createdBy.firstname ~ ' ' ~ event.createdBy.lastname)|lower|e('html_attr') }}">
            <div class="card-body p-4 position-relative">
                <a href="{{ path('app_community_event_show', {id: event.id}) }}" class="stretched-link" aria-label="Ouvrir l'événement {{ event.title }}"></a>
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <h5 class="fw-bold mb-0">{{ event.title }}</h5>
                    {% if isCreator %}
                    <span class="badge bg-primary">Organisateur</span>
                    {% endif %}
                </div>
                <p class="text-muted small mb-3">{{ event.description|length > 120 ? event.description|slice(0,120) ~ '...' : event.description }}</p>
                <div class="mb-3">
                    <p class="mb-1"><i class="bi bi-calendar3 me-2 text-primary"></i><strong>{{ event.eventDate|date('d/m/Y à H:i') }}</strong></p>
                    <p class="mb-1"><i class="bi bi-people me-2 text-primary"></i>{{ event.participantsCount }}/{{ event.capacity > 0 ? event.capacity : 'Illimite' }} participants</p>
                    <p class="mb-0"><i class="bi bi-person-badge me-2 text-primary"></i>{{ event.createdBy.firstname }} {{ event.createdBy.lastname }}</p>
                </div>
                {% if event.capacity > 0 %}
                <div class="progress mb-3" style="height:6px">
                    <div class="progress-bar" style="width:{{ (event.participantsCount / event.capacity * 100)|round }}%;background:var(--nj-gradient)"></div>
                </div>
                {% endif %}
                <div class="small text-muted mb-3 position-relative" style="z-index:2">
                    Cliquez sur la carte pour ouvrir la fiche détaillée.
                </div>
                <div class="d-flex flex-wrap gap-2 mt-3 position-relative" style="z-index:2">
                    {% if isParticipant and not isCreator %}
                    <form method="post" action="{{ path('app_community_event_leave', {id: event.id}) }}" class="flex-fill">
                        <button class="btn btn-sm btn-outline-secondary w-100"><i class="bi bi-box-arrow-left me-1"></i>Quitter</button>
                    </form>
                    {% elseif not isParticipant and event.hasCapacity %}
                    <form method="post" action="{{ path('app_community_event_join', {id: event.id}) }}" class="flex-fill">
                        <button class="btn btn-sm btn-nj w-100"><i class="bi bi-check-circle me-1"></i>S'inscrire</button>
                    </form>
                    {% elseif not event.hasCapacity %}
                    <button class="btn btn-sm btn-secondary flex-fill" disabled>Complet</button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
<div class="text-center py-5 d-none" data-live-event-empty>
    <div class="text-center"><i class="bi bi-search" style="font-size:3rem;color:var(--nj-primary)"></i></div>
    <p class="text-muted mt-2 mb-0">Aucun evenement visible ne correspond a cette recherche en direct.</p>
</div>
{% else %}
<div class="text-center py-5">
    <div class="text-center"><i class="bi bi-calendar-event" style="font-size:4rem;color:var(--nj-primary)"></i></div>
    <h4 class="fw-bold mt-3">Aucun événement à venir</h4>
    <p class="text-muted">Créez le premier événement</p>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const liveEventSearch = document.querySelector('[data-live-event-search]');
    const liveEventCards = Array.from(document.querySelectorAll('[data-live-event-card]'));
    const liveEventEmpty = document.querySelector('[data-live-event-empty]');

    const applyLiveEventFilter = () => {
        if (!(liveEventSearch instanceof HTMLInputElement)) {
            return;
        }

        const needle = liveEventSearch.value.trim().toLowerCase();
        let visible = 0;

        liveEventCards.forEach((card) => {
            if (!(card instanceof HTMLElement)) {
                return;
            }

            const haystack = (card.dataset.liveEventText || '').toLowerCase();
            const matches = needle === '' || haystack.includes(needle);
            card.parentElement?.classList.toggle('d-none', !matches);

            if (matches) {
                visible += 1;
            }
        });

        if (liveEventEmpty instanceof HTMLElement) {
            liveEventEmpty.classList.toggle('d-none', visible !== 0);
        }
    };

    if (liveEventSearch instanceof HTMLInputElement) {
        liveEventSearch.addEventListener('input', applyLiveEventFilter);
        applyLiveEventFilter();
    }
});
</script>
{% endblock %}
