{% extends 'front/layout.html.twig' %}

{% block title %}Événements - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-calendar-event me-2"></i>Événements</h2>
    <a href="{{ path('app_community_event_new') }}" class="btn btn-nj"><i class="bi bi-plus-lg me-2"></i>Créer un événement</a>
</div>

{% if events|length > 0 %}
<div class="row g-4">
    {% for event in events %}
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:1rem">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-2">{{ event.title }}</h5>
                <p class="text-muted small mb-3">{{ event.description|length > 120 ? event.description|slice(0,120) ~ '...' : event.description }}</p>
                <div class="mb-3">
                    <p class="mb-1"><i class="bi bi-calendar3 me-2 text-primary"></i><strong>{{ event.eventDate|date('d/m/Y à H:i') }}</strong></p>
                    <p class="mb-1"><i class="bi bi-people me-2 text-primary"></i>{{ event.participantsCount }}/{{ event.capacity }} participants</p>
                </div>
                {% if event.capacity > 0 %}
                <div class="progress mb-3" style="height:6px">
                    <div class="progress-bar" style="width:{{ (event.participantsCount / event.capacity * 100)|round }}%;background:var(--nj-gradient)"></div>
                </div>
                {% endif %}
                {% if event.hasCapacity %}
                <form method="post" action="{{ path('app_community_event_join', {id: event.id}) }}">
                    <button class="btn btn-sm btn-nj w-100"><i class="bi bi-check-circle me-1"></i>S'inscrire</button>
                </form>
                {% else %}
                <button class="btn btn-sm btn-secondary w-100" disabled>Complet</button>
                {% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="text-center py-5">
    <div style="font-size:5rem">📅</div>
    <h4 class="fw-bold mt-3">Aucun événement à venir</h4>
    <p class="text-muted">Créez le premier événement</p>
</div>
{% endif %}
{% endblock %}
