{% extends 'front/layout.html.twig' %}

{% block title %}Créer un groupe - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-people me-2"></i>Créer un groupe</h2>
    <a href="{{ path('app_community_groups') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem;max-width:600px">
    <div class="card-body p-4">
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Nom du groupe</label>
                <input type="text" name="name" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="description" class="form-control" rows="4" required></textarea>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="is_private" id="isPrivate" value="1">
                <label class="form-check-label" for="isPrivate">Groupe privé</label>
            </div>
            <button type="submit" class="btn btn-nj"><i class="bi bi-check-lg me-2"></i>Créer</button>
        </form>
    </div>
</div>
{% endblock %}
