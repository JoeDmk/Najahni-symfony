{% extends 'front/layout.html.twig' %}

{% block title %}{{ event.title }} - Najahni{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .community-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
    }

    .community-meta-item {
        border-radius: 1rem;
        padding: 1rem;
        background: rgba(67, 97, 238, .05);
        border: 1px solid rgba(67, 97, 238, .08);
    }
</style>
{% endblock %}

{% block main %}
{% set eventAiResult = eventAiResult|default(null) %}
{% set eventEditData = eventEditData|default({title: event.title, description: event.description, event_date: event.eventDate|date('Y-m-d\\TH:i'), capacity: event.capacity > 0 ? event.capacity : 1}) %}
{% set eventEditErrors = eventEditErrors|default({}) %}
{% set openEventEdit = openEventEdit|default(false) %}
<a href="{{ path('app_community_events') }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Tous les evenements</a>

<div class="row g-4 mt-3">
    <div class="col-xl-8">
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <h2 class="fw-bold mb-0">{{ event.title }}</h2>
                        {% if isCreator %}
                        <span class="badge bg-primary">Organisateur</span>
                        {% endif %}
                        {% if isParticipant %}
                        <span class="badge bg-success">Inscrit</span>
                        {% endif %}
                    </div>
                    <p class="text-muted mb-0" style="white-space:pre-wrap">{{ event.description }}</p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    {% if isCreator %}
                    <a href="{{ path('app_community_event_report', {id: event.id}) }}" class="btn btn-sm btn-outline-dark"><i class="bi bi-file-earmark-arrow-down me-1"></i>Exporter PDF</a>
                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#edit-event-form"><i class="bi bi-pencil-square me-1"></i>Modifier</button>
                    <form method="post" action="{{ path('app_community_event_delete', {id: event.id}) }}">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash me-1"></i>Supprimer</button>
                    </form>
                    {% elseif isParticipant %}
                    <form method="post" action="{{ path('app_community_event_leave', {id: event.id}) }}">
                        <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-box-arrow-left me-1"></i>Quitter</button>
                    </form>
                    {% elseif not isFull %}
                    <form method="post" action="{{ path('app_community_event_join', {id: event.id}) }}">
                        <button class="btn btn-sm btn-nj"><i class="bi bi-check-circle me-1"></i>S'inscrire</button>
                    </form>
                    {% else %}
                    <button class="btn btn-sm btn-secondary" disabled>Complet</button>
                    {% endif %}
                </div>
            </div>

            <div class="community-meta-grid mb-4">
                <div class="community-meta-item">
                    <div class="small text-uppercase text-muted fw-semibold mb-1">Date</div>
                    <div class="fw-semibold">{{ event.eventDate|date('d/m/Y H:i') }}</div>
                </div>
                <div class="community-meta-item">
                    <div class="small text-uppercase text-muted fw-semibold mb-1">Capacite</div>
                    <div class="fw-semibold">{{ event.capacity > 0 ? event.capacity : 'Illimitee' }}</div>
                </div>
                <div class="community-meta-item">
                    <div class="small text-uppercase text-muted fw-semibold mb-1">Participants</div>
                    <div class="fw-semibold">{{ event.participantsCount }}</div>
                </div>
                <div class="community-meta-item">
                    <div class="small text-uppercase text-muted fw-semibold mb-1">Organisateur</div>
                    <div class="fw-semibold">{{ event.createdBy.firstname }} {{ event.createdBy.lastname }}</div>
                </div>
            </div>

            {% if isCreator %}
            <div class="collapse{{ openEventEdit ? ' show' : '' }}" id="edit-event-form">
                <div class="border rounded-4 p-3 bg-light-subtle">
                    <form method="post" action="{{ path('app_community_event_update', {id: event.id}) }}" novalidate>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Titre</label>
                            <input type="text" name="title" class="form-control{{ eventEditErrors.title is defined ? ' is-invalid' }}" value="{{ eventEditData.title }}" maxlength="150" required>
                            <div class="form-text">5 a 150 caracteres avec un vrai titre exploitable.</div>
                            {% if eventEditErrors.title is defined %}
                            <div class="invalid-feedback d-block">{{ eventEditErrors.title }}</div>
                            {% endif %}
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="description" class="form-control{{ eventEditErrors.description is defined ? ' is-invalid' }}" rows="4" maxlength="4000" required>{{ eventEditData.description }}</textarea>
                            <div class="form-text">Expliquez clairement l objectif, le deroule et les infos pratiques.</div>
                            {% if eventEditErrors.description is defined %}
                            <div class="invalid-feedback d-block">{{ eventEditErrors.description }}</div>
                            {% endif %}
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Date et heure</label>
                                <input type="datetime-local" name="event_date" class="form-control{{ eventEditErrors.event_date is defined ? ' is-invalid' }}" value="{{ eventEditData.event_date }}" required>
                                {% if eventEditErrors.event_date is defined %}
                                <div class="invalid-feedback d-block">{{ eventEditErrors.event_date }}</div>
                                {% endif %}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Capacite</label>
                                <input type="number" name="capacity" min="1" class="form-control{{ eventEditErrors.capacity is defined ? ' is-invalid' }}" value="{{ eventEditData.capacity }}" required>
                                {% if eventEditErrors.capacity is defined %}
                                <div class="invalid-feedback d-block">{{ eventEditErrors.capacity }}</div>
                                {% endif %}
                            </div>
                        </div>
                        <button type="submit" class="btn btn-nj btn-sm mt-3">Enregistrer</button>
                    </form>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="row g-4 mt-1">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius:1rem">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-cloud-sun me-2"></i>Meteo</h5>
                        {% if weather.status == 'available' %}
                        <div class="d-flex flex-column gap-2">
                            <div class="fw-semibold">{{ weather.label }}</div>
                            <div class="text-muted">{{ weather.temperature_range }}</div>
                            <div class="text-muted">{{ weather.rain_label }}</div>
                            <div class="small text-muted">Source : {{ weather.source }}</div>
                        </div>
                        {% else %}
                        <div class="text-muted">{{ weather.message }}</div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius:1rem">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                            <h5 class="fw-bold mb-0"><i class="bi bi-stars me-2"></i>Assistant IA</h5>
                            <div class="d-flex gap-2 flex-wrap">
                                <form method="post" action="{{ path('app_community_event_ai', {id: event.id}) }}">
                                    <input type="hidden" name="mode" value="summary">
                                    <button class="btn btn-sm {{ eventAiMode == 'summary' ? 'btn-nj' : 'btn-outline-nj' }}">Resume</button>
                                </form>
                                <form method="post" action="{{ path('app_community_event_ai', {id: event.id}) }}">
                                    <input type="hidden" name="mode" value="promo">
                                    <button class="btn btn-sm {{ eventAiMode == 'promo' ? 'btn-nj' : 'btn-outline-nj' }}">Promo</button>
                                </form>
                                <form method="post" action="{{ path('app_community_event_ai', {id: event.id}) }}">
                                    <input type="hidden" name="mode" value="checklist">
                                    <button class="btn btn-sm {{ eventAiMode == 'checklist' ? 'btn-nj' : 'btn-outline-nj' }}">Checklist</button>
                                </form>
                            </div>
                        </div>
                        {% if eventAiResult %}
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                            <span class="badge rounded-pill {{ eventAiResult.error ? 'text-bg-danger' : (eventAiResult.used_provider ? 'text-bg-success' : 'text-bg-secondary') }}">{{ eventAiResult.source_label }}{% if eventAiResult.model %} · {{ eventAiResult.model }}{% endif %}</span>
                        </div>
                        {% if eventAiResult.error_message %}
                        <div class="alert alert-danger py-2 px-3 small mb-2">{{ eventAiResult.error_message }}</div>
                        {% endif %}
                        {% if eventAiResult.content %}
                        <div style="white-space:pre-wrap">{{ eventAiResult.content }}</div>
                        {% endif %}
                        {% if eventAiResult.source_hint %}
                        <div class="small text-muted mt-2">{{ eventAiResult.source_hint }}</div>
                        {% endif %}
                        {% else %}
                        <div class="text-muted">Choisissez un mode pour generer un texte adapte a cet evenement.</div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {% if isParticipant and not isCreator %}
        <div class="card border-0 shadow-sm mt-4" style="border-radius:1rem">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-2"><i class="bi bi-envelope-check me-2"></i>Ticket QR envoye par email</h5>
                <p class="text-muted mb-0">Votre ticket n est plus affiche sur cette page. Il est envoye a <strong>{{ app.user.email }}</strong> au moment de l inscription pour rester reserve aux participants.</p>
            </div>
        </div>
        {% endif %}

        {% if isCreator %}
        <div class="card border-0 shadow-sm mt-4" style="border-radius:1rem">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-shield-check me-2"></i>Validation des tickets</h5>
                {% if ticketValidation %}
                <div class="alert {{ ticketValidation.valid ? 'alert-success' : 'alert-danger' }} mb-3">
                    <div class="fw-semibold mb-1">{{ ticketValidation.message }}</div>
                    {% if ticketValidation.payload %}
                    <div class="small text-break">{{ ticketValidation.payload }}</div>
                    {% endif %}
                </div>
                {% endif %}
                <form method="post" action="{{ path('app_community_event_ticket_validate', {id: event.id}) }}" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Payload du ticket</label>
                        <textarea name="payload" class="form-control" rows="4" placeholder="Collez le contenu signe du ticket..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ou image QR</label>
                        <input type="file" name="ticket_image" class="form-control" accept="image/*">
                    </div>
                    <button type="submit" class="btn btn-nj btn-sm">Verifier le ticket</button>
                </form>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-xl-4">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-people me-2"></i>Participants ({{ participants|length }})</h5>
                <div class="d-flex flex-column gap-3">
                    {% for participant in participants %}
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <div>
                            <div class="fw-semibold">{{ participant.user.firstname }} {{ participant.user.lastname }}</div>
                            <div class="small text-muted">{{ participant.user.email }}</div>
                        </div>
                        {% if isCreator and participant.user != event.createdBy %}
                        <form method="post" action="{{ path('app_community_event_remove_participant', {eventId: event.id, userId: participant.user.id}) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-person-dash"></i></button>
                        </form>
                        {% endif %}
                    </div>
                    {% else %}
                    <div class="text-muted">Aucun participant pour le moment.</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}