{% extends 'front/layout.html.twig' %}

{% block title %}{{ thread.title }} - Najahni{% endblock %}

{% block main %}
{% set canManageThread = thread.user == app.user or is_granted('ROLE_ADMIN') %}
{% set threadSummaryResult = threadSummaryResult|default(null) %}
{% set replySuggestionsResult = replySuggestionsResult|default({items: []}) %}
{% set threadEditData = threadEditData|default({title: thread.title, content: thread.content}) %}
{% set threadEditErrors = threadEditErrors|default({}) %}
{% set openThreadEdit = openThreadEdit|default(false) %}
{% set commentFormData = commentFormData|default({content: ''}) %}
{% set commentFormErrors = commentFormErrors|default({}) %}
{% set commentEditTargetId = commentEditTargetId|default(null) %}
{% set commentEditData = commentEditData|default({content: ''}) %}
{% set commentEditErrors = commentEditErrors|default({}) %}

<a href="{{ path('app_community_group_show', {id: thread.group.id}) }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>{{ thread.group.name }}</a>

<div class="card border-0 shadow-sm p-4 mt-3 mb-4" style="border-radius:1rem">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h3 class="fw-bold mb-2">{{ thread.title }}</h3>
            <p class="mb-3" style="white-space:pre-wrap">{{ thread.content }}</p>
            <div class="d-flex align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="width:32px;height:32px;background:var(--nj-gradient);color:#fff;font-size:.75rem">
                    {{ thread.user.firstname|first|upper }}{{ thread.user.lastname|first|upper }}
                </div>
                <small class="text-muted">{{ thread.user.firstname }} {{ thread.user.lastname }} · {{ thread.createdAt|date('d/m/Y H:i') }}</small>
            </div>
        </div>
        {% if canManageThread %}
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#thread-edit-form"><i class="bi bi-pencil-square"></i></button>
            <form method="post" action="{{ path('app_community_thread_delete', {id: thread.id}) }}">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
        </div>
        {% endif %}
    </div>

    {% if canManageThread %}
    <div class="collapse mt-4{{ openThreadEdit ? ' show' : '' }}" id="thread-edit-form">
        <div class="border rounded-4 p-3 bg-light-subtle">
            <form method="post" action="{{ path('app_community_thread_update', {id: thread.id}) }}" novalidate>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Titre</label>
                    <input type="text" name="title" class="form-control{{ threadEditErrors.title is defined ? ' is-invalid' }}" value="{{ threadEditData.title }}" maxlength="150" required>
                    <div class="form-text">5 a 150 caracteres avec un titre lisible.</div>
                    {% if threadEditErrors.title is defined %}
                    <div class="invalid-feedback d-block">{{ threadEditErrors.title }}</div>
                    {% endif %}
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Contenu</label>
                    <textarea name="content" class="form-control{{ threadEditErrors.content is defined ? ' is-invalid' }}" rows="4" maxlength="5000" required>{{ threadEditData.content }}</textarea>
                    <div class="form-text">Decrivez clairement le contexte, la question et les attentes.</div>
                    {% if threadEditErrors.content is defined %}
                    <div class="invalid-feedback d-block">{{ threadEditErrors.content }}</div>
                    {% endif %}
                </div>
                <button type="submit" class="btn btn-nj btn-sm">Enregistrer</button>
            </form>
        </div>
    </div>
    {% endif %}
</div>

<div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
        <div>
            <h5 class="fw-bold mb-1"><i class="bi bi-stars me-2"></i>Assistant IA du fil</h5>
            <p class="text-muted mb-0">Generez un resume ou des suggestions de reponse a partir de l'ordre reel des commentaires.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <form method="post" action="{{ path('app_community_thread_summary', {id: thread.id}) }}">
                <button class="btn btn-sm btn-outline-nj"><i class="bi bi-body-text me-1"></i>Resume</button>
            </form>
            <form method="post" action="{{ path('app_community_thread_reply_suggestions', {id: thread.id}) }}">
                <button class="btn btn-sm btn-outline-nj"><i class="bi bi-lightbulb me-1"></i>Suggestions</button>
            </form>
        </div>
    </div>

    {% if threadSummaryResult %}
    <div class="rounded-4 border p-3 mb-3 bg-light-subtle">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <div class="small text-uppercase text-muted fw-semibold">Resume</div>
            <span class="badge rounded-pill {{ threadSummaryResult.error ? 'text-bg-danger' : (threadSummaryResult.used_provider ? 'text-bg-success' : 'text-bg-secondary') }}">{{ threadSummaryResult.source_label }}{% if threadSummaryResult.model %} · {{ threadSummaryResult.model }}{% endif %}</span>
        </div>
        {% if threadSummaryResult.error_message %}
        <div class="alert alert-danger py-2 px-3 small mb-2">{{ threadSummaryResult.error_message }}</div>
        {% endif %}
        {% if threadSummaryResult.content %}
        <div>{{ threadSummaryResult.content }}</div>
        {% endif %}
        {% if threadSummaryResult.source_hint %}
        <div class="small text-muted mt-2">{{ threadSummaryResult.source_hint }}</div>
        {% endif %}
    </div>
    {% endif %}

    {% if replySuggestionsResult.items is not empty or replySuggestionsResult.error_message %}
    <div>
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <div class="small text-uppercase text-muted fw-semibold">Suggestions de reponse</div>
            <span class="badge rounded-pill {{ replySuggestionsResult.error ? 'text-bg-danger' : (replySuggestionsResult.used_provider ? 'text-bg-success' : 'text-bg-secondary') }}">{{ replySuggestionsResult.source_label }}{% if replySuggestionsResult.model %} · {{ replySuggestionsResult.model }}{% endif %}</span>
        </div>
        {% if replySuggestionsResult.error_message %}
        <div class="alert alert-danger py-2 px-3 small mb-2">{{ replySuggestionsResult.error_message }}</div>
        {% endif %}
        {% if replySuggestionsResult.items is not empty %}
        <div class="d-flex flex-column gap-2">
            {% for suggestion in replySuggestionsResult.items %}
            <button type="button" class="btn btn-outline-secondary text-start community-suggestion" data-suggestion="{{ suggestion|e('html_attr') }}">{{ suggestion }}</button>
            {% endfor %}
        </div>
        {% endif %}
        {% if replySuggestionsResult.source_hint %}
        <div class="small text-muted mt-2">{{ replySuggestionsResult.source_hint }}</div>
        {% endif %}
    </div>
    {% endif %}
</div>

{# Comments #}
<h5 class="fw-bold mb-3"><i class="bi bi-chat me-2"></i>Commentaires ({{ comments|length }})</h5>

{% for comment in comments %}
{% set canManageComment = comment.user == app.user or is_granted('ROLE_ADMIN') %}
{% set commentEditActive = commentEditTargetId == comment.id %}
<div class="card border-0 shadow-sm mb-2" style="border-radius:.75rem">
    <div class="card-body p-3">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
            <div class="d-flex align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="width:28px;height:28px;background:var(--nj-gradient);color:#fff;font-size:.65rem">
                    {{ comment.user.firstname|first|upper }}{{ comment.user.lastname|first|upper }}
                </div>
                <strong class="small">{{ comment.user.firstname }} {{ comment.user.lastname }}</strong>
                <small class="text-muted ms-2">{{ comment.createdAt|date('d/m/Y H:i') }}</small>
            </div>
            {% if canManageComment %}
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#edit-comment-{{ comment.id }}"><i class="bi bi-pencil-square"></i></button>
                <form method="post" action="{{ path('app_community_comment_delete', {id: comment.id}) }}">
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
            </div>
            {% endif %}
        </div>
        <p class="mb-0 small" style="white-space:pre-wrap">{{ comment.content }}</p>

        {% if canManageComment %}
        <div class="collapse mt-3{{ commentEditActive ? ' show' : '' }}" id="edit-comment-{{ comment.id }}">
            <div class="border rounded-4 p-3 bg-light-subtle">
                <form method="post" action="{{ path('app_community_comment_update', {id: comment.id}) }}" novalidate>
                    <label class="form-label fw-semibold">Modifier le commentaire</label>
                    <textarea name="content" class="form-control mb-2{{ commentEditActive and commentEditErrors.content is defined ? ' is-invalid' }}" rows="3" maxlength="2000" required>{{ commentEditActive ? commentEditData.content : comment.content }}</textarea>
                    <div class="form-text mb-2">Ecrivez un commentaire utile, pas juste quelques symboles.</div>
                    {% if commentEditActive and commentEditErrors.content is defined %}
                    <div class="invalid-feedback d-block mb-2">{{ commentEditErrors.content }}</div>
                    {% endif %}
                    <button type="submit" class="btn btn-sm btn-nj">Enregistrer</button>
                </form>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% else %}
<p class="text-muted">Aucun commentaire.</p>
{% endfor %}

{# Add Comment #}
<div class="card border-0 shadow-sm mt-3" style="border-radius:1rem">
    <div class="card-body p-4">
        {% if canParticipate %}
        <form method="post" action="{{ path('app_community_thread_comment', {id: thread.id}) }}" novalidate>
            <label class="form-label fw-semibold">Ajouter un commentaire</label>
            <textarea name="content" class="form-control mb-2{{ commentFormErrors.content is defined ? ' is-invalid' }}" rows="3" placeholder="Ajouter un commentaire..." maxlength="2000" required data-comment-target>{{ commentFormData.content }}</textarea>
            <div class="form-text mb-2">Expliquez votre idee ou votre retour en quelques phrases utiles.</div>
            {% if commentFormErrors.content is defined %}
            <div class="invalid-feedback d-block mb-2">{{ commentFormErrors.content }}</div>
            {% endif %}
            <button type="submit" class="btn btn-nj btn-sm"><i class="bi bi-reply me-1"></i>Commenter</button>
        </form>
        {% else %}
        <div class="rounded-4 border border-warning-subtle bg-warning-subtle p-3 small text-muted">
            Rejoignez le groupe pour participer a la discussion. Vous pouvez toujours lire le fil tant qu'il est public.
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const target = document.querySelector('[data-comment-target]');

    document.querySelectorAll('.community-suggestion').forEach((button) => {
        button.addEventListener('click', () => {
            if (!target) {
                return;
            }

            target.value = button.dataset.suggestion || '';
            target.focus();
            target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    });
});
</script>
{% endblock %}
