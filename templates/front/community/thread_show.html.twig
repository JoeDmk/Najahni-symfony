{% extends 'front/layout.html.twig' %}

{% block title %}{{ thread.title }} - Najahni{% endblock %}

{% block main %}
<a href="{{ path('app_community_group_show', {id: thread.group.id}) }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>{{ thread.group.name }}</a>

<div class="card border-0 shadow-sm p-4 mt-3 mb-4" style="border-radius:1rem">
    <h3 class="fw-bold">{{ thread.title }}</h3>
    <p>{{ thread.content }}</p>
    <div class="d-flex align-items-center">
        <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="width:32px;height:32px;background:var(--nj-gradient);color:#fff;font-size:.75rem">
            {{ thread.user.firstname|first|upper }}{{ thread.user.lastname|first|upper }}
        </div>
        <small class="text-muted">{{ thread.user.firstname }} {{ thread.user.lastname }} · {{ thread.createdAt|date('d/m/Y H:i') }}</small>
    </div>
</div>

{# Comments #}
<h5 class="fw-bold mb-3"><i class="bi bi-chat me-2"></i>Commentaires ({{ thread.comments|length }})</h5>

{% for comment in thread.comments %}
<div class="card border-0 shadow-sm mb-2" style="border-radius:.75rem">
    <div class="card-body p-3">
        <div class="d-flex align-items-center mb-2">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-2" style="width:28px;height:28px;background:var(--nj-gradient);color:#fff;font-size:.65rem">
                {{ comment.user.firstname|first|upper }}{{ comment.user.lastname|first|upper }}
            </div>
            <strong class="small">{{ comment.user.firstname }} {{ comment.user.lastname }}</strong>
            <small class="text-muted ms-2">{{ comment.createdAt|date('d/m/Y H:i') }}</small>
        </div>
        <p class="mb-0 small">{{ comment.content }}</p>
    </div>
</div>
{% else %}
<p class="text-muted">Aucun commentaire.</p>
{% endfor %}

{# Add Comment #}
<div class="card border-0 shadow-sm mt-3" style="border-radius:1rem">
    <div class="card-body p-4">
        <form method="post" action="{{ path('app_community_thread_comment', {id: thread.id}) }}">
            <textarea name="content" class="form-control mb-2" rows="2" placeholder="Ajouter un commentaire..." required></textarea>
            <button type="submit" class="btn btn-nj btn-sm"><i class="bi bi-reply me-1"></i>Commenter</button>
        </form>
    </div>
</div>
{% endblock %}
