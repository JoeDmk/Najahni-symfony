{% extends 'front/layout.html.twig' %}

{% block title %}Groupes - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-people me-2"></i>Groupes</h2>
    <a href="{{ path('app_community_group_new') }}" class="btn btn-nj"><i class="bi bi-plus-lg me-2"></i>Créer un groupe</a>
</div>

{% if groups|length > 0 %}
<div class="row g-4">
    {% for group in groups %}
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="fw-bold mb-0">{{ group.name }}</h5>
                    {% if group.isPrivate %}
                        <span class="badge bg-warning text-dark"><i class="bi bi-lock"></i> Privé</span>
                    {% else %}
                        <span class="badge bg-success"><i class="bi bi-unlock"></i> Public</span>
                    {% endif %}
                </div>
                <p class="text-muted small mb-3">{{ group.description|length > 100 ? group.description|slice(0,100) ~ '...' : group.description }}</p>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted"><i class="bi bi-people me-1"></i>{{ group.members|length }} membres</small>
                    <a href="{{ path('app_community_group_show', {id: group.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="text-center py-5">
    <div style="font-size:5rem">👥</div>
    <h4 class="fw-bold mt-3">Aucun groupe</h4>
    <p class="text-muted">Créez le premier groupe de la communauté</p>
</div>
{% endif %}
{% endblock %}
