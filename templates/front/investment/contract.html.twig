                    + '<div class="text-end mt-2"><button type="button" class="btn btn-sm btn-outline-secondary ai-suggest-dismiss" style="font-size:.78rem">Fermer</button></div>';

                panel.querySelector('.ai-suggest-dismiss').addEventListener('click', function() {
