{% extends 'front/layout.html.twig' %}

{% block title %}Contrat d'investissement - Najahni{% endblock %}

{% block main %}
{% include 'front/investment/_wayfinder.html.twig' with {pageLabel: 'Contrat', activeStep: 3} %}
{% set canPayNow = contract.fullySigned and not offer.paid %}
{% set hasMilestones = milestones is defined and milestones|length > 0 %}
{% set contractsIndexUrl = path('app_invest_my_contracts') %}
{% set postSignatureUrl = isInvestorParty ? path('app_invest_my_offers') : contractsIndexUrl %}

{# Particle network background #}
<canvas id="particleNetworkCanvas" style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;opacity:.12"></canvas>

<style>
.contract-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, .8fr);
    gap: 1.5rem;
    align-items: start;
    position: relative;
    z-index: 1;
}

.contract-card {
    border: 0;
    border-radius: 1.2rem;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    overflow: hidden;
}

.contract-hero {
    background: linear-gradient(135deg, #0f172a, #1d4ed8 58%, #38bdf8);
    color: #fff;
    padding: 1.5rem;
}

.contract-stat {
    border-radius: 1rem;
    background: rgba(255,255,255,.12);
    padding: .9rem 1rem;
    border: 1px solid rgba(255,255,255,.15);
}

.signature-chip {
    border-radius: 999px;
    padding: .45rem .85rem;
    font-size: .82rem;
    font-weight: 700;
}

.signature-panel {
    border-radius: 1rem;
    border: 1px solid #dbeafe;
    background: linear-gradient(180deg, #ffffff, #eff6ff);
    padding: 1rem;
}

.terms-box {
    white-space: pre-wrap;
    border-radius: 1rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    padding: 1rem;
}

.chat-shell {
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 1.5rem;
    max-height: calc(100vh - 2rem);
}

.chat-header {
    padding: 1rem 1rem .85rem;
}

.chat-list {
    flex: 1;
    min-height: 260px;
    overflow-y: auto;
    padding: 1rem;
    background: linear-gradient(180deg, #f8fafc, #ffffff);
    border-bottom: 1px solid #e5e7eb;
}

.chat-bubble {
    max-width: 88%;
    border-radius: 1rem;
    padding: .9rem 1rem;
    margin-bottom: .9rem;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
}

.chat-bubble.mine {
    margin-left: auto;
    background: linear-gradient(135deg, #1d4ed8, #2563eb);
    color: #fff;
}

.chat-bubble.theirs {
    background: #fff;
    border: 1px solid #dbeafe;
}

.chat-bubble.system {
    max-width: 100%;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    color: #9a3412;
}

.chat-form {
    padding: 1rem;
    background: #fff;
}

.digest-badge {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .5rem .75rem;
    border-radius: .8rem;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    color: #1d4ed8;
    font-family: Consolas, monospace;
    font-size: .84rem;
}

.pdf-panel {
    border-radius: 1rem;
    border: 1px solid #c7d2fe;
    background: linear-gradient(180deg, #eef2ff, #ffffff);
    padding: 1rem;
}

.pdf-preview {
    width: 100%;
    height: 720px;
    border: 1px solid #dbeafe;
    border-radius: 1rem;
    background: #fff;
}

@media (max-width: 991.98px) {
    .contract-shell {
        grid-template-columns: 1fr;
    }

    .chat-shell {
        position: static;
        max-height: none;
    }
}

/* ── Lifecycle stepper ── */
.lc-stepper {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    padding: 1.25rem 1rem .85rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, #f8fafc, #eff6ff);
    border: 1px solid #dbeafe;
    margin-bottom: 1.5rem;
    overflow: hidden;
}

.lc-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    position: relative;
    z-index: 1;
}

/* Connector line between steps */
.lc-step + .lc-step::before {
    content: '';
    position: absolute;
    top: 18px;
    right: 50%;
    width: 100%;
    height: 3px;
    background: #e2e8f0;
    z-index: -1;
}

.lc-step.done + .lc-step::before,
.lc-step.done + .lc-step.done::before,
.lc-step.done + .lc-step.active::before {
    background: #1d4ed8;
}

/* Circle indicator */
.lc-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .85rem;
    font-weight: 700;
    border: 2.5px solid #cbd5e1;
    background: #fff;
    color: #94a3b8;
    transition: all .25s;
    flex-shrink: 0;
}

.lc-step.done .lc-circle {
    border-color: #22c55e;
    background: #22c55e;
    color: #fff;
}

.lc-step.active .lc-circle {
    border-color: #1d4ed8;
    background: #1d4ed8;
    color: #fff;
    animation: lcPulse 1.5s ease-in-out infinite;
}

@keyframes lcPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(29, 78, 216, .45); }
    50%      { box-shadow: 0 0 0 10px rgba(29, 78, 216, 0); }
}

/* Label */
.lc-label {
    margin-top: .45rem;
    font-size: .78rem;
    color: #94a3b8;
    text-align: center;
    line-height: 1.25;
    max-width: 100px;
}

.lc-step.done .lc-label {
    color: #334155;
}

.lc-step.active .lc-label {
    color: #1d4ed8;
    font-weight: 700;
}

/* Mobile: only active step */
.lc-mobile-hint {
    display: none;
    text-align: center;
    padding: .85rem 1rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, #f8fafc, #eff6ff);
    border: 1px solid #dbeafe;
    margin-bottom: 1.5rem;
    font-size: .9rem;
    color: #334155;
}

.lc-mobile-hint .lc-circle {
    display: inline-flex;
    width: 30px;
    height: 30px;
    font-size: .78rem;
    vertical-align: middle;
    margin-right: .4rem;
    border-color: #1d4ed8;
    background: #1d4ed8;
    color: #fff;
    animation: lcPulse 1.5s ease-in-out infinite;
}

@media (max-width: 639px) {
    .lc-stepper { display: none; }
    .lc-mobile-hint { display: block; }
}

/* Milestone tracker */
.milestone-card {
    border-radius: 1rem;
    border: 1px solid #e2e8f0;
    padding: 1rem 1.1rem;
    background: #fff;
    transition: border-color .2s;
}

.milestone-card.released {
    border-color: #86efac;
    background: linear-gradient(180deg, #f0fdf4, #fff);
}

.milestone-card.confirmed {
    border-color: #93c5fd;
    background: linear-gradient(180deg, #eff6ff, #fff);
}

.milestone-card.completed {
    border-color: #fbbf24;
    background: linear-gradient(180deg, #fffbeb, #fff);
}

.milestone-progress-bar {
    height: 6px;
    border-radius: 3px;
    background: #e2e8f0;
    overflow: hidden;
}

.milestone-progress-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, #22c55e, #16a34a);
    transition: width .4s ease;
}

/* AI Suggest panels */
.ai-suggest-panel {
    margin-top: .5rem;
    padding: .75rem 1rem;
    border-radius: .75rem;
    background: linear-gradient(135deg, #eff6ff, #f0fdf4);
    border: 1px solid #bfdbfe;
    font-size: .88rem;
    animation: aiSuggestFadeIn .3s ease;
}

.ai-suggest-panel .ai-suggest-disclaimer {
    font-size: .75rem;
    color: #6b7280;
    margin-bottom: .5rem;
    font-style: italic;
}

.ai-suggest-panel .ai-suggest-body {
    white-space: pre-wrap;
    color: #1e293b;
    line-height: 1.55;
}

.ai-suggest-btn:hover {
    color: #3b82f6 !important;
}

.ai-suggest-loading {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid #bfdbfe;
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: aiSpinAnim .6s linear infinite;
}

@keyframes aiSuggestFadeIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes aiSpinAnim {
    to { transform: rotate(360deg); }
}

.deal-temp-hot {
    animation: dealTempPulse 2s ease-in-out infinite;
}

@keyframes dealTempPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
    50% { box-shadow: 0 0 8px 3px rgba(245, 158, 11, 0.2); }
}
/* ── Fixed Status Bar ── */
.navbar-nj { z-index: 1085; }
.navbar-nj .dropdown-menu { z-index: 1086; }
.contract-status-bar { position: fixed; top: 56px; left: 0; right: 0; height: 40px; background: #0f172a; z-index: 1030; display: flex; align-items: center; justify-content: space-between; padding: 0 1.5rem; border-bottom: 1px solid #1e293b; transform: translateY(-40px); animation: csBarSlide 300ms ease forwards; }
@keyframes csBarSlide { to { transform: translateY(0); } }
.contract-status-bar .csb-left, .contract-status-bar .csb-center, .contract-status-bar .csb-right { font-size: .78rem; color: #cbd5e1; white-space: nowrap; }
.contract-status-bar .csb-left .csb-badge { display: inline-block; padding: .15rem .55rem; border-radius: 10rem; font-weight: 600; font-size: .72rem; margin-left: .4rem; }
.contract-status-bar .csb-center { color: #94a3b8; }
.contract-status-bar .csb-right a { font-size: .75rem; color: #93c5fd; text-decoration: none; font-weight: 600; }
.contract-status-bar .csb-right a:hover { text-decoration: underline; }
.contract-content-push { margin-top: 40px; }

/* Advisor chips */
.advisor-chip {
    background: #eff6ff;
    border: 1px solid #93c5fd;
    color: #1e40af;
    font-size: .72rem;
    padding: .2rem .6rem;
    border-radius: 999px;
    height: 28px;
    line-height: 1;
    white-space: nowrap;
    cursor: pointer;
    transition: background .15s, border-color .15s;
}
.advisor-chip:hover {
    background: #dbeafe;
    border-color: #3b82f6;
    color: #1e3a8a;
}

/* Typing indicator */
.typing-indicator {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: .5rem .85rem;
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 1rem;
    margin-bottom: .5rem;
}
.typing-indicator .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #94a3b8;
    animation: typingFade 1.2s ease-in-out infinite;
}
.typing-indicator .dot:nth-child(2) { animation-delay: .2s; }
.typing-indicator .dot:nth-child(3) { animation-delay: .4s; }
@keyframes typingFade {
    0%, 60%, 100% { opacity: .3; }
    30% { opacity: 1; }
}

.advisor-messages {
    height: 260px;
    overflow-y: auto;
    padding: .9rem;
    background: linear-gradient(180deg, #fafcff 0%, #f3f8ff 100%);
    border-top: 1px solid #dbeafe;
    scroll-behavior: smooth;
}

.advisor-empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100%;
    padding: 1rem;
}

.advisor-empty-card {
    max-width: 420px;
    width: 100%;
    text-align: center;
    background: rgba(255, 255, 255, .92);
    border: 1px solid #dbeafe;
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    box-shadow: 0 12px 28px rgba(37, 99, 235, .08);
}

.advisor-empty-card i {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 1.1rem;
    margin-bottom: .65rem;
}

.advisor-empty-card h6 {
    margin-bottom: .35rem;
    font-weight: 700;
    color: #1e3a8a;
}

.advisor-empty-card p {
    margin: 0;
    color: #64748b;
    font-size: .82rem;
    line-height: 1.5;
}

.advisor-composer {
    padding: .8rem .9rem .9rem;
    border-top: 1px solid #dbeafe;
    background: rgba(255, 255, 255, .88);
}

.advisor-composer textarea {
    min-height: 72px;
    resize: vertical;
    border-radius: .9rem;
    border-color: #bfdbfe;
    background: #fff;
    font-size: .9rem;
}

.advisor-composer-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    margin-top: .55rem;
}

.advisor-composer-hint {
    color: #64748b;
    font-size: .76rem;
}

.advisor-send-btn {
    min-width: 130px;
    border-radius: .8rem;
    font-weight: 600;
}

/* ── Signature Canvas Modal ── */
.sig-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(15, 23, 42, .65);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease;
}
.sig-overlay.active {
    opacity: 1;
    pointer-events: auto;
}
.sig-modal {
    background: #fff;
    border-radius: 1.25rem;
    box-shadow: 0 32px 64px rgba(15, 23, 42, .18);
    width: 660px;
    max-width: 96vw;
    overflow: hidden;
    transform: translateY(20px) scale(.97);
    transition: transform .3s ease;
}
.sig-overlay.active .sig-modal {
    transform: translateY(0) scale(1);
}
.sig-modal-header {
    padding: 1.25rem 1.5rem;
    background: linear-gradient(135deg, #0f172a, #1d4ed8);
    color: #fff;
}
.sig-modal-header h4 {
    margin: 0 0 .25rem;
    font-weight: 700;
    font-size: 1.15rem;
}
.sig-modal-header p {
    margin: 0;
    opacity: .8;
    font-size: .88rem;
}
.sig-canvas-wrap {
    padding: 1.25rem 1.5rem .75rem;
    display: flex;
    justify-content: center;
}
.sig-canvas-wrap canvas {
    border: 1.5px solid #d1d5db;
    border-radius: .75rem;
    background: #fff;
    cursor: crosshair;
    touch-action: none;
    max-width: 100%;
}
.sig-toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0 1.5rem .75rem;
    flex-wrap: wrap;
}
.sig-toolbar label {
    font-size: .82rem;
    color: #475569;
    font-weight: 600;
}
.sig-toolbar input[type="color"] {
    width: 32px;
    height: 32px;
    border: 2px solid #d1d5db;
    border-radius: .5rem;
    padding: 0;
    cursor: pointer;
}
.sig-toolbar select {
    font-size: .82rem;
    padding: .3rem .6rem;
    border-radius: .5rem;
    border: 1.5px solid #d1d5db;
}
.sig-toolbar .sig-clear-btn {
    margin-left: auto;
    font-size: .82rem;
    color: #dc2626;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: .5rem;
    padding: .3rem .75rem;
    cursor: pointer;
    font-weight: 600;
    transition: background .15s;
}
.sig-toolbar .sig-clear-btn:hover {
    background: #fee2e2;
}
.sig-disclaimer {
    padding: .5rem 1.5rem;
    font-size: .78rem;
    color: #64748b;
    font-style: italic;
}
.sig-footer {
    display: flex;
    justify-content: flex-end;
    gap: .75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid #e5e7eb;
}
.sig-footer .sig-cancel-btn {
    padding: .55rem 1.5rem;
    border-radius: .7rem;
    border: 1.5px solid #d1d5db;
    background: #fff;
    color: #475569;
    font-weight: 600;
    font-size: .9rem;
    cursor: pointer;
    transition: background .15s;
}
.sig-footer .sig-cancel-btn:hover {
    background: #f8fafc;
}
.sig-footer .sig-confirm-btn {
    padding: .55rem 1.5rem;
    border-radius: .7rem;
    border: none;
    background: linear-gradient(135deg, #1d4ed8, #2563eb);
    color: #fff;
    font-weight: 700;
    font-size: .9rem;
    cursor: pointer;
    transition: transform .1s, box-shadow .15s;
}
.sig-footer .sig-confirm-btn:hover {
    box-shadow: 0 4px 16px rgba(37, 99, 235, .35);
}
.sig-error {
    color: #dc2626;
    font-size: .82rem;
    font-weight: 600;
    padding: 0 1.5rem;
    display: none;
}
.sig-error.show {
    display: block;
}
@keyframes sigShake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-8px); }
    40%, 80% { transform: translateX(8px); }
}
.sig-shake {
    animation: sigShake .4s ease;
}

/* ── Signature display (Feature 3) ── */
.sig-drawn-img {
    max-width: 200px;
    max-height: 80px;
    border-bottom: 1px solid #ccc;
    display: block;
    margin-bottom: .35rem;
}
.sig-signer-name {
    font-family: 'Caveat', cursive;
    font-size: 1.1rem;
    color: #1e293b;
}
.sig-timestamp {
    font-size: .75rem;
    color: #94a3b8;
}
.sig-hash {
    font-family: Consolas, monospace;
    font-size: .7rem;
    color: #94a3b8;
    word-break: break-all;
}

/* ── Signature reveal animation (Feature 4) ── */
@keyframes signatureReveal {
    from { clip-path: inset(0 100% 0 0); }
    to { clip-path: inset(0 0% 0 0); }
}
.sig-reveal {
    animation: signatureReveal 1200ms ease-out both;
}
.sig-reveal-delay {
    animation: signatureReveal 1200ms ease-out 400ms both;
}
</style>

{# ── Fixed persistent status bar ── #}
{% set csBarStatus = 'Negociation active' %}
{% set csBarBadgeClass = 'background:#2563eb;color:#fff' %}
{% if offer.paid %}
    {% set csBarStatus = 'Finance' %}
    {% set csBarBadgeClass = 'background:#22c55e;color:#fff' %}
{% elseif contract.fullySigned %}
    {% set csBarStatus = 'Pret pour paiement' %}
    {% set csBarBadgeClass = 'background:#f59e0b;color:#0f172a' %}
{% elseif hasCurrentUserSigned %}
    {% set csBarStatus = 'En attente de cosignature' %}
    {% set csBarBadgeClass = 'background:#3b82f6;color:#fff' %}
{% endif %}

<div class="contract-status-bar">
    <div class="csb-left">Statut : <span class="csb-badge" style="{{ csBarBadgeClass }}">{{ csBarStatus }}</span></div>
    <div class="csb-center">
        {% if lastMessageAt %}
            Derniere activite : {{ lastMessageAt|date('d/m/Y H:i') }}
        {% else %}
            Aucun message — commencez la negociation
        {% endif %}
    </div>
    <div class="csb-right">
        {% if not contract.fullySigned %}
            <a href="#signatureSection">Signer le contrat &rarr;</a>
        {% elseif contract.fullySigned and not offer.paid %}
            <a href="{{ postSignatureUrl }}">{{ isInvestorParty ? 'Passer au paiement' : 'Retour aux contrats' }} &rarr;</a>
        {% elseif offer.paid %}
            <a href="#pdfSection">Voir le document &rarr;</a>
        {% endif %}
    </div>
</div>

<div class="contract-content-push"></div>

<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4" style="position:relative;z-index:1">
    <div>
        <a href="{{ path('app_invest_opportunity_show', {id: offer.opportunity.id}) }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Retour a l'opportunite</a>
        <h2 class="fw-bold mt-2 mb-1">Contrat d'investissement</h2>
        <div class="text-muted">Negociation en temps reel entre {{ contract.investor.fullName }} et {{ contract.entrepreneur.fullName }}.</div>
        <div class="small mt-2 {{ isInvestorParty ? 'text-primary' : 'text-success' }}">
            Vous intervenez ici en tant que {{ isInvestorParty ? 'investisseur' : 'entrepreneur' }}. Les deux parties peuvent negocier les termes, envoyer des messages et signer.
        </div>
        {% if offer.riskAcknowledged %}
        <div class="d-inline-flex align-items-center gap-2 mt-2 px-3 py-1 rounded-pill" style="background:#dcfce7;color:#15803d;font-size:.82rem;font-weight:600">
            <i class="bi bi-shield-check"></i>L'investisseur a consulte l'evaluation de risque avant de soumettre son offre
        </div>
        {% endif %}
    </div>
    <div class="d-flex gap-2 flex-wrap">
        {% if canPayNow %}
            <a href="{{ postSignatureUrl }}" class="btn btn-nj">{{ isInvestorParty ? 'Revenir au paiement' : 'Retour aux contrats' }}</a>
        {% endif %}
        {% if offer.paid and is_granted('ROLE_INVESTISSEUR') %}
            <a href="{{ path('app_invest_portfolio') }}" class="btn btn-outline-success">Voir le portfolio</a>
        {% endif %}
        {% if not canPayNow %}
            <a href="{{ contractsIndexUrl }}" class="btn btn-outline-secondary">Mes contrats</a>
        {% endif %}
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

{# ── Lifecycle stepper ── #}
{% set step1done = offer.status == 'ACCEPTED' or offer.paid %}
{% set step2done = contract.title is not empty and contract.terms is not empty %}
{% set step3done = contract.fullySigned %}
{% set step4done = contract.fullySigned and not offer.paid %}
{% set step5done = offer.paid %}

{# Walk forward to find the active step (first incomplete) #}
{% if not step1done %}
    {% set activeStep = 1 %}
{% elseif not step2done %}
    {% set activeStep = 2 %}
{% elseif not step3done %}
    {% set activeStep = 3 %}
{% elseif not step5done %}
    {% set activeStep = 4 %}
{% else %}
    {% set activeStep = 5 %}
{% endif %}

{% set stepLabels = {1: 'Offre acceptee', 2: 'Termes rediges', 3: 'Double signature', 4: 'Paiement en cours', 5: 'Finance'} %}
{% set stepDone  = {1: step1done, 2: step2done, 3: step3done, 4: step5done, 5: step5done} %}

<div class="lc-stepper" id="dealStatusBanner">
    {% for i in 1..5 %}
        {% if i < activeStep %}
            {% set cls = 'done' %}
        {% elseif i == activeStep %}
            {% set cls = 'active' %}
        {% else %}
            {% set cls = '' %}
        {% endif %}
        <div class="lc-step {{ cls }}">
            <span class="lc-circle">
                {% if i < activeStep %}
                    <i class="bi bi-check-lg"></i>
                {% else %}
                    {{ i }}
                {% endif %}
            </span>
            <span class="lc-label">{{ stepLabels[i] }}</span>
            {% if i == 4 %}
                <span class="lc-sublabel" style="display:block;font-size:.65rem;color:#64748b;font-weight:400;margin-top:1px">Apres signature des deux parties</span>
            {% endif %}
        </div>
    {% endfor %}
</div>
<div class="lc-mobile-hint">
    <span class="lc-circle">{{ activeStep }}</span>
    <strong>{{ stepLabels[activeStep] }}</strong>
    <span class="text-muted ms-1">&mdash; Etape {{ activeStep }} sur 5</span>
</div>

<div class="contract-shell">
    <div class="d-flex flex-column gap-4">
        <div class="card contract-card">
            <div class="contract-hero">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <div class="small text-uppercase opacity-75 mb-2">Projet</div>
                        <h3 class="fw-bold mb-1">{{ offer.opportunity.project ? offer.opportunity.project.titre : 'Projet' }}</h3>
                        <div class="opacity-75">Offre acceptee de {{ offer.proposedAmount|number_format(0, ',', ' ') }} DT</div>
                    </div>
                    <span class="signature-chip {{ contract.fullySigned ? 'bg-success text-white' : 'bg-light text-dark' }}" id="signatureStatus">
                        {{ contract.fullySigned ? 'Signe par les deux parties' : 'Signature en attente' }}
                    </span>
                </div>

                {# Deal Temperature #}
                {% if dealTemperatureLabel is defined %}
                <div class="d-flex align-items-center gap-2 mt-3">
                    {% if dealTemperatureLabel == 'hot' %}
                        <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill deal-temp-hot" style="background:#fef3c7;color:#92400e;font-size:.82rem;font-weight:600">
                            <i class="bi bi-fire"></i>Hot ({{ dealTemperature }})
                        </span>
                    {% elseif dealTemperatureLabel == 'active' %}
                        <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#dcfce7;color:#15803d;font-size:.82rem;font-weight:600">
                            <i class="bi bi-activity"></i>Actif ({{ dealTemperature }})
                        </span>
                    {% else %}
                        <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#e0f2fe;color:#0369a1;font-size:.82rem;font-weight:600">
                            <i class="bi bi-snow"></i>Froid ({{ dealTemperature }})
                        </span>
                    {% endif %}
                    <span class="small" style="color:#64748b">
                        {% if lastMessageAt %}
                            {% set hoursDiff = ((date().timestamp - lastMessageAt.timestamp) / 3600)|round(0, 'floor') %}
                            {% if hoursDiff < 1 %}
                                Negociation active — dernier message a l'instant
                            {% elseif hoursDiff < 24 %}
                                Negociation active — dernier message il y a {{ hoursDiff }} heure{{ hoursDiff > 1 ? 's' : '' }}
                            {% elseif hoursDiff < 168 %}
                                {% set daysDiff = (hoursDiff / 24)|round(0, 'floor') %}
                                Ce deal est calme depuis {{ daysDiff }} jour{{ daysDiff > 1 ? 's' : '' }}
                            {% else %}
                                Ce deal est silencieux depuis plus d'une semaine
                            {% endif %}
                        {% else %}
                            Aucun message echange pour le moment
                        {% endif %}
                    </span>
                </div>
                {% endif %}
                <div class="row g-3 mt-1">
                    <div class="col-md-4">
                        <div class="contract-stat">
                            <div class="small opacity-75">Statut</div>
                            <div class="fw-bold" id="contractStatusLabel">{{ contract.status }}</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="contract-stat">
                            <div class="small opacity-75">Participation</div>
                            <div class="fw-bold">{{ contract.equityPercentage ? contract.equityPercentage|number_format(2, ',', ' ') ~ ' %' : 'A definir' }}</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="contract-stat">
                            <div class="small opacity-75">Paiement</div>
                            <div class="fw-bold" id="paymentGateStatus">{{ canPayNow ? 'Disponible' : (offer.paid ? 'Effectue' : 'Bloque') }}</div>
                        </div>
                    </div>
                </div>

                {# ── Payment availability gate ── #}
                {% if not offer.paid %}
                <div class="mt-3" id="paymentGateNotice">
                    {% if contract.fullySigned %}
                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded" style="background:#dcfce7;border:1px solid #86efac">
                            <i class="bi bi-check-circle-fill" style="color:#16a34a;font-size:1.1rem"></i>
                            <span style="color:#15803d;font-weight:600;font-size:.88rem">Contrat signe par les deux parties -- le paiement est maintenant disponible.</span>
                        </div>
                        {% if isInvestorParty %}
                        <div class="mt-2">
                            <a href="{{ postSignatureUrl }}" class="btn btn-nj btn-sm">Proceder au paiement</a>
                        </div>
                        {% endif %}
                    {% elseif contract.investorSignedAt or contract.entrepreneurSignedAt %}
                        {% set missingSigner = contract.investorSignedAt ? contract.entrepreneur.fullName ~ ' (entrepreneur)' : contract.investor.fullName ~ ' (investisseur)' %}
                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded" style="background:#fef3c7;border:1px solid #fcd34d">
                            <i class="bi bi-hourglass-split" style="color:#d97706;font-size:1.1rem"></i>
                            <span style="color:#92400e;font-weight:600;font-size:.88rem">En attente de la signature de {{ missingSigner }}</span>
                        </div>
                    {% else %}
                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded" style="background:#e0f2fe;border:1px solid #7dd3fc">
                            <i class="bi bi-pen" style="color:#0369a1;font-size:1.1rem"></i>
                            <span style="color:#0c4a6e;font-size:.88rem">Signez le contrat pour debloquer le paiement. <a href="#signatureSection" style="color:#0369a1;font-weight:600;text-decoration:underline">Aller a la signature</a></span>
                        </div>
                    {% endif %}
                </div>
                {% endif %}

            </div>
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h5 class="fw-bold mb-0">Version actuelle du contrat</h5>
                    <span class="digest-badge" id="digestPreview"><i class="bi bi-shield-check"></i>{{ contract.termsDigest|slice(0, 20) }}...</span>
                </div>
                <div class="small text-muted mb-4">Chaque signature enregistre une empreinte SHA-256 du contrat, du signataire, de la date et du contexte de signature. Toute modification des termes reinitialise les signatures.</div>

                <form method="post" action="{{ path('app_invest_contract_update_terms', {id: offer.id}) }}" class="mb-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('contract_terms_' ~ offer.id) }}">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Titre du contrat</label>
                            <input type="text" name="title" class="form-control" value="{{ contract.title }}" required>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <label class="form-label fw-semibold mb-0">Participation au capital (%)</label>
                                <button type="button" class="btn btn-sm p-0 border-0 text-muted ai-suggest-btn" data-field="equity" title="Suggestion IA" style="font-size:.95rem;line-height:1"><i class="bi bi-stars"></i></button>
                            </div>
                            <input type="number" step="0.01" min="0" max="100" name="equity_percentage" class="form-control" value="{{ contract.equityPercentage }}" placeholder="Ex: 8.5">
                            <div class="ai-suggest-panel d-none" id="aiSuggestEquity"></div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Contreparties / avantages</label>
                            <input type="text" name="consideration" class="form-control" value="{{ contract.consideration }}" placeholder="Ex: acces anticipe, distribution exclusive, licence...">
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <label class="form-label fw-semibold mb-0">Etapes et obligations</label>
                                <button type="button" class="btn btn-sm p-0 border-0 text-muted ai-suggest-btn" data-field="milestones" title="Suggestion IA" style="font-size:.95rem;line-height:1"><i class="bi bi-stars"></i></button>
                            </div>
                            <textarea name="milestones" rows="3" class="form-control" placeholder="Decrivez les livrables, etapes de versement ou conditions de release...">{{ contract.milestones }}</textarea>
                            <div class="ai-suggest-panel d-none" id="aiSuggestMilestones"></div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <label class="form-label fw-semibold mb-0">Termes detailles</label>
                                <button type="button" class="btn btn-sm p-0 border-0 text-muted ai-suggest-btn" data-field="terms" title="Suggestion IA" style="font-size:.95rem;line-height:1"><i class="bi bi-stars"></i></button>
                            </div>
                            <textarea name="terms" rows="10" class="form-control" required>{{ contract.terms }}</textarea>
                            <div class="ai-suggest-panel d-none" id="aiSuggestTerms"></div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn btn-outline-primary">Enregistrer les termes</button>
                    </div>
                </form>

                <div class="row g-3 mb-4" id="signatureSection">
                    <div class="col-md-6">
                        <div class="signature-panel h-100">
                            <div class="small text-muted mb-1">Investisseur</div>
                            <div class="fw-bold mb-2">{{ contract.investor.fullName }}</div>
                            {% if contract.investorSignatureImage %}
                                <img src="{{ contract.investorSignatureImage }}" alt="Signature investisseur" class="sig-drawn-img sig-reveal" id="investorSigImg">
                                <div class="sig-signer-name">{{ contract.investorSignatureName }}</div>
                                <div class="sig-timestamp">Signe le {{ contract.investorSignedAt|date('d/m/Y H:i') }}</div>
                                <div class="sig-hash">{{ contract.investorSignatureHash|slice(0, 24) }}...</div>
                            {% elseif contract.investorSignedAt %}
                                <div id="investorSignatureState" class="small text-success fw-semibold">
                                    Signe le {{ contract.investorSignedAt|date('d/m/Y H:i') }}
                                </div>
                            {% else %}
                                <div id="investorSignatureState" class="small text-muted">Signature en attente</div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="signature-panel h-100">
                            <div class="small text-muted mb-1">Entrepreneur</div>
                            <div class="fw-bold mb-2">{{ contract.entrepreneur.fullName }}</div>
                            {% if contract.entrepreneurSignatureImage %}
                                <img src="{{ contract.entrepreneurSignatureImage }}" alt="Signature entrepreneur" class="sig-drawn-img {{ contract.investorSignatureImage ? 'sig-reveal-delay' : 'sig-reveal' }}" id="entrepreneurSigImg">
                                <div class="sig-signer-name">{{ contract.entrepreneurSignatureName }}</div>
                                <div class="sig-timestamp">Signe le {{ contract.entrepreneurSignedAt|date('d/m/Y H:i') }}</div>
                                <div class="sig-hash">{{ contract.entrepreneurSignatureHash|slice(0, 24) }}...</div>
                            {% elseif contract.entrepreneurSignedAt %}
                                <div id="entrepreneurSignatureState" class="small text-success fw-semibold">
                                    Signe le {{ contract.entrepreneurSignedAt|date('d/m/Y H:i') }}
                                </div>
                            {% else %}
                                <div id="entrepreneurSignatureState" class="small text-muted">Signature en attente</div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <form method="post" action="{{ path('app_invest_contract_sign', {id: offer.id}) }}" class="row g-3 align-items-end" id="signatureForm">
                    <input type="hidden" name="_token" value="{{ csrf_token('contract_sign_' ~ offer.id) }}">
                    <input type="hidden" name="signature_image" id="signatureImageInput" value="">
                    <div class="col-lg-8">
                        <label class="form-label fw-semibold">Nom du signataire</label>
                        <input type="text" name="signature_name" class="form-control" id="contractSignatureName" value="{{ currentUser.fullName }}" placeholder="Votre nom complet" required>
                    </div>
                    <div class="col-lg-4 d-grid">
                        <button type="button" class="btn {{ hasCurrentUserSigned ? 'btn-outline-secondary' : 'btn-nj' }}" id="contractSignBtn" {{ contract.fullySigned ? 'disabled' : '' }}>
                            {{ hasCurrentUserSigned ? 'Signature deja enregistree' : 'Signer numeriquement' }}
                        </button>
                    </div>
                </form>
            </div>
        </div>

        {# ── Funding milestones section ── #}
        <div class="card contract-card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h5 class="fw-bold mb-0">Jalons de financement</h5>
                    {% if hasMilestones %}
                        {% set releasedPct = 0 %}
                        {% for m in milestones %}
                            {% if m.status == 'RELEASED' %}
                                {% set releasedPct = releasedPct + m.percentage %}
                            {% endif %}
                        {% endfor %}
                        <span class="badge bg-primary fs-6">{{ releasedPct|number_format(0) }}% libere</span>
                    {% endif %}
                </div>

                {% if hasMilestones %}
                    {# Progress bar #}
                    <div class="milestone-progress-bar mb-3">
                        <div class="milestone-progress-fill" style="width: {{ releasedPct|default(0) }}%"></div>
                    </div>

                    <div class="d-flex flex-column gap-3 mb-3">
                        {% for m in milestones %}
                            <div class="milestone-card {{ m.status|lower }}">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <div>
                                        <div class="fw-bold">{{ m.label }}</div>
                                        <div class="small text-muted">{{ m.percentage|number_format(0) }}% &mdash; {{ m.amount|number_format(0, ',', ' ') }} DT</div>
                                    </div>
                                    <span class="badge {{ m.status == 'RELEASED' ? 'bg-success' : (m.status == 'CONFIRMED' ? 'bg-primary' : (m.status == 'COMPLETED' ? 'bg-warning text-dark' : 'bg-secondary')) }}">
                                        {{ m.status == 'RELEASED' ? 'Libere' : (m.status == 'CONFIRMED' ? 'Confirme' : (m.status == 'COMPLETED' ? 'Termine' : 'En attente')) }}
                                    </span>
                                </div>

                                {# Actions based on role and status #}
                                {% if m.status == 'PENDING' and isEntrepreneurParty and contract.fullySigned %}
                                    <form method="post" action="{{ path('app_invest_milestone_complete', {id: offer.id, milestoneId: m.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('milestone_action_' ~ m.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Marquer comme termine</button>
                                    </form>
                                {% elseif m.status == 'COMPLETED' and isInvestorParty %}
                                    <form method="post" action="{{ path('app_invest_milestone_confirm', {id: offer.id, milestoneId: m.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('milestone_action_' ~ m.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Confirmer la livraison</button>
                                    </form>
                                {% elseif m.status == 'CONFIRMED' and isInvestorParty %}
                                    <form method="post" action="{{ path('app_invest_milestone_release', {id: offer.id, milestoneId: m.id}) }}" onsubmit="return confirm('Liberer {{ m.amount|number_format(0, ',', ' ') }} DT pour ce jalon ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('milestone_action_' ~ m.id) }}">
                                        <button type="submit" class="btn btn-sm btn-success">Liberer {{ m.amount|number_format(0, ',', ' ') }} DT</button>
                                    </form>
                                {% elseif m.status == 'RELEASED' %}
                                    <div class="small text-success">
                                        <i class="bi bi-check-circle-fill me-1"></i>Paiement libere {{ m.releasedAt ? 'le ' ~ m.releasedAt|date('d/m/Y H:i') : '' }}
                                    </div>
                                {% elseif m.status == 'COMPLETED' and isEntrepreneurParty %}
                                    <div class="small text-warning">En attente de confirmation de l'investisseur</div>
                                {% elseif m.status == 'PENDING' and isInvestorParty %}
                                    <div class="small text-muted">L'entrepreneur doit d'abord marquer ce jalon comme termine.</div>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    {# Define milestones form — only investor can set up milestones, and only if not yet paid #}
                    {% if isInvestorParty and not offer.paid %}
                        <div class="small text-muted mb-3">Definissez entre 2 et 4 jalons de paiement. Chaque jalon represente une etape de livraison avec un pourcentage du montant total ({{ offer.proposedAmount|number_format(0, ',', ' ') }} DT). Le total doit faire 100%.</div>
                        <form method="post" action="{{ path('app_invest_contract_save_milestones', {id: offer.id}) }}" id="milestoneForm">
                            <input type="hidden" name="_token" value="{{ csrf_token('milestones_' ~ offer.id) }}">
                            <div id="milestoneRows">
                                <div class="row g-2 mb-2 milestone-row">
                                    <div class="col-7">
                                        <input type="text" name="milestone_label[]" class="form-control form-control-sm" placeholder="Ex: Livraison prototype" required minlength="3">
                                    </div>
                                    <div class="col-3">
                                        <div class="input-group input-group-sm">
                                            <input type="number" name="milestone_percentage[]" class="form-control form-control-sm milestone-pct" min="5" max="80" step="1" placeholder="%" required>
                                            <span class="input-group-text">%</span>
                                        </div>
                                    </div>
                                    <div class="col-2 d-flex align-items-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-milestone-row d-none"><i class="bi bi-x-lg"></i></button>
                                    </div>
                                </div>
                                <div class="row g-2 mb-2 milestone-row">
                                    <div class="col-7">
                                        <input type="text" name="milestone_label[]" class="form-control form-control-sm" placeholder="Ex: Lancement commercial" required minlength="3">
                                    </div>
                                    <div class="col-3">
                                        <div class="input-group input-group-sm">
                                            <input type="number" name="milestone_percentage[]" class="form-control form-control-sm milestone-pct" min="5" max="80" step="1" placeholder="%" required>
                                            <span class="input-group-text">%</span>
                                        </div>
                                    </div>
                                    <div class="col-2 d-flex align-items-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-milestone-row d-none"><i class="bi bi-x-lg"></i></button>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-2 mb-3">
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="addMilestoneRow">+ Ajouter un jalon</button>
                                <div class="small fw-semibold" id="milestoneTotalLabel">Total : 0%</div>
                            </div>
                            <button type="submit" class="btn btn-nj w-100">Enregistrer les jalons</button>
                        </form>
                    {% else %}
                        <div class="text-muted small">Aucun jalon de financement defini. {% if isInvestorParty %}Vous pouvez en definir avant le paiement.{% else %}L'investisseur peut definir des jalons de paiement.{% endif %}</div>
                    {% endif %}
                {% endif %}
            </div>
        </div>

        <div class="card contract-card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Lecture rapide</h5>
                    <span class="small text-muted">Derniere mise a jour {{ contract.updatedAt|date('d/m/Y H:i') }}</span>
                </div>
                <div class="terms-box">{{ contract.terms }}</div>
            </div>
        </div>

        {% if contract.fullySigned and pdfPreviewUrl %}
        <div class="card contract-card">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">Document PDF du contrat</h5>
                        <div class="text-muted small">Le PDF officiel est maintenant disponible avec les termes, le montant, l'empreinte SHA-256 et les deux signatures.</div>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="{{ pdfPreviewUrl }}" target="_blank" rel="noopener" class="btn btn-outline-primary">Ouvrir le PDF</a>
                        <a href="{{ pdfDownloadUrl }}" class="btn btn-outline-success">Telecharger</a>
                        <a href="{{ printViewUrl }}" target="_blank" rel="noopener" class="btn btn-nj">Imprimer</a>
                    </div>
                </div>
                <div class="pdf-panel mb-3" id="pdfSection">
                    <div class="small text-muted">Disponible des la seconde signature. Le bouton "Imprimer" ouvre une vue propre qui lance la boite d'impression du navigateur.</div>
                </div>
                <object data="{{ pdfPreviewUrl }}" type="application/pdf" class="pdf-preview">
                    <div class="alert alert-info mb-0">Le navigateur ne peut pas afficher l'aperçu PDF ici. Utilisez les boutons ci-dessus pour ouvrir, telecharger ou imprimer le contrat.</div>
                </object>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="card contract-card chat-shell">
        <div class="card-body border-bottom chat-header">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                    <div class="small text-uppercase text-muted mb-1">Negociation</div>
                    <h5 class="fw-bold mb-1">Messagerie en temps reel</h5>
                    <div class="text-muted small">Les nouveaux messages sont pousses par polling rapide et remontent aussi dans les notifications.</div>
                </div>
                <div class="text-end small text-muted">
                    <div>Interlocuteur</div>
                    <div class="fw-semibold text-dark">{{ otherParty ? otherParty.fullName : 'Partie' }}</div>
                </div>
            </div>
        </div>
        <div class="chat-list" id="contractChatList">
            {% for message in messages %}
                <div class="chat-bubble {{ message.systemMessage ? 'system' : (message.sender.id == currentUser.id ? 'mine' : 'theirs') }}" data-message-id="{{ message.id }}">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="fw-semibold small">{{ message.sender.fullName }}</span>
                        <span class="small opacity-75">{{ message.createdAt|date('d/m/Y H:i') }}</span>
                    </div>
                    <div style="white-space:pre-wrap">{{ message.body }}</div>
                </div>
            {% else %}
                <div class="text-muted small" id="chatEmptyState">Aucun message pour le moment. Utilisez ce fil pour negocier les conditions du contrat.</div>
            {% endfor %}
