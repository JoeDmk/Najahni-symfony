<script>
(function() {
    var chatList = document.getElementById('contractChatList');
    var chatForm = document.getElementById('contractMessageForm');
    var chatInput = document.getElementById('contractMessageInput');
    var chatError = document.getElementById('contractMessageError');
    var chatSubmit = document.getElementById('contractMessageSubmit');
    var digestPreview = document.getElementById('digestPreview');
    var signatureStatus = document.getElementById('signatureStatus');
    var investorSignatureState = document.getElementById('investorSignatureState');
    var entrepreneurSignatureState = document.getElementById('entrepreneurSignatureState');
    var paymentGateStatus = document.getElementById('paymentGateStatus');
    var contractStatusLabel = document.getElementById('contractStatusLabel');
    var contractSignBtn = document.getElementById('contractSignBtn');
    var contractSignatureName = document.getElementById('contractSignatureName');
    var messageUrl = '{{ path('app_invest_contract_messages', {id: offer.id}) }}';
    var sendUrl = '{{ path('app_invest_contract_send_message', {id: offer.id}) }}';
    var lastMessageNode = chatList.querySelector('[data-message-id]:last-of-type');
    var lastMessageId = lastMessageNode ? Number(lastMessageNode.getAttribute('data-message-id')) : 0;

    function escapeHtml(text) {
        return String(text == null ? '' : text)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function scrollToBottom() {
        chatList.scrollTop = chatList.scrollHeight;
    }

    function renderMessage(message) {
        var bubbleClass = message.system ? 'system' : (message.mine ? 'mine' : 'theirs');
        return '<div class="chat-bubble ' + bubbleClass + '" data-message-id="' + message.id + '">'
            + '<div class="d-flex justify-content-between align-items-center gap-2 mb-2">'
            + '<span class="fw-semibold small">' + escapeHtml(message.senderName) + '</span>'
            + '<span class="small opacity-75">' + escapeHtml(message.createdAt) + '</span>'
            + '</div>'
            + '<div style="white-space:pre-wrap">' + escapeHtml(message.body) + '</div>'
            + '</div>';
    }

    function applyContractState(contract) {
        if (!contract) {
            return;
        }

        contractStatusLabel.textContent = contract.status;
        digestPreview.innerHTML = '<i class="bi bi-shield-check"></i>' + escapeHtml((contract.digest || '').slice(0, 20)) + '...';
        signatureStatus.textContent = contract.fullySigned ? 'Signe par les deux parties' : 'Signature en attente';
        signatureStatus.className = 'signature-chip ' + (contract.fullySigned ? 'bg-success text-white' : 'bg-light text-dark');
        investorSignatureState.textContent = contract.investorSigned ? 'Signe le ' + contract.investorSigned : 'Signature en attente';
        investorSignatureState.className = 'small ' + (contract.investorSigned ? 'text-success fw-semibold' : 'text-muted');
        entrepreneurSignatureState.textContent = contract.entrepreneurSigned ? 'Signe le ' + contract.entrepreneurSigned : 'Signature en attente';
        entrepreneurSignatureState.className = 'small ' + (contract.entrepreneurSigned ? 'text-success fw-semibold' : 'text-muted');
        paymentGateStatus.textContent = {{ offer.paid ? "'Effectue'" : "(contract.fullySigned ? 'Disponible' : 'Bloque')" }};

        if (contractSignBtn) {
            contractSignBtn.disabled = !!contract.fullySigned;
            contractSignBtn.textContent = contract.signedByMe ? 'Signature deja enregistree' : 'Signer numeriquement';
            contractSignBtn.className = 'btn ' + (contract.signedByMe ? 'btn-outline-secondary' : 'btn-nj');
        }

        if (contractSignatureName) {
            contractSignatureName.readOnly = !!contract.fullySigned;
        }
    }

    function appendMessages(messages) {
        if (!messages || !messages.length) {
            return;
        }

        var emptyState = document.getElementById('chatEmptyState');
        if (emptyState) {
            emptyState.remove();
        }

        messages.forEach(function(message) {
            if (message.id > lastMessageId) {
                lastMessageId = message.id;
            }
            chatList.insertAdjacentHTML('beforeend', renderMessage(message));
        });
        scrollToBottom();
    }

    function pollMessages() {
        fetch(messageUrl + '?afterId=' + encodeURIComponent(lastMessageId), {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            appendMessages(data.messages || []);
            applyContractState(data.contract || null);
        })
        .catch(function() {});
    }

    chatForm.addEventListener('submit', function(event) {
        event.preventDefault();
        var text = chatInput.value.trim();
        if (!text) {
            chatError.textContent = 'Le message ne peut pas etre vide.';
            chatError.classList.remove('d-none');
            return;
        }

        chatError.classList.add('d-none');
        chatSubmit.disabled = true;

        var body = new URLSearchParams();
        body.append('_token', document.getElementById('contractMessageToken').value);
        body.append('message', text);

        fetch(sendUrl, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: body
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (!data.success) {
                chatError.textContent = data.error || 'Envoi impossible pour le moment.';
                chatError.classList.remove('d-none');
                chatSubmit.disabled = false;
                return;
            }

            appendMessages([data.message]);
            applyContractState(data.contract || null);
            chatInput.value = '';
            chatSubmit.disabled = false;
        })
        .catch(function() {
            chatError.textContent = 'Erreur reseau pendant l\'envoi du message.';
            chatError.classList.remove('d-none');
            chatSubmit.disabled = false;
        });
    });

    scrollToBottom();
    setInterval(pollMessages, 4000);
})();

// Milestone form logic
(function() {
    var form = document.getElementById('milestoneForm');
    if (!form) return;

    var container = document.getElementById('milestoneRows');
    var addBtn = document.getElementById('addMilestoneRow');
    var totalLabel = document.getElementById('milestoneTotalLabel');

    function updateTotal() {
        var pcts = container.querySelectorAll('.milestone-pct');
        var total = 0;
        pcts.forEach(function(el) { total += parseFloat(el.value) || 0; });
        totalLabel.textContent = 'Total : ' + total + '%';
        totalLabel.className = 'small fw-semibold ' + (Math.abs(total - 100) < 0.01 ? 'text-success' : (total > 100 ? 'text-danger' : ''));
    }

    function updateRemoveButtons() {
        var rows = container.querySelectorAll('.milestone-row');
        rows.forEach(function(row) {
            var btn = row.querySelector('.remove-milestone-row');
            if (btn) btn.classList.toggle('d-none', rows.length <= 2);
        });
    }

    addBtn.addEventListener('click', function() {
        var rows = container.querySelectorAll('.milestone-row');
        if (rows.length >= 4) return;
        var clone = rows[0].cloneNode(true);
        clone.querySelectorAll('input').forEach(function(inp) { inp.value = ''; });
        container.appendChild(clone);
        updateRemoveButtons();
        if (rows.length + 1 >= 4) addBtn.disabled = true;
    });

    container.addEventListener('click', function(e) {
        if (e.target.closest('.remove-milestone-row')) {
            var rows = container.querySelectorAll('.milestone-row');
            if (rows.length <= 2) return;
            e.target.closest('.milestone-row').remove();
            updateRemoveButtons();
            updateTotal();
            addBtn.disabled = false;
        }
    });

    container.addEventListener('input', function(e) {
        if (e.target.classList.contains('milestone-pct')) updateTotal();
    });

    updateRemoveButtons();
    updateTotal();
})();

