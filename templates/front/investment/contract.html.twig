// Particle Network
(function() {
    var canvas = document.getElementById('particleNetworkCanvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var particles = [];
    var PARTICLE_COUNT = 60;
    var CONNECT_DIST = 120;
    var burstUntil = 0;

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    for (var i = 0; i < PARTICLE_COUNT; i++) {
        particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.6,
            vy: (Math.random() - 0.5) * 0.6,
            r: 2 + Math.random() * 2,
            baseVx: 0, baseVy: 0
        });
        particles[i].baseVx = particles[i].vx;
        particles[i].baseVy = particles[i].vy;
    }

    function tick() {
        requestAnimationFrame(tick);
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        var now = Date.now();
        var bursting = now < burstUntil;

        for (var i = 0; i < particles.length; i++) {
            var p = particles[i];
            if (bursting) {
                p.vx = p.baseVx * 4;
                p.vy = p.baseVy * 4;
            } else {
                p.vx += (p.baseVx - p.vx) * 0.05;
                p.vy += (p.baseVy - p.vy) * 0.05;
            }
            p.x += p.vx;
            p.y += p.vy;
            if (p.x < 0 || p.x > canvas.width) { p.vx *= -1; p.baseVx *= -1; p.x = Math.max(0, Math.min(canvas.width, p.x)); }
            if (p.y < 0 || p.y > canvas.height) { p.vy *= -1; p.baseVy *= -1; p.y = Math.max(0, Math.min(canvas.height, p.y)); }

            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(59,130,246,.7)';
            ctx.fill();

            for (var j = i + 1; j < particles.length; j++) {
                var q = particles[j];
                var dx = p.x - q.x;
                var dy = p.y - q.y;
                var dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < CONNECT_DIST) {
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(q.x, q.y);
                    ctx.strokeStyle = 'rgba(59,130,246,' + (0.4 * (1 - dist / CONNECT_DIST)).toFixed(3) + ')';
                    ctx.lineWidth = 0.8;
                    ctx.stroke();
                }
            }
        }
    }
    tick();

    // Watch for signing success flash to trigger burst
    var observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(m) {
            m.addedNodes.forEach(function(node) {
                if (node.nodeType === 1 && node.classList && node.classList.contains('alert-success')) {
                    burstUntil = Date.now() + 800;
                }
            });
        });
    });
    observer.observe(document.querySelector('[class*="block"]') || document.body, { childList: true, subtree: true });
})();

// Deal Advisor
(function() {
    var toggle = document.getElementById('dealAdvisorToggle');
    var body = document.getElementById('dealAdvisorBody');
    var chevron = document.getElementById('dealAdvisorChevron');
    var messages = document.getElementById('advisorMessages');
    var input = document.getElementById('advisorInput');
    var sendBtn = document.getElementById('advisorSendBtn');
    var chips = document.getElementById('advisorSuggestedPrompts');
    var advisorUrl = '{{ path("app_invest_contract_advisor", {id: offer.id}) }}';
    var advisorHistory = [];
    var advisorFirstSent = false;
    var advisorOpen = false;
    var advisorSeeded = false;

    if (!toggle || !body) return;

    function ensureAdvisorOpen() {
        advisorOpen = true;
        body.classList.remove('d-none');
        chevron.style.transform = 'rotate(180deg)';
        setTimeout(function() {
            input.focus();
        }, 50);
    }

    function seedAdvisorIntro() {
        if (advisorSeeded) return;
        advisorSeeded = true;
        appendAssistant('Je peux vous aider a analyser ce deal, proposer une structure de milestones, ou revoir les points sensibles du contrat.');
    }

    toggle.addEventListener('click', function() {
        advisorOpen = !advisorOpen;
        body.classList.toggle('d-none', !advisorOpen);
        chevron.style.transform = advisorOpen ? 'rotate(180deg)' : '';
        if (advisorOpen) {
            seedAdvisorIntro();
            setTimeout(function() {
                input.focus();
            }, 50);
        }
    });

    function parseMd(text) {
        var safe = String(text || '');
        safe = safe.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
        safe = safe.replace(/\*(.+?)\*/g, '<em>$1</em>');
        var blocks = safe.split(/\n{2,}/);
        var html = [];
        blocks.forEach(function(block) {
            block = block.trim();
            if (!block) return;
            var lines = block.split('\n');
            if (/^\d+\.\s/.test(lines[0])) {
                html.push('<ol>' + lines.map(function(l) { return '<li>' + l.replace(/^\d+\.\s*/, '') + '</li>'; }).join('') + '</ol>');
            } else if (/^[-*]\s/.test(lines[0])) {
                html.push('<ul>' + lines.map(function(l) { return '<li>' + l.replace(/^[-*]\s*/, '') + '</li>'; }).join('') + '</ul>');
            } else {
                html.push('<p>' + lines.join('<br>') + '</p>');
            }
        });
        return html.join('');
    }

    function typewriter(element, htmlContent, cb) {
        var temp = document.createElement('div');
        temp.innerHTML = htmlContent;
        var rawText = temp.textContent || temp.innerText || '';
        var i = 0;
        element.textContent = '';
        var iv = setInterval(function() {
            i += 1;
            element.textContent = rawText.substring(0, i);
            messages.scrollTop = messages.scrollHeight;
            if (i >= rawText.length) {
                clearInterval(iv);
                element.innerHTML = htmlContent;
                messages.scrollTop = messages.scrollHeight;
                if (cb) cb();
            }
        }, 55);
    }

    function appendUser(text) {
        var placeholder = document.getElementById('advisorPlaceholder');
        if (placeholder) placeholder.remove();
        var div = document.createElement('div');
        div.className = 'mb-2 text-end';
        var bubble = document.createElement('div');
        bubble.className = 'd-inline-block px-3 py-2 rounded-3 bg-primary text-white small';
        bubble.style.maxWidth = '85%';
        bubble.style.textAlign = 'left';
        bubble.textContent = text;
        div.appendChild(bubble);
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
    }

    function appendAssistant(text) {
        var placeholder = document.getElementById('advisorPlaceholder');
        if (placeholder) placeholder.remove();
        var div = document.createElement('div');
        div.className = 'mb-2';
        var bubble = document.createElement('div');
        bubble.className = 'd-inline-block px-3 py-2 rounded-3 small';
        bubble.style.maxWidth = '85%';
        bubble.style.textAlign = 'left';
        bubble.style.background = '#eff6ff';
        bubble.style.border = '1px solid #bfdbfe';
        var content = document.createElement('span');
        bubble.appendChild(content);
        div.appendChild(bubble);
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
        typewriter(content, parseMd(text));
    }

    function showTyping() {
        var div = document.createElement('div');
        div.className = 'mb-2';
        div.id = 'advisorTyping';
        div.innerHTML = '<div class="typing-indicator"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
        messages.appendChild(div);
        messages.scrollTop = messages.scrollHeight;
    }

    function removeTyping() {
        var el = document.getElementById('advisorTyping');
        if (el) el.remove();
    }

    function sendAdvisor(msg) {
        var userMsg = msg || input.value.trim();
        if (!userMsg) return;
        ensureAdvisorOpen();
        input.value = '';

        if (!advisorFirstSent) {
            advisorFirstSent = true;
            chips.style.opacity = '0';
            setTimeout(function() { chips.style.display = 'none'; }, 200);
        }

        appendUser(userMsg);
        advisorHistory.push({role: 'user', content: userMsg});
        while (advisorHistory.length > 20) {
            advisorHistory.shift();
            advisorHistory.shift();
        }

        sendBtn.disabled = true;
        showTyping();

        var body = new URLSearchParams();
        body.append('message', userMsg);
        body.append('conversationHistory', JSON.stringify(advisorHistory));

        fetch(advisorUrl, {method: 'POST', body: body})
            .then(function(r) { return r.json(); })
            .then(function(data) {
                removeTyping();
                var resp = data.response || data.error || 'Pas de reponse.';
                appendAssistant(resp);
                advisorHistory.push({role: 'assistant', content: resp});
                sendBtn.disabled = false;
            })
            .catch(function() {
                removeTyping();
                appendAssistant('Erreur de connexion.');
                sendBtn.disabled = false;
            });
    }

    sendBtn.addEventListener('click', function() { sendAdvisor(); });
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendAdvisor();
        }
    });

    chips.querySelectorAll('.advisor-chip').forEach(function(chip) {
        chip.addEventListener('click', function() {
            ensureAdvisorOpen();
            seedAdvisorIntro();
            sendAdvisor(chip.getAttribute('data-prompt'));
        });
    });

    input.addEventListener('focus', function() {
        ensureAdvisorOpen();
        seedAdvisorIntro();
    });
})();

// ── Signature Canvas Modal ──
(function() {
    var overlay = document.getElementById('sigOverlay');
    var modal = document.getElementById('sigModal');
    var canvas = document.getElementById('sigCanvas');
    var ctx = canvas.getContext('2d');
    var colorPicker = document.getElementById('sigColor');
    var strokeSelect = document.getElementById('sigStroke');
    var clearBtn = document.getElementById('sigClear');
    var cancelBtn = document.getElementById('sigCancelBtn');
    var confirmBtn = document.getElementById('sigConfirmBtn');
    var sigError = document.getElementById('sigError');
    var signBtn = document.getElementById('contractSignBtn');
    var signForm = document.getElementById('signatureForm');
    var sigImageInput = document.getElementById('signatureImageInput');

    var isDrawing = false;
    var lastX = 0;
    var lastY = 0;
    var lastTime = 0;
    var hasDrawn = false;

    function drawBaseline() {
        ctx.save();
        ctx.setLineDash([4, 4]);
        ctx.strokeStyle = '#d1d5db';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(20, canvas.height * 0.75);
        ctx.lineTo(canvas.width - 20, canvas.height * 0.75);
        ctx.stroke();
        ctx.restore();
    }

    function clearCanvas() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        drawBaseline();
        hasDrawn = false;
        sigError.classList.remove('show');
    }

    function getPos(e) {
        var rect = canvas.getBoundingClientRect();
        var scaleX = canvas.width / rect.width;
        var scaleY = canvas.height / rect.height;
        if (e.touches && e.touches.length > 0) {
            return {
                x: (e.touches[0].clientX - rect.left) * scaleX,
                y: (e.touches[0].clientY - rect.top) * scaleY
            };
        }
        return {
            x: (e.clientX - rect.left) * scaleX,
            y: (e.clientY - rect.top) * scaleY
        };
    }

    function getBaseWidth() {
        return parseFloat(strokeSelect.value) || 2.5;
    }

    function startDraw(e) {
        e.preventDefault();
        isDrawing = true;
        var pos = getPos(e);
        lastX = pos.x;
        lastY = pos.y;
        lastTime = Date.now();
        ctx.beginPath();
        ctx.moveTo(lastX, lastY);
    }

    function draw(e) {
        if (!isDrawing) return;
        e.preventDefault();
        var pos = getPos(e);
        var now = Date.now();
        var dx = pos.x - lastX;
        var dy = pos.y - lastY;
        var dist = Math.sqrt(dx * dx + dy * dy);
        var dt = Math.max(now - lastTime, 1);
        var speed = dist / dt;

        // Pressure simulation: slower = thicker, faster = thinner
        var base = getBaseWidth();
        var width = base * Math.max(0.5, Math.min(1.5, 1.2 - speed * 0.15));

        ctx.lineWidth = width;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.strokeStyle = colorPicker.value;
        ctx.lineTo(pos.x, pos.y);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(pos.x, pos.y);

        lastX = pos.x;
        lastY = pos.y;
        lastTime = now;
        hasDrawn = true;
    }

    function endDraw(e) {
        if (e) e.preventDefault();
        isDrawing = false;
    }

    // Canvas events — mouse
    canvas.addEventListener('mousedown', startDraw);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', endDraw);
    canvas.addEventListener('mouseleave', endDraw);

    // Canvas events — touch
    canvas.addEventListener('touchstart', startDraw, { passive: false });
    canvas.addEventListener('touchmove', draw, { passive: false });
    canvas.addEventListener('touchend', endDraw);

    clearBtn.addEventListener('click', clearCanvas);

    function isCanvasBlank() {
        if (!hasDrawn) return true;
        var blank = document.createElement('canvas');
        blank.width = canvas.width;
        blank.height = canvas.height;
        var bCtx = blank.getContext('2d');
        // Draw the same baseline on blank for comparison
        bCtx.setLineDash([4, 4]);
        bCtx.strokeStyle = '#d1d5db';
        bCtx.lineWidth = 1;
        bCtx.beginPath();
        bCtx.moveTo(20, blank.height * 0.75);
        bCtx.lineTo(blank.width - 20, blank.height * 0.75);
        bCtx.stroke();
        return canvas.toDataURL() === blank.toDataURL();
    }

    function openModal() {
        clearCanvas();
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    if (signBtn) {
        signBtn.addEventListener('click', function() {
            if (signBtn.disabled) return;
            openModal();
        });
    }

    cancelBtn.addEventListener('click', closeModal);

    overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeModal();
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && overlay.classList.contains('active')) {
            closeModal();
        }
    });

    confirmBtn.addEventListener('click', function() {
        if (isCanvasBlank()) {
            sigError.classList.add('show');
            modal.classList.add('sig-shake');
            setTimeout(function() { modal.classList.remove('sig-shake'); }, 450);
            return;
        }
        sigError.classList.remove('show');
        var dataUrl = canvas.toDataURL('image/png');
        sigImageInput.value = dataUrl;
        closeModal();
        signForm.submit();
    });

    // Init baseline
    drawBaseline();
})();
</script>
{% endblock %}