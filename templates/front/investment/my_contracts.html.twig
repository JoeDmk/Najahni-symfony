{% extends 'front/layout.html.twig' %}

{% block title %}Mes contrats - Najahni{% endblock %}

{% block main %}
{% include 'front/investment/_wayfinder.html.twig' with {pageLabel: 'Mes contrats', activeStep: 3} %}

<style>
.contract-index-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1rem;
}

.contract-index-card {
    border: 0;
    border-radius: 1.1rem;
    overflow: hidden;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
}

.contract-index-band {
    height: 6px;
    width: 100%;
}

.contract-index-kpi {
    border: 0;
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    background: linear-gradient(135deg, rgba(59, 130, 246, .08), rgba(14, 165, 233, .12));
}

.contract-role-pill,
.contract-status-pill {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    border-radius: 999px;
    padding: .45rem .8rem;
    font-size: .78rem;
    font-weight: 700;
}

.contract-counterparty {
    color: #475569;
    font-size: .88rem;
}

.contract-empty {
    border: 1px dashed #cbd5e1;
    border-radius: 1.1rem;
    padding: 3rem 1.5rem;
    text-align: center;
    background: #f8fafc;
}
</style>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-file-earmark-text me-2"></i>Mes contrats</h2>
        <div class="text-muted">Retrouvez tous vos contrats d'investissement en cours, qu'ils soient cote investisseur ou cote entrepreneur.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="{{ path('app_invest_opportunities') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Opportunites</a>
        {% if is_granted('ROLE_INVESTISSEUR') %}
        <a href="{{ path('app_invest_my_offers') }}" class="btn btn-outline-primary"><i class="bi bi-list-check me-1"></i>Mes Offres</a>
        {% endif %}
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="contract-index-kpi h-100">
            <div class="small text-muted">Total</div>
            <div class="display-6 fw-bold">{{ summary.total }}</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="contract-index-kpi h-100">
            <div class="small text-muted">Ma signature attendue</div>
            <div class="display-6 fw-bold">{{ summary.awaitingMySignature }}</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="contract-index-kpi h-100">
            <div class="small text-muted">Cosignature attendue</div>
            <div class="display-6 fw-bold">{{ summary.awaitingOtherSignature }}</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="contract-index-kpi h-100">
            <div class="small text-muted">Complets ou finances</div>
            <div class="display-6 fw-bold">{{ summary.fullySigned + summary.funded }}</div>
        </div>
    </div>
</div>

{% if contracts|length > 0 %}
<div class="contract-index-grid">
    {% for contract in contracts %}
        {% set offer = contract.offer %}
        {% set isFunded = contract.status == constant('App\\Entity\\InvestmentContract::STATUS_FUNDED') %}
        {% set isInvestorParty = contract.investor and currentUser and contract.investor.id == currentUser.id %}
        {% set roleLabel = isInvestorParty ? 'Investisseur' : 'Entrepreneur' %}
        {% set roleBg = isInvestorParty ? '#dbeafe' : '#dcfce7' %}
        {% set roleColor = isInvestorParty ? '#1d4ed8' : '#15803d' %}
        {% set bandColor = isFunded ? '#16a34a' : (contract.fullySigned ? '#2563eb' : (contract.hasSigned(currentUser) ? '#f59e0b' : '#dc2626')) %}
        {% set statusLabel = isFunded ? 'Finance' : (contract.fullySigned ? 'Signe par les deux parties' : (contract.hasSigned(currentUser) ? 'En attente de cosignature' : 'Votre signature est requise')) %}
        {% set statusBg = isFunded ? '#dcfce7' : (contract.fullySigned ? '#dbeafe' : (contract.hasSigned(currentUser) ? '#fef3c7' : '#fee2e2')) %}
        {% set statusColor = isFunded ? '#166534' : (contract.fullySigned ? '#1d4ed8' : (contract.hasSigned(currentUser) ? '#92400e' : '#b91c1c')) %}
        {% set counterparty = isInvestorParty ? contract.entrepreneur : contract.investor %}
        <div class="contract-index-card">
            <div class="contract-index-band" style="background:{{ bandColor }}"></div>
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                    <div>
                        <div class="small text-muted mb-1">Projet</div>
                        <h5 class="fw-bold mb-1">{{ offer and offer.opportunity and offer.opportunity.project ? offer.opportunity.project.titre : contract.title }}</h5>
                        <div class="contract-counterparty">Avec {{ counterparty ? counterparty.fullName : 'partie introuvable' }}</div>
                    </div>
                    <span class="contract-role-pill" style="background:{{ roleBg }};color:{{ roleColor }};">{{ roleLabel }}</span>
                </div>

                <div class="mb-3 d-flex flex-wrap gap-2">
                    <span class="contract-status-pill" style="background:{{ statusBg }};color:{{ statusColor }};">{{ statusLabel }}</span>
                </div>

                <div class="row g-2 small mb-3">
                    <div class="col-6">
                        <div class="text-muted">Montant</div>
                        <div class="fw-semibold">{{ offer ? offer.proposedAmount|number_format(0, ',', ' ') ~ ' DT' : 'N/A' }}</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Participation</div>
                        <div class="fw-semibold">{{ contract.equityPercentage ? contract.equityPercentage|number_format(2, ',', ' ') ~ ' %' : 'A definir' }}</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Derniere activite</div>
                        <div class="fw-semibold">{{ (contract.lastMessageAt ?: contract.updatedAt)|date('d/m/Y H:i') }}</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted">Signatures</div>
                        <div class="fw-semibold">{{ contract.investorSignedAt ? 'Investisseur' : '...' }} / {{ contract.entrepreneurSignedAt ? 'Entrepreneur' : '...' }}</div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a href="{{ path('app_invest_contract_show', {id: offer.id}) }}" class="btn btn-outline-primary flex-fill">Ouvrir le contrat</a>
                    <a href="{{ path('app_invest_opportunity_show', {id: offer.opportunity.id}) }}" class="btn btn-outline-secondary flex-fill">Voir l'opportunite</a>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
{% else %}
<div class="contract-empty">
    <div class="mb-3"><i class="bi bi-file-earmark-text" style="font-size:3rem;color:#94a3b8"></i></div>
    <h4 class="fw-bold mb-2">Aucun contrat pour le moment</h4>
    <p class="text-muted mb-3">Les contrats acceptes apparaitront ici des qu'une negociation sera ouverte.</p>
    <a href="{{ path('app_invest_opportunities') }}" class="btn btn-nj">Explorer les opportunites</a>
</div>
{% endif %}
{% endblock %}