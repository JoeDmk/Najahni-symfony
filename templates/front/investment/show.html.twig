{% extends 'front/layout.html.twig' %}

{% block title %}{{ opportunity.project ? opportunity.project.titre : 'Opportunité' }} - Investissement{% endblock %}

{% block main %}
<a href="{{ path('app_invest_opportunities') }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Toutes les opportunités</a>

<div class="row g-4 mt-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h3 class="fw-bold mb-0">{{ opportunity.project ? opportunity.project.titre : 'Opportunité' }}</h3>
                <span class="badge bg-{{ opportunity.status == 'OPEN' ? 'success' : 'secondary' }} fs-6">{{ opportunity.status }}</span>
            </div>
            <p>{{ opportunity.description }}</p>

            <div class="p-3 rounded-3 mb-4" style="background:rgba(67,97,238,.05)">
                <div class="d-flex justify-content-between mb-2">
                    <span>Progression du financement</span>
                    <span class="fw-bold">{{ opportunity.fundingPercentage|number_format(1) }}%</span>
                </div>
                <div class="progress mb-2" style="height:12px">
                    <div class="progress-bar" style="width:{{ opportunity.fundingPercentage }}%;background:var(--nj-gradient)"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                    <span>{{ opportunity.totalFunded|number_format(0, ',', ' ') }} DT collectés</span>
                    <span>Objectif : {{ opportunity.targetAmount|number_format(0, ',', ' ') }} DT</span>
                </div>
            </div>

            {% if opportunity.deadline %}
            <p><i class="bi bi-calendar-event me-2"></i>Deadline : <strong>{{ opportunity.deadline|date('d/m/Y') }}</strong></p>
            {% endif %}
        </div>

        {# Offers list #}
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3">Offres ({{ offers|length }})</h5>
            {% if offers|length > 0 %}
            <div class="table-responsive">
                <table class="table table-nj">
                    <thead><tr><th>Investisseur</th><th>Montant</th><th>Statut</th><th>Payé</th></tr></thead>
                    <tbody>
                        {% for offer in offers %}
                        <tr>
                            <td>{{ offer.investor.firstname }} {{ offer.investor.lastname }}</td>
                            <td class="fw-semibold">{{ offer.proposedAmount|number_format(0, ',', ' ') }} DT</td>
                            <td><span class="badge bg-{{ offer.status == 'ACCEPTED' ? 'success' : (offer.status == 'REJECTED' ? 'danger' : 'warning text-dark') }}">{{ offer.status }}</span></td>
                            <td>{{ offer.paid ? '✅' : '❌' }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <p class="text-muted">Aucune offre pour le moment.</p>
            {% endif %}
        </div>
    </div>

    <div class="col-md-4">
        {# Make offer #}
        {% if opportunity.status == 'OPEN' %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-cash-coin me-2"></i>Investir</h5>
            <form method="post" action="{{ path('app_invest_offer', {id: opportunity.id}) }}">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Montant (DT)</label>
                    <input type="number" step="0.01" min="1" name="amount" class="form-control form-control-lg" placeholder="Ex: 5000" required>
                </div>
                <button type="submit" class="btn btn-nj w-100 btn-lg"><i class="bi bi-send me-2"></i>Soumettre l'offre</button>
            </form>
        </div>
        {% endif %}

        {# Risk info #}
        {% if opportunity.riskScore %}
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h6 class="fw-bold mb-3"><i class="bi bi-shield-exclamation me-2"></i>Analyse de risque</h6>
            <div class="text-center mb-2">
                <div class="display-5 fw-bold" style="color:var(--nj-accent)">{{ opportunity.riskScore|number_format(1) }}</div>
                <span class="badge bg-{{ opportunity.riskScore < 30 ? 'success' : (opportunity.riskScore < 60 ? 'warning text-dark' : 'danger') }}">
                    {{ opportunity.riskLabel ?? 'N/A' }}
                </span>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
