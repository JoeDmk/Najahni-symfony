{% extends 'front/layout.html.twig' %}

{% block title %}{{ opportunity.project ? opportunity.project.titre : 'Opportunité' }} - Investissement{% endblock %}

{% block main %}
{% include 'front/investment/_wayfinder.html.twig' with {pageLabel: 'Detail opportunite', activeStep: 1} %}
<div class="d-flex justify-content-between align-items-center">
    <a href="{{ path('app_invest_opportunities') }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Toutes les opportunités</a>
    <a href="{{ path('app_invest_risk_analysis', {id: opportunity.id}) }}" class="btn btn-sm btn-outline-warning"><i class="bi bi-shield-exclamation me-1"></i>Analyse de risque IA</a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show mt-3">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show mt-3">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="row g-4 mt-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h3 class="fw-bold mb-0">{{ opportunity.project ? opportunity.project.titre : 'Opportunité' }}</h3>
                <span class="badge bg-{{ opportunity.status == 'OPEN' ? 'success' : 'secondary' }} fs-6">{{ opportunity.status }}</span>
            </div>
            <p>{{ opportunity.description }}</p>

            <div class="p-3 rounded-3 mb-4" style="background:rgba(67,97,238,.05)">
                <div class="d-flex justify-content-between mb-2">
                    <span>Progression du financement</span>
                    <span class="fw-bold">{{ opportunity.fundingPercentage|number_format(1) }}%</span>
                </div>
                <div class="progress mb-2" style="height:12px">
                    <div class="progress-bar" style="width:{{ opportunity.fundingPercentage }}%;background:var(--nj-gradient)"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                    <span>{{ opportunity.totalFunded|number_format(0, ',', ' ') }} DT collectés</span>
                    <span>Objectif : {{ opportunity.targetAmount|number_format(0, ',', ' ') }} DT</span>
                </div>
            </div>

            {% if opportunity.deadline %}
            <p><i class="bi bi-calendar-event me-2"></i>Deadline : <strong>{{ opportunity.deadline|date('d/m/Y') }}</strong>
                {% set days_left = (opportunity.deadline|date('U') - 'now'|date('U')) / 86400 %}
                {% if days_left > 0 and days_left < 30 %}
                    <span class="badge bg-warning text-dark ms-2">{{ days_left|round(0, 'floor') }} jours restants</span>
                {% elseif days_left <= 0 %}
                    <span class="badge bg-danger ms-2">Expiré</span>
                {% endif %}
            </p>
            {% endif %}

            {% if opportunity.project %}
            <div class="mt-3 p-3 rounded-3 bg-light">
                <h6 class="fw-semibold mb-1"><i class="bi bi-briefcase me-1"></i>Projet : {{ opportunity.project.titre }}</h6>
                {% if opportunity.project.description is defined and opportunity.project.description %}
                    <p class="text-muted small mb-0">{{ opportunity.project.description|slice(0, 200) }}</p>
                {% endif %}
            </div>
            {% endif %}
        </div>

        {# Offers list #}
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3">Offres ({{ offers|length }})</h5>
            {% if offers|length > 0 %}
            <div class="table-responsive">
                <table class="table table-nj">
                    <thead><tr><th>Investisseur</th><th>Montant</th><th>Statut</th><th>Date</th>{% if canManageOffers %}<th class="text-end">Actions</th>{% endif %}</tr></thead>
                    <tbody>
                        {% for offer in offers %}
                        <tr>
                            <td><a href="{{ path('app_user_profile', {id: offer.investor.id}) }}" class="text-decoration-none">{{ offer.investor.firstname }} {{ offer.investor.lastname }}</a></td>
                            <td class="fw-semibold">{{ offer.proposedAmount|number_format(0, ',', ' ') }} DT</td>
                            <td>
                                <span class="badge bg-{{ offer.status == 'ACCEPTED' ? 'success' : (offer.status == 'REJECTED' ? 'danger' : 'warning text-dark') }}">{{ offer.status }}</span>
                                {% if offer.status == 'ACCEPTED' and offer.paid %}
                                    <div class="small text-success fw-semibold mt-1">Paiement confirme</div>
                                {% elseif offer.status == 'ACCEPTED' %}
                                    {% if offer.contract and offer.contract.fullySigned %}
                                        <div class="small text-success fw-semibold mt-1">Contrat signe -- paiement disponible</div>
                                    {% else %}
                                        <div class="small text-warning mt-1">
                                            <a href="{{ path('app_invest_contract_show', {id: offer.id}) }}" class="text-warning text-decoration-underline">Negociation en cours -- signature requise avant paiement</a>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </td>
                            <td class="text-muted small">{{ offer.createdAt|date('d/m/Y H:i') }}</td>
                            {% if canManageOffers %}
                            <td class="text-end">
                                {% if offer.status == 'PENDING' %}
                                <form method="post" action="{{ path('app_invest_offer_accept_front', {id: offer.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('offer_action_' ~ offer.id) }}">
                                    <input type="hidden" name="_redirect_route" value="app_invest_entrepreneur_inbox">
                                    <button class="btn btn-sm btn-outline-success" title="Accepter l'offre"><i class="bi bi-check-lg"></i></button>
                                </form>
                                <form method="post" action="{{ path('app_invest_offer_reject_front', {id: offer.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('offer_action_' ~ offer.id) }}">
                                    <input type="hidden" name="_redirect_route" value="app_invest_entrepreneur_inbox">
                                    <button class="btn btn-sm btn-outline-danger" title="Refuser l'offre"><i class="bi bi-x-lg"></i></button>
                                </form>
                                {% elseif offer.status == 'ACCEPTED' and not offer.paid %}
                                    <a href="{{ path('app_invest_contract_show', {id: offer.id}) }}" class="btn btn-sm btn-outline-primary">Contrat</a>
                                {% elseif offer.status == 'ACCEPTED' and offer.paid %}
                                    <a href="{{ path('app_invest_contract_show', {id: offer.id}) }}" class="btn btn-sm btn-outline-success">Contrat signe</a>
                                {% else %}
                                    <span class="small text-muted">Aucune action</span>
                                {% endif %}
                            </td>
                            {% endif %}
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <p class="text-muted">Aucune offre pour le moment.</p>
            {% endif %}
        </div>
    </div>

    <div class="col-md-4">
        {# Make offer — Investor only #}
        {% if opportunity.status == 'OPEN' and is_granted('ROLE_INVESTISSEUR') %}
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3"><i class="bi bi-cash-coin me-2"></i>Investir</h5>
            {% if myOffer %}
                <div class="alert alert-info mb-0">
                    <i class="bi bi-info-circle me-1"></i>Vous avez déjà soumis une offre de <strong>{{ myOffer.proposedAmount|number_format(0, ',', ' ') }} DT</strong>
                    <br><span class="badge bg-{{ myOffer.status == 'ACCEPTED' ? 'success' : (myOffer.status == 'REJECTED' ? 'danger' : 'warning text-dark') }} mt-1">{{ myOffer.status }}</span>
                    {% if myOffer.status == 'ACCEPTED' and not myOffer.paid %}
                        <div class="mt-3">
                            <a href="{{ path('app_invest_contract_show', {id: myOffer.id}) }}" class="btn btn-sm btn-outline-primary">Negocier le contrat</a>
                            {% if myOffer.contract and myOffer.contract.fullySigned %}
                                <a href="{{ path('app_invest_my_offers') }}" class="btn btn-sm btn-nj">Finaliser le paiement</a>
                            {% endif %}
                        </div>
                        <div class="mt-2 small {{ myOffer.contract and myOffer.contract.fullySigned ? 'text-success fw-semibold' : 'text-warning' }}">
                            {% if myOffer.contract and myOffer.contract.fullySigned %}
                                Le contrat est signe numeriquement par les deux parties.
                            {% elseif myOffer.contract %}
                                Negociation en cours -- <a href="{{ path('app_invest_contract_show', {id: myOffer.id}) }}" class="text-warning text-decoration-underline">signature requise avant paiement</a>.
                            {% else %}
                                Le paiement sera active apres signature SHA-256 du contrat par l'investisseur et l'entrepreneur.
                            {% endif %}
                        </div>
                    {% elseif myOffer.paid %}
                        <div class="mt-2 small text-success fw-semibold">Paiement confirme{% if myOffer.paymentIntentId %} · {{ myOffer.paymentIntentId }}{% endif %}</div>
                        <div class="mt-3">
                            <a href="{{ path('app_invest_contract_show', {id: myOffer.id}) }}" class="btn btn-sm btn-outline-primary">Voir le contrat</a>
                            <a href="{{ path('app_invest_portfolio') }}" class="btn btn-sm btn-outline-success">Voir dans le portfolio</a>
                        </div>
                    {% endif %}
                </div>
            {% else %}
                {% set remaining = (opportunity.targetAmount|number_format(2, '.', '') - opportunity.totalFunded)|round(2) %}
                <form method="post" action="{{ path('app_invest_offer', {id: opportunity.id}) }}" id="offerForm" novalidate>
                    <input type="hidden" name="_token" value="{{ csrf_token('invest_offer_' ~ opportunity.id) }}">
                    <input type="hidden" name="risk_acknowledged" id="riskAcknowledgedField" value="0">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Montant (DT)</label>
                        <input type="number" step="0.01" min="1" {% if remaining > 0 %}max="{{ remaining }}"{% endif %} name="amount" class="form-control form-control-lg" placeholder="Ex: 5000" required id="offerAmount">
                        <div class="form-text">Montant restant à financer : <strong>{{ remaining|number_format(0, ',', ' ') }} DT</strong></div>
                        <div class="invalid-feedback" id="offerAmountError"></div>
                    </div>
                    <button type="submit" class="btn btn-nj w-100 btn-lg"><i class="bi bi-send me-2"></i>Soumettre l'offre</button>
                </form>

            {% endif %}
        </div>
        {% endif %}

        {# Risk info #}
        {% if opportunity.riskScore %}
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h6 class="fw-bold mb-3"><i class="bi bi-shield-exclamation me-2"></i>Analyse de risque</h6>
            <div class="text-center mb-2">
                <div class="display-5 fw-bold" style="color:var(--nj-accent)">{{ opportunity.riskScore|number_format(1) }}</div>
                <span class="badge bg-{{ opportunity.riskScore < 30 ? 'success' : (opportunity.riskScore < 60 ? 'warning text-dark' : 'danger') }}">
                    {{ opportunity.riskLabel ?? 'N/A' }}
                </span>
            </div>
        </div>
        {% endif %}
    </div>
</div>

{% if opportunity.status == 'OPEN' and is_granted('ROLE_INVESTISSEUR') and not myOffer %}
        {# Keep the risk modal at page level so Bootstrap renders it outside the hoverable card. #}
        <div class="modal fade" id="riskGateModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow" style="border-radius:1rem;overflow:hidden">
                    <div class="modal-header border-0 {{ riskLevel == 'high' ? 'bg-danger text-white' : 'bg-warning' }}" id="riskModalHeader" style="padding:1.2rem 1.5rem">
                        <h5 class="modal-title fw-bold mb-0">
                            <i class="bi bi-shield-exclamation me-2"></i>
                            {{ riskLevel == 'high' ? 'Risque eleve detecte' : 'Risque modere detecte' }}
                        </h5>
                        <button type="button" class="btn-close {{ riskLevel == 'high' ? 'btn-close-white' : '' }}" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body" style="padding:1.5rem">
                        <p class="mb-3" id="riskModalMessage">
                            {{ riskLevel == 'high'
                                ? 'Ce projet presente un niveau de risque eleve selon les conditions economiques actuelles. Prenez le temps de consulter l\'analyse complete avant de vous engager.'
                                : 'Ce projet porte un risque modere selon les conditions economiques actuelles.'
                            }}
                        </p>
                        {% if riskFactors|length > 0 %}
                        <div class="mb-3">
                            <div class="small fw-semibold text-muted mb-2">Facteurs de risque :</div>
                            <ul class="mb-0 ps-3">
                                {% for factor in riskFactors %}
                                    <li class="mb-1">{{ factor }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                        {% endif %}
                        <div class="small text-muted">Score de risque : {{ riskScore }}/100</div>
                    </div>
                    <div class="modal-footer border-0 d-flex gap-2" style="padding:1rem 1.5rem">
                        <a href="{{ path('app_invest_risk_analysis', {id: opportunity.id}) }}" class="btn btn-outline-primary flex-fill">Consulter l'analyse complete</a>
                        <button type="button" class="btn {{ riskLevel == 'high' ? 'btn-danger' : 'btn-warning' }} flex-fill" id="riskProceedBtn">Poursuivre malgre tout</button>
                    </div>
                </div>
            </div>
        </div>

        <script>
        (function() {
                var form = document.getElementById('offerForm');
                var amount = document.getElementById('offerAmount');
                var errEl = document.getElementById('offerAmountError');
                var riskAcknowledgedField = document.getElementById('riskAcknowledgedField');
                var proceedBtn = document.getElementById('riskProceedBtn');
                var modalElement = document.getElementById('riskGateModal');
                var riskLevel = '{{ riskLevel }}';
                var riskAccepted = false;
                var riskGateModal;

                if (!form || !amount || !riskAcknowledgedField || !proceedBtn || !modalElement) {
                        return;
                }

                riskGateModal = bootstrap.Modal.getOrCreateInstance(modalElement);

                if (new URLSearchParams(window.location.search).get('risk_reviewed') === '1') {
                        riskAccepted = true;
                        riskAcknowledgedField.value = '1';
                }

                form.addEventListener('submit', function(e) {
                        var val = parseFloat(amount.value);
                        var max = parseFloat(amount.getAttribute('max')) || Infinity;

                        amount.classList.remove('is-invalid');

                        if (isNaN(val) || val <= 0) {
                                e.preventDefault();
                                amount.classList.add('is-invalid');
                                errEl.textContent = 'Le montant doit etre un nombre positif.';
                                return;
                        }

                        if (val > max) {
                                e.preventDefault();
                                amount.classList.add('is-invalid');
                                errEl.textContent = 'Le montant ne peut pas depasser ' + max.toLocaleString('fr') + ' DT.';
                                return;
                        }

                        if ({{ riskScore }} > 60 && !riskAccepted) {
                                e.preventDefault();
                                riskGateModal.show();
                        }
                });

                proceedBtn.addEventListener('click', function() {
                        riskAccepted = true;
                        riskAcknowledgedField.value = '1';
                        riskGateModal.hide();
                        form.requestSubmit();
                });
        })();
        </script>
{% endif %}
{% endblock %}
