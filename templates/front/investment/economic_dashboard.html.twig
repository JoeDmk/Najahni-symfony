{% extends 'front/layout.html.twig' %}

{% block title %}Intelligence investissement - Najahni{% endblock %}

{% block main %}
{% include 'front/investment/_wayfinder.html.twig' with {pageLabel: 'Intelligence economique', activeStep: 1} %}
<style>
.eco-dash-hero {
    background: linear-gradient(-45deg, #0f172a, #1e3a5f, #0d9488, #1e293b);
    background-size: 400% 400%;
    animation: gradientShift 8s ease infinite;
    border-radius: 1rem;
    padding: 2rem 2.5rem;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
}
@keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}
.eco-dash-hero h2, .eco-dash-hero a { position: relative; z-index: 1; }
.eco-dash-vignette {
    position: relative;
}
.eco-dash-vignette::before {
    content: '';
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse at center, transparent 55%, rgba(15,23,42,.06) 100%);
    pointer-events: none;
    border-radius: 1.5rem;
    z-index: 0;
}
.eco-dash-vignette > * { position: relative; z-index: 1; }
</style>

<div class="eco-dash-hero">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="fw-bold mb-0 text-white"><i class="bi bi-globe me-2"></i>Intelligence investissement</h2>
        <a href="{{ path('app_invest_opportunities') }}" class="btn btn-outline-light"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

{# ── Impact on Active Opportunities ── #}
<div class="card border-0 shadow-sm mb-4" style="border-radius:1rem;border-left:4px solid #0f172a">
    <div class="card-body py-4 px-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-bullseye me-2"></i>Impact sur les opportunites actives</h5>

        {# Risk breakdown #}
        {% if riskCounts is defined and riskCounts.total > 0 %}
        <div class="d-flex align-items-center gap-2 mb-3">
            <span class="fw-semibold" style="font-size:1.05rem">{{ riskCounts.total }} opportunite{{ riskCounts.total > 1 ? 's' : '' }} active{{ riskCounts.total > 1 ? 's' : '' }}</span>
            <span class="mx-1 text-muted">|</span>
            {% if riskCounts.low > 0 %}
            <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#dcfce7;color:#15803d;font-size:.82rem;font-weight:600">
                <i class="bi bi-shield-check"></i>{{ riskCounts.low }} faible
            </span>
            {% endif %}
            {% if riskCounts.medium > 0 %}
            <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#fef3c7;color:#92400e;font-size:.82rem;font-weight:600">
                <i class="bi bi-exclamation-triangle"></i>{{ riskCounts.medium }} modere
            </span>
            {% endif %}
            {% if riskCounts.high > 0 %}
            <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#fee2e2;color:#991b1b;font-size:.82rem;font-weight:600">
                <i class="bi bi-shield-exclamation"></i>{{ riskCounts.high }} eleve
            </span>
            {% endif %}
        </div>
        {% endif %}

        {# Sector breakdown as horizontal bar #}
        {% if sectorCounts is defined and sectorCounts|length > 0 %}
        <div class="mb-3">
            <div class="small fw-semibold text-muted mb-2">Exposition par secteur</div>
            {% set sectorColors = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899', '#06b6d4', '#84cc16'] %}
            {% set maxSector = sectorCounts|first %}
            {% for sector, count in sectorCounts %}
            <div class="d-flex align-items-center gap-2 mb-1">
                <div class="text-truncate" style="width:140px;font-size:.82rem">{{ sector }}</div>
                <div class="flex-fill" style="height:18px;background:#f1f5f9;border-radius:4px;overflow:hidden">
                    <div style="width:{{ maxSector > 0 ? (count / maxSector * 100) : 0 }}%;height:100%;background:{{ sectorColors[loop.index0 % 8] }};border-radius:4px;transition:width .3s"></div>
                </div>
                <div class="small fw-semibold" style="min-width:28px;text-align:right">{{ count }}</div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# Climate verdict #}
        {% if climateVerdict is defined and climateVerdict %}
        <div class="p-3 rounded-3 mt-3" style="background:linear-gradient(135deg,#f8fafc,#eff6ff);border:1px solid #dbeafe">
            <div class="small fw-semibold text-muted mb-1"><i class="bi bi-cloud-sun me-1"></i>Climat d'investissement du jour</div>
            <div style="font-size:.92rem;line-height:1.55">{{ climateVerdict }}</div>
        </div>
        {% endif %}
    </div>
</div>

{# Mission control: current conditions affecting opportunities #}
{% if riskCounts is defined and riskCounts.total > 0 %}
<div class="card border-0 shadow-sm mb-4" style="border-radius:1rem;border-left:4px solid #3b82f6">
    <div class="card-body py-3 px-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-activity fs-5 text-primary"></i>
            <span class="fw-bold" style="font-size:1.05rem">Les conditions actuelles affectent {{ riskCounts.total }} opportunite{{ riskCounts.total > 1 ? 's' : '' }} sur la plateforme</span>
        </div>
        <div class="d-flex gap-3 flex-wrap">
            {% if riskCounts.low > 0 %}
            <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#dcfce7;color:#15803d;font-size:.82rem;font-weight:600">
                <i class="bi bi-shield-check"></i>{{ riskCounts.low }} risque faible
            </span>
            {% endif %}
            {% if riskCounts.medium > 0 %}
            <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#fef3c7;color:#92400e;font-size:.82rem;font-weight:600">
                <i class="bi bi-exclamation-triangle"></i>{{ riskCounts.medium }} risque modere
            </span>
            {% endif %}
            {% if riskCounts.high > 0 %}
            <span class="d-inline-flex align-items-center gap-1 px-3 py-1 rounded-pill" style="background:#fee2e2;color:#991b1b;font-size:.82rem;font-weight:600">
                <i class="bi bi-shield-exclamation"></i>{{ riskCounts.high }} risque eleve
            </span>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

{# Country selector + Currency converter #}
<div class="eco-dash-vignette">
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Donnees economiques par pays</h6>
                <select id="countrySelect" class="form-select mb-3">
                    <option value="TN" selected>Tunisie</option>
                    <option value="FR">France</option>
                    <option value="US">Etats-Unis</option>
                    <option value="DE">Allemagne</option>
                    <option value="GB">Royaume-Uni</option>
                    <option value="MA">Maroc</option>
                </select>
                <div id="ecoSpinner" class="text-center py-3">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="small text-muted mt-2">Chargement des donnees...</p>
                </div>
                <div id="ecoCards" class="d-none">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="stat-card p-3">
                                <div class="small text-muted">EUR/USD</div>
                                <div class="fw-bold fs-5" id="eurUsd">--</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-card p-3">
                                <div class="small text-muted">EUR/TND</div>
                                <div class="fw-bold fs-5" id="eurTnd">--</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-card p-3">
                                <div class="small text-muted">PIB</div>
                                <div class="fw-bold fs-5" id="gdpVal">--</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat-card p-3">
                                <div class="small text-muted">Inflation</div>
                                <div class="fw-bold fs-5" id="inflVal">--</div>
                            </div>
                        </div>
                    </div>

                    {# Investment context annotations #}
                    <div class="mt-3 d-flex flex-column gap-2">
                        {% if inflationSensitive is defined and inflationSensitive > 0 %}
                        <div class="d-flex align-items-start gap-2 p-2 rounded" style="background:#fefce8;border:1px solid #fef08a">
                            <i class="bi bi-graph-up-arrow text-warning mt-1" style="font-size:.85rem"></i>
                            <span style="font-size:.82rem;line-height:1.4;color:#854d0e">
                                <strong>{{ inflationSensitive }}</strong> opportunite{{ inflationSensitive > 1 ? 's' : '' }} active{{ inflationSensitive > 1 ? 's' : '' }} dans des secteurs sensibles a l'inflation (import-dependent)
                            </span>
                        </div>
                        {% endif %}
                        {% if shortDeadlineCount is defined and shortDeadlineCount > 0 %}
                        <div class="d-flex align-items-start gap-2 p-2 rounded" style="background:#eff6ff;border:1px solid #bfdbfe">
                            <i class="bi bi-currency-exchange text-primary mt-1" style="font-size:.85rem"></i>
                            <span style="font-size:.82rem;line-height:1.4;color:#1e40af">
                                <strong>{{ shortDeadlineCount }}</strong> opportunite{{ shortDeadlineCount > 1 ? 's' : '' }} avec echeance proche impliquent des considerations de financement transfrontalier
                            </span>
                        </div>
                        {% endif %}
                    </div>

                    <div class="mt-3 p-3 rounded" id="riskFactorBox" style="background:#f8f9fa">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="small text-muted">Facteur de risque economique</div>
                                <div class="fw-bold fs-4" id="riskFactorVal">--</div>
                            </div>
                            <div>
                                <span class="badge fs-6" id="riskLevelBadge">--</span>
                            </div>
                        </div>
                        <div class="progress mt-2" style="height:8px;border-radius:4px">
                            <div class="progress-bar" id="riskBar" style="width:0%"></div>
                        </div>
                        <p class="small mt-2 mb-0" id="riskRecommendation">--</p>
                    </div>
                    <p class="small text-muted mt-2 mb-0" id="ecoTimestamp"></p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Convertisseur de devises</h6>
                <div class="row g-2 mb-3">
                    <div class="col-5">
                        <label class="form-label small">Montant</label>
                        <input type="number" id="convAmount" class="form-control" value="1000" min="0" step="0.01">
                    </div>
                    <div class="col-3">
                        <label class="form-label small">De</label>
                        <select id="convFrom" class="form-select">
                            <option value="EUR" selected>EUR</option>
                            <option value="USD">USD</option>
                            <option value="TND">TND</option>
                            <option value="GBP">GBP</option>
                            <option value="MAD">MAD</option>
                        </select>
                    </div>
                    <div class="col-1 d-flex align-items-end justify-content-center pb-2">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                    <div class="col-3">
                        <label class="form-label small">Vers</label>
                        <select id="convTo" class="form-select">
                            <option value="EUR">EUR</option>
                            <option value="USD">USD</option>
                            <option value="TND" selected>TND</option>
                            <option value="GBP">GBP</option>
                            <option value="MAD">MAD</option>
                        </select>
                    </div>
                </div>
                <button type="button" id="convertBtn" class="btn btn-nj w-100 mb-3">Convertir</button>
                <div id="convResult" class="p-3 rounded text-center d-none" style="background:#f8f9fa">
                    <div class="small text-muted">Resultat</div>
                    <div class="fw-bold fs-4" id="convValue">--</div>
                    <div class="small text-muted" id="convRate">--</div>
                </div>

                <hr class="my-3">
                <h6 class="fw-semibold mb-2">Taux en temps reel (base EUR)</h6>
                <div id="ratesTable">
                    <div class="text-center py-2"><div class="spinner-border spinner-border-sm text-primary"></div></div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>{# /.eco-dash-vignette #}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const countrySelect = document.getElementById('countrySelect');

    function loadEconomicData() {
        const country = countrySelect.value;
        document.getElementById('ecoSpinner').classList.remove('d-none');
        document.getElementById('ecoCards').classList.add('d-none');

        fetch('{{ path("app_invest_economic_data") }}?country=' + encodeURIComponent(country))
            .then(r => r.json())
            .then(data => {
                document.getElementById('eurUsd').textContent = (data.exchangeRateEurUsd || 0).toFixed(4);
                document.getElementById('eurTnd').textContent = (data.exchangeRateEurTnd || 0).toFixed(3);
                document.getElementById('gdpVal').textContent = (data.gdpBillions || 0).toFixed(1) + ' Mrd $';
                document.getElementById('inflVal').textContent = (data.inflationRate || 0).toFixed(1) + '%';

                const factor = data.economicRiskFactor || 50;
                document.getElementById('riskFactorVal').textContent = factor + ' / 100';
                const badge = document.getElementById('riskLevelBadge');
                badge.textContent = data.riskLevel || '--';
                badge.style.background = data.riskColor || '#999';
                badge.style.color = '#fff';

                const bar = document.getElementById('riskBar');
                bar.style.width = factor + '%';
                bar.style.background = data.riskColor || '#999';

                document.getElementById('riskRecommendation').textContent = data.recommendation || '';
                document.getElementById('ecoTimestamp').textContent = 'Pays: ' + (data.countryName || country) + ' | Annee donnees: ' + (data.dataYear || 'N/A');

                document.getElementById('ecoSpinner').classList.add('d-none');
                document.getElementById('ecoCards').classList.remove('d-none');
            })
            .catch(() => {
                document.getElementById('ecoSpinner').innerHTML = '<p class="text-danger">Erreur de chargement.</p>';
            });
    }

    countrySelect.addEventListener('change', loadEconomicData);
    loadEconomicData();

    // Currency converter
    document.getElementById('convertBtn').addEventListener('click', function() {
        const amount = document.getElementById('convAmount').value;
        const from = document.getElementById('convFrom').value;
        const to = document.getElementById('convTo').value;

        fetch('{{ path("app_invest_currency_convert") }}?amount=' + amount + '&from=' + from + '&to=' + to)
            .then(r => r.json())
            .then(data => {
                document.getElementById('convValue').textContent = data.formatted;
                document.getElementById('convRate').textContent = '1 ' + from + ' = ' + data.rate + ' ' + to;
                document.getElementById('convResult').classList.remove('d-none');

                // Update rates table
                if (data.rates) {
                    let html = '<table class="table table-sm mb-0">';
                    for (const [cur, rate] of Object.entries(data.rates)) {
                        html += '<tr><td class="fw-semibold">' + cur + '</td><td>' + Number(rate).toFixed(4) + '</td></tr>';
                    }
                    html += '</table>';
                    document.getElementById('ratesTable').innerHTML = html;
                }
            })
            .catch(() => {
                document.getElementById('convValue').textContent = 'Erreur';
            });
    });

    // Auto-load rates on page load
    fetch('{{ path("app_invest_currency_convert") }}?amount=1&from=EUR&to=TND')
        .then(r => r.json())
        .then(data => {
            if (data.rates) {
                let html = '<table class="table table-sm mb-0">';
                for (const [cur, rate] of Object.entries(data.rates)) {
                    html += '<tr><td class="fw-semibold">' + cur + '</td><td>' + Number(rate).toFixed(4) + '</td></tr>';
                }
                html += '</table>';
                document.getElementById('ratesTable').innerHTML = html;
            }
        });
});
</script>
{% endblock %}
