{% extends 'front/layout.html.twig' %}

{% block title %}Créer une opportunité - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2"></i>Créer une opportunité</h2>
    <a href="{{ path('app_invest_opportunities') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-4">
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Projet</label>
                <select name="project_id" class="form-select" required>
                    <option value="">Sélectionnez un projet</option>
                    {% for p in projets %}
                        <option value="{{ p.id }}">{{ p.titre }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Montant cible (DT)</label>
                    <input type="number" step="0.01" min="1" name="target_amount" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Deadline</label>
                    <input type="date" name="deadline" class="form-control" required>
                </div>
            </div>
            <div class="mb-3 mt-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="description" class="form-control" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn-nj btn-lg"><i class="bi bi-check-lg me-2"></i>Créer l'opportunité</button>
        </form>
    </div>
</div>
{% endblock %}
