<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Impression du contrat</title>
    <style>
        body { font-family: Helvetica, Arial, sans-serif; margin: 24px; color: #111827; }
        .header { margin-bottom: 20px; }
        .title { font-size: 28px; font-weight: 700; margin-bottom: 4px; }
        .subtitle { color: #475569; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
        .card { border: 1px solid #d1d5db; border-radius: 10px; padding: 14px; }
        .section { margin-top: 22px; }
        .section h2 { font-size: 18px; margin-bottom: 8px; }
        .terms { white-space: pre-wrap; line-height: 1.6; border: 1px solid #d1d5db; border-radius: 10px; padding: 14px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        td, th { border: 1px solid #d1d5db; padding: 8px 10px; text-align: left; vertical-align: top; }
        .actions { margin-bottom: 18px; }
        @media print {
            .actions { display: none; }
            body { margin: 0; }
        }
    </style>
</head>
<body>
    <div class="actions">
        <button onclick="window.print()">Imprimer</button>
        <button onclick="window.close()">Fermer</button>
    </div>

    <div class="header">
        <div class="title">Contrat d'investissement signe</div>
        <div class="subtitle">Projet {{ offer.opportunity.project ? offer.opportunity.project.titre : 'Projet' }} · genere le {{ generatedAt|date('d/m/Y H:i') }}</div>
    </div>

    <div class="grid">
        <div class="card"><strong>Investisseur</strong><br>{{ contract.investor.fullName }}<br>{{ contract.investor.email }}</div>
        <div class="card"><strong>Entrepreneur</strong><br>{{ contract.entrepreneur.fullName }}<br>{{ contract.entrepreneur.email }}</div>
        <div class="card"><strong>Montant</strong><br>{{ offer.proposedAmount|number_format(2, ',', ' ') }} DT</div>
        <div class="card"><strong>Participation</strong><br>{{ contract.equityPercentage ? contract.equityPercentage|number_format(2, ',', ' ') ~ ' %' : 'A definir' }}</div>
    </div>

    <div class="section">
        <h2>Contreparties et obligations</h2>
        <div class="terms"><strong>Contreparties</strong>
{{ contract.consideration ?: 'Non precisees' }}

<strong>Etapes et obligations</strong>
{{ contract.milestones ?: 'Non precisees' }}</div>
    </div>

    <div class="section">
        <h2>Termes complets</h2>
        <div class="terms">{{ contract.terms }}</div>
    </div>

    <div class="section">
        <h2>Signatures</h2>
        <hr style="border:none;border-top:1px solid #d1d5db;margin-bottom:14px">
        <table>
            <tr>
                <th style="width:50%">Investisseur</th>
                <th style="width:50%">Entrepreneur</th>
            </tr>
            <tr>
                <td>
                    {% if contract.investorSignatureImage %}
                        <img src="{{ contract.investorSignatureImage }}" style="max-width:180px;max-height:70px;display:block;margin-bottom:4px">
                    {% endif %}
                    <div style="font-weight:bold;margin-bottom:2px">{{ contract.investorSignatureName ?: contract.investor.fullName }}</div>
                    <div style="font-size:11px;color:#475569">{{ contract.investorSignedAt ? contract.investorSignedAt|date('d/m/Y H:i') : 'N/A' }}</div>
                    <div style="font-family:Courier,monospace;font-size:9px;color:#94a3b8;margin-top:3px">{{ contract.investorSignatureHash ?: 'N/A' }}</div>
                </td>
                <td>
                    {% if contract.entrepreneurSignatureImage %}
                        <img src="{{ contract.entrepreneurSignatureImage }}" style="max-width:180px;max-height:70px;display:block;margin-bottom:4px">
                    {% endif %}
                    <div style="font-weight:bold;margin-bottom:2px">{{ contract.entrepreneurSignatureName ?: contract.entrepreneur.fullName }}</div>
                    <div style="font-size:11px;color:#475569">{{ contract.entrepreneurSignedAt ? contract.entrepreneurSignedAt|date('d/m/Y H:i') : 'N/A' }}</div>
                    <div style="font-family:Courier,monospace;font-size:9px;color:#94a3b8;margin-top:3px">{{ contract.entrepreneurSignatureHash ?: 'N/A' }}</div>
                </td>
            </tr>
        </table>
    </div>

    <div class="section">
        <h2>Empreinte du contrat</h2>
        <div class="terms">{{ contract.termsDigest }}</div>
    </div>

    <script>
    window.addEventListener('load', function() {
        window.print();
    });
    </script>
</body>
</html>