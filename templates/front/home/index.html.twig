                <div class="nj-impact-sub">finances avec succes sur la plateforme</div>
            </div>
            <div class="nj-impact-item">
                <span class="nj-impact-num" data-count="{{ platformStats.totalSessions }}">0</span>
                <div class="nj-impact-label">Sessions</div>
                <div class="nj-impact-sub">de mentorat realisees</div>
