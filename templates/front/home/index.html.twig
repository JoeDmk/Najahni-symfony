{% block javascripts %}
<script>
(function() {
    'use strict';

    /* ═══════════════════════════════════════════
       FEATURE 1 — Hero counter + pill cycling
       ═══════════════════════════════════════════ */

    // Animate counters from 0 to target over duration ms
    function animateCounters(elements, duration) {
        elements.forEach(function(el) {
            var target = parseInt(el.getAttribute('data-count'), 10) || 0;
            if (target === 0) { el.textContent = '0'; return; }
            var start = performance.now();
            function step(now) {
                var progress = Math.min((now - start) / duration, 1);
                var eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
                el.textContent = Math.floor(eased * target);
                if (progress < 1) requestAnimationFrame(step);
                else el.textContent = target;
            }
            requestAnimationFrame(step);
        });
    }

    // Hero micro-stats count-up on load
    var heroNums = document.querySelectorAll('.nj-hero-stat .stat-num');
    if (heroNums.length) animateCounters(heroNums, 1500);

    // Pill badge cycling
    var pillEl = document.getElementById('heroPillText');
    if (pillEl) {
        var pillData = [
            '{{ platformStats.activeProjects }} projets actifs',
            '{{ platformStats.totalInvestors }} investisseurs inscrits',
            '{{ platformStats.fundedDeals }} deals finances'
        ];
        var pillIndex = 0;
        var pillContainer = pillEl.parentElement;
        setInterval(function() {
            pillContainer.classList.add('fade-out');
            setTimeout(function() {
                pillIndex = (pillIndex + 1) % pillData.length;
                pillEl.textContent = pillData[pillIndex];
                pillContainer.classList.remove('fade-out');
            }, 350);
        }, 3000);
    }

    /* ═══════════════════════════════════════════
       FEATURE 5 — Three.js Network Visualization
       ═══════════════════════════════════════════ */
    function initThreeNetwork() {
        if (window.innerWidth < 768) return; // skip mobile
        var canvas = document.getElementById('heroCanvas');
        if (!canvas || typeof THREE === 'undefined') return;

        var hero = document.getElementById('njHero');
        var W = hero.offsetWidth, H = hero.offsetHeight;
        var renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
        renderer.setSize(W, H);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        var scene = new THREE.Scene();
        var camera = new THREE.PerspectiveCamera(60, W / H, 1, 1000);
        camera.position.z = 250;

        var BOUNDS = 160;
        var nodes = [];
        var nodeMeshes = [];
        var velocities = [];

        // Node types: 5 investor (gold, large), 30 entrepreneur (blue, med), 45 community (white, small)
        var types = [];
        var i;
        for (i = 0; i < 5; i++) types.push({ color: 0xf59e0b, size: 3.5 });
        for (i = 0; i < 30; i++) types.push({ color: 0x3b82f6, size: 2.2 });
        for (i = 0; i < 45; i++) types.push({ color: 0xffffff, size: 1.3 });

        for (i = 0; i < 80; i++) {
            var geo = new THREE.SphereGeometry(types[i].size, 12, 12);
            var mat = new THREE.MeshBasicMaterial({ color: types[i].color, transparent: true, opacity: .7 });
            var mesh = new THREE.Mesh(geo, mat);
            mesh.position.set(
                (Math.random() - .5) * BOUNDS * 2,
                (Math.random() - .5) * BOUNDS * 2,
                (Math.random() - .5) * BOUNDS * 2
            );
            scene.add(mesh);
            nodeMeshes.push(mesh);
            velocities.push(new THREE.Vector3(
                (Math.random() - .5) * .15,
                (Math.random() - .5) * .15,
                (Math.random() - .5) * .15
            ));
        }

        // Lines
        var lineMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: .12 });
        var lineGeo = new THREE.BufferGeometry();
        var MAX_LINES = 300;
        var linePositions = new Float32Array(MAX_LINES * 6);
        lineGeo.setAttribute('position', new THREE.BufferAttribute(linePositions, 3));
        lineGeo.setDrawRange(0, 0);
        var lines = new THREE.LineSegments(lineGeo, lineMat);
        scene.add(lines);

        var angle = 0;
        function animate() {
            requestAnimationFrame(animate);

            // Move nodes
            for (var n = 0; n < 80; n++) {
                var p = nodeMeshes[n].position;
                var v = velocities[n];
                p.add(v);
                if (Math.abs(p.x) > BOUNDS) v.x *= -1;
                if (Math.abs(p.y) > BOUNDS) v.y *= -1;
                if (Math.abs(p.z) > BOUNDS) v.z *= -1;
            }

            // Update lines (proximity)
            var lineCount = 0;
            var DIST = 80;
            for (var a = 0; a < 80 && lineCount < MAX_LINES; a++) {
                for (var b = a + 1; b < 80 && lineCount < MAX_LINES; b++) {
                    var d = nodeMeshes[a].position.distanceTo(nodeMeshes[b].position);
                    if (d < DIST) {
                        var idx = lineCount * 6;
                        linePositions[idx]     = nodeMeshes[a].position.x;
                        linePositions[idx + 1] = nodeMeshes[a].position.y;
                        linePositions[idx + 2] = nodeMeshes[a].position.z;
                        linePositions[idx + 3] = nodeMeshes[b].position.x;
                        linePositions[idx + 4] = nodeMeshes[b].position.y;
                        linePositions[idx + 5] = nodeMeshes[b].position.z;
                        lineCount++;
                    }
                }
            }
            lineGeo.attributes.position.needsUpdate = true;
            lineGeo.setDrawRange(0, lineCount * 2);

            // Auto-rotate camera
            angle += 0.001745; // ~0.1 deg/frame => ~60s per revolution at 60fps
            camera.position.x = 250 * Math.sin(angle);
            camera.position.z = 250 * Math.cos(angle);
            camera.lookAt(0, 0, 0);

            renderer.render(scene, camera);
        }
        animate();
        canvas.classList.add('loaded');

        window.addEventListener('resize', function() {
            W = hero.offsetWidth; H = hero.offsetHeight;
            camera.aspect = W / H;
            camera.updateProjectionMatrix();
            renderer.setSize(W, H);
        });
    }

    // Load Three.js then init
    if (window.innerWidth >= 768) {
        var s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
        s.onload = initThreeNetwork;
        document.head.appendChild(s);
    }

    /* ═══════════════════════════════════════════
       FEATURE 6 — Scroll-triggered reveals
       ═══════════════════════════════════════════ */
    if ('IntersectionObserver' in window) {
        var revealObs = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    revealObs.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });

        // Ticker
        var ticker = document.getElementById('njTicker');
        if (ticker) revealObs.observe(ticker);

        // Module cards
        document.querySelectorAll('.nj-module-card').forEach(function(card) {
            revealObs.observe(card);
        });

        // Audience cards
        document.querySelectorAll('.nj-audience-card').forEach(function(card) {
            revealObs.observe(card);
        });

        // Strength cards
        document.querySelectorAll('.nj-strength-card').forEach(function(card) {
            revealObs.observe(card);
        });

        // Closing
        var closing = document.getElementById('njClosing');
        if (closing) revealObs.observe(closing);

        // Impact grid — also triggers counter animation
        var impactGrid = document.getElementById('impactGrid');
        if (impactGrid) {
            var impactObs = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('revealed');
                        animateCounters(entry.target.querySelectorAll('.nj-impact-num'), 1500);
                        impactObs.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.15 });
            impactObs.observe(impactGrid);
        }
    }

    /* ═══════════════════════════════════════════
       FEATURE 3 — 3D Tilt on module cards
       ═══════════════════════════════════════════ */
    document.querySelectorAll('[data-tilt]').forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
            var rect = card.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;
            var cx = rect.width / 2;
            var cy = rect.height / 2;
            var rotY = ((x - cx) / cx) * 6;
            var rotX = ((cy - y) / cy) * 6;
            card.style.transform = 'perspective(800px) rotateX(' + rotX + 'deg) rotateY(' + rotY + 'deg) translateY(-8px)';
        });
        card.addEventListener('mouseleave', function() {
            card.style.transform = '';
        });
    });

})();
</script>
{% endblock %}
