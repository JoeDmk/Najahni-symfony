        </div>

        {# Part 2 — Strengths #}
        <div class="nj-strengths" id="strengthsGrid">
            <div class="nj-strength-card" style="transition-delay:0ms">
                <i class="bi bi-file-earmark-lock2"></i>
                <h6>Contrats signes numeriquement</h6>
                <p>SHA-256 signature electronique integree</p>
            </div>
            <div class="nj-strength-card" style="transition-delay:80ms">
                <i class="bi bi-shield-check"></i>
                <h6>Paiement Stripe securise</h6>
                <p>Transactions protegees et tracees</p>
            </div>
            <div class="nj-strength-card" style="transition-delay:160ms">
                <i class="bi bi-cpu"></i>
                <h6>IA integree au workflow</h6>
                <p>Analyse de risque et matching automatise</p>
            </div>
            <div class="nj-strength-card" style="transition-delay:240ms">
                <i class="bi bi-geo-alt"></i>
                <h6>100% Tunisien</h6>
                <p>Concu pour l'ecosysteme entrepreneurial local</p>
            </div>
        </div>

        {# Part 3 — Closing statement #}
        <div class="nj-closing" id="njClosing">
            {% if isGuest %}
                <h2>Pret a commencer ? Creez votre compte gratuitement.</h2>
                <a href="{{ path('app_register') }}" class="btn btn-hero-primary">Creer mon compte gratuitement</a>
            {% else %}
                <h2>Najahni n'est pas un outil. C'est l'ecosysteme complet dont chaque entrepreneur tunisien a besoin.</h2>
                <a href="{{ path('app_register') }}" class="btn btn-hero-primary">Commencer maintenant</a>
            {% endif %}
