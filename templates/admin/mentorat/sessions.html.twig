{% extends 'admin/layout.html.twig' %}

{% block title %}Sessions de mentorat - Admin Najahni{% endblock %}

{% block main %}
<h2 class="fw-bold mb-4"><i class="bi bi-camera-video me-2"></i>Sessions de mentorat</h2>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-nj mb-0">
                <thead><tr><th>Mentor</th><th>Entrepreneur</th><th>Date</th><th>Durée</th><th>Statut</th><th>Notes M.</th><th>Notes E.</th></tr></thead>
                <tbody>
                    {% for s in pagination %}
                    <tr>
                        <td>{{ s.mentorshipRequest ? s.mentorshipRequest.mentor.firstname ~ ' ' ~ s.mentorshipRequest.mentor.lastname : '-' }}</td>
                        <td>{{ s.mentorshipRequest ? s.mentorshipRequest.entrepreneur.firstname ~ ' ' ~ s.mentorshipRequest.entrepreneur.lastname : '-' }}</td>
                        <td>{{ s.scheduledAt|date('d/m/Y H:i') }}</td>
                        <td>{{ s.durationMinutes }} min</td>
                        <td><span class="badge bg-{{ s.status == 'completed' ? 'success' : (s.status == 'cancelled' ? 'danger' : 'primary') }}">{{ s.status }}</span></td>
                        <td>{{ s.mentorRating ? s.mentorRating ~ '/5' : '-' }}</td>
                        <td>{{ s.entrepreneurRating ? s.entrepreneurRating ~ '/5' : '-' }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="7" class="text-center text-muted py-4">Aucune session.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(pagination) }}</div>
{% endblock %}
