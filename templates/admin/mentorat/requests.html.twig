{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion Mentorat - Najahni{% endblock %}

{% block main %}
<h2 class="fw-bold mb-4"><i class="bi bi-mortarboard me-2"></i>Demandes de mentorat</h2>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-nj mb-0">
                <thead><tr><th>Entrepreneur</th><th>Mentor</th><th>Projet</th><th>Date</th><th>Statut</th><th>Score</th></tr></thead>
                <tbody>
                    {% for req in pagination %}
                    <tr>
                        <td>{{ req.entrepreneur.firstname }} {{ req.entrepreneur.lastname }}</td>
                        <td>{{ req.mentor.firstname }} {{ req.mentor.lastname }}</td>
                        <td>{{ req.project ? req.project.titre : '-' }}</td>
                        <td>{{ req.date|date('d/m/Y') }}</td>
                        <td><span class="badge bg-{{ req.status == 'ACCEPTED' ? 'success' : (req.status == 'REJECTED' ? 'danger' : 'warning text-dark') }}">{{ req.status }}</span></td>
                        <td>{{ req.matchScore ?? '-' }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">Aucune demande.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(pagination) }}</div>
{% endblock %}
