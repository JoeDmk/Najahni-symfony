{% extends 'base.html.twig' %}

{% block body %}
<nav class="navbar navbar-expand-lg navbar-nj navbar-dark sticky-top">
    <div class="container-fluid px-4">
        <a class="navbar-brand text-white" href="{{ path('admin_dashboard') }}">Najahni <span class="badge bg-light text-dark ms-2" style="font-size:.65rem">Admin</span></a>
        <div class="d-flex align-items-center">
            <a href="{{ path('app_home') }}" class="btn btn-outline-light btn-sm me-3"><i class="bi bi-house me-1"></i>Front Office</a>
            <div class="dropdown">
                <a class="text-white text-decoration-none dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle me-1"></i>{{ app.user ? app.user.firstname : 'Admin' }}
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="bi bi-person me-2"></i>Profil</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Déconnexion</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="d-flex">
    {# Sidebar #}
    <aside class="sidebar d-none d-lg-block" style="width:260px;flex-shrink:0">
        <nav class="nav flex-column py-3">
            <span class="px-3 pb-2 text-uppercase fw-bold text-muted" style="font-size:.7rem;letter-spacing:1px">Navigation</span>
            <a class="nav-link {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' }}" href="{{ path('admin_dashboard') }}"><i class="bi bi-speedometer2"></i>Tableau de Bord</a>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_user' ? 'active' }}" href="{{ path('admin_users') }}"><i class="bi bi-people"></i>Utilisateurs</a>
            <a class="nav-link {{ app.request.attributes.get('_route') == 'admin_users_stats' ? 'active' }}" href="{{ path('admin_users_stats') }}"><i class="bi bi-bar-chart-line"></i>Stats Utilisateurs</a>
            <a class="nav-link {{ app.request.attributes.get('_route') == 'admin_users_broadcast' ? 'active' }}" href="{{ path('admin_users_broadcast') }}"><i class="bi bi-megaphone"></i>Email Broadcast</a>

            <span class="px-3 pt-3 pb-2 text-uppercase fw-bold text-muted" style="font-size:.7rem;letter-spacing:1px">Modules</span>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_projet' ? 'active' }}" href="{{ path('admin_projets') }}"><i class="bi bi-kanban"></i>Projets</a>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_invest' ? 'active' }}" href="{{ path('admin_invest_opportunities') }}"><i class="bi bi-graph-up-arrow"></i>Investissement</a>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_community' ? 'active' }}" href="{{ path('admin_community_dashboard') }}"><i class="bi bi-chat-dots"></i>Communauté</a>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_mentorat' ? 'active' }}" href="{{ path('admin_mentorat_requests') }}"><i class="bi bi-mortarboard"></i>Mentorat</a>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_cours' ? 'active' }}" href="{{ path('admin_cours') }}"><i class="bi bi-book"></i>Cours</a>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_badge' ? 'active' }}" href="{{ path('admin_badges') }}"><i class="bi bi-award"></i>Badges</a>
            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'admin_progression' ? 'active' }}" href="{{ path('admin_progressions') }}"><i class="bi bi-bar-chart-line"></i>Progressions</a>
        </nav>
    </aside>

    {# Content #}
    <div class="flex-grow-1 p-4 fade-in">
        {% block main %}{% endblock %}
    </div>
</div>
{% endblock %}
