{% extends 'admin/layout.html.twig' %}

{% block title %}Créer une opportunité - Admin Najahni{% endblock %}

{% block main %}
<a href="{{ path('admin_invest_opportunities') }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Toutes les opportunités</a>
<h2 class="fw-bold mt-3 mb-4">Créer une opportunité</h2>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-4">
        <form method="post" id="adminCreateForm" novalidate>
            <input type="hidden" name="_token" value="{{ csrf_token('admin_create_opportunity') }}">
            <div class="mb-3">
                <label for="project_id" class="form-label fw-semibold">Projet <span class="text-danger">*</span></label>
                <select name="project_id" id="project_id" class="form-select" required>
                    <option value="">Sélectionnez un projet</option>
                    {% for p in projets %}
                        <option value="{{ p.id }}">{{ p.titre }}</option>
                    {% endfor %}
                </select>
                <div class="invalid-feedback">Veuillez sélectionner un projet.</div>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label for="target_amount" class="form-label fw-semibold">Montant cible (DT) <span class="text-danger">*</span></label>
                    <input type="number" step="0.01" min="100" name="target_amount" id="target_amount" class="form-control" placeholder="Min: 100 DT" required>
                    <div class="invalid-feedback">Le montant doit être au minimum 100 DT.</div>
                </div>
                <div class="col-md-6">
                    <label for="deadline" class="form-label fw-semibold">Deadline <span class="text-danger">*</span></label>
                    <input type="date" name="deadline" id="deadline" class="form-control" min="{{ 'now'|date('Y-m-d') }}" required>
                    <div class="invalid-feedback">La date doit être dans le futur.</div>
                </div>
            </div>
            <div class="mb-3 mt-3">
                <label for="description" class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                <textarea name="description" id="description" class="form-control" rows="4" minlength="10" maxlength="2000" placeholder="Min. 10 caractères" required></textarea>
                <div class="d-flex justify-content-between">
                    <div class="invalid-feedback">La description doit contenir au moins 10 caractères.</div>
                    <small class="text-muted mt-1" id="charCount">0 / 2000</small>
                </div>
            </div>
            <button type="submit" class="btn btn-nj btn-lg"><i class="bi bi-check-lg me-2"></i>Créer l'opportunité</button>
        </form>
        <script>
        (function() {
            var desc = document.getElementById('description');
            var counter = document.getElementById('charCount');
            desc.addEventListener('input', function() { counter.textContent = desc.value.length + ' / 2000'; });
            document.getElementById('adminCreateForm').addEventListener('submit', function(e) {
                var valid = true;
                this.querySelectorAll('[required]').forEach(function(f) {
                    f.classList.remove('is-invalid');
                    if (!f.value.trim()) { f.classList.add('is-invalid'); valid = false; }
                });
                if (parseFloat(document.getElementById('target_amount').value) < 100) { document.getElementById('target_amount').classList.add('is-invalid'); valid = false; }
                if (desc.value.trim().length < 10) { desc.classList.add('is-invalid'); valid = false; }
                if (!valid) e.preventDefault();
            });
        })();
        </script>
    </div>
</div>
{% endblock %}
