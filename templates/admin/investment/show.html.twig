{% extends 'admin/layout.html.twig' %}

{% block title %}Détails Opportunité - Admin Najahni{% endblock %}

{% block main %}
<a href="{{ path('admin_invest_opportunities') }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Toutes les opportunités</a>
<div class="d-flex justify-content-between align-items-center mt-3 mb-4">
    <h2 class="fw-bold mb-0">{{ opportunity.project ? opportunity.project.titre : 'Opportunité #' ~ opportunity.id }}</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_invest_edit', {id: opportunity.id}) }}" class="btn btn-outline-primary"><i class="bi bi-pencil me-1"></i>Modifier</a>
        {% if opportunity.status == 'OPEN' %}
        <form method="post" action="{{ path('admin_invest_close', {id: opportunity.id}) }}" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('close_opportunity_' ~ opportunity.id) }}">
            <button class="btn btn-outline-warning" onclick="return confirm('Fermer cette opportunité ?')"><i class="bi bi-x-circle me-1"></i>Fermer</button>
        </form>
        {% endif %}
        <form method="post" action="{{ path('admin_invest_delete', {id: opportunity.id}) }}" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_opportunity_' ~ opportunity.id) }}">
            <button class="btn btn-outline-danger" onclick="return confirm('Supprimer cette opportunité et toutes ses offres ?')"><i class="bi bi-trash me-1"></i>Supprimer</button>
        </form>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius:1rem">
            <span class="badge bg-{{ opportunity.status == 'OPEN' ? 'success' : (opportunity.status == 'FUNDED' ? 'primary' : 'secondary') }} mb-3">{{ opportunity.status }}</span>
            <p>{{ opportunity.description }}</p>
            <div class="p-3 rounded-3" style="background:rgba(67,97,238,.05)">
                <div class="d-flex justify-content-between mb-2">
                    <span>Financement</span>
                    <span class="fw-bold">{{ opportunity.fundingPercentage|number_format(1) }}%</span>
                </div>
                <div class="progress" style="height:10px">
                    <div class="progress-bar" style="width:{{ opportunity.fundingPercentage }}%;background:var(--nj-gradient)"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted mt-1">
                    <span>{{ opportunity.totalFunded|number_format(0,',', ' ') }} DT</span>
                    <span>{{ opportunity.targetAmount|number_format(0, ',', ' ') }} DT</span>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h5 class="fw-bold mb-3">Offres ({{ opportunity.offers|length }})</h5>
            <div class="table-responsive">
                <table class="table table-nj">
                    <thead><tr><th>Investisseur</th><th>Montant</th><th>Statut</th><th>Date</th><th class="text-end">Actions</th></tr></thead>
                    <tbody>
                        {% for offer in opportunity.offers %}
                        <tr>
                            <td>{{ offer.investor.firstname }} {{ offer.investor.lastname }}</td>
                            <td class="fw-semibold">{{ offer.proposedAmount|number_format(0,',', ' ') }} DT</td>
                            <td><span class="badge bg-{{ offer.status == 'ACCEPTED' ? 'success' : (offer.status == 'REJECTED' ? 'danger' : 'warning text-dark') }}">{{ offer.status }}</span></td>
                            <td class="text-muted small">{{ offer.createdAt|date('d/m/Y H:i') }}</td>
                            <td class="text-end">
                                {% if offer.status == 'PENDING' %}
                                <form method="post" action="{{ path('admin_invest_offer_accept', {id: offer.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('offer_action_' ~ offer.id) }}">
                                    <button class="btn btn-sm btn-outline-success" title="Accepter"><i class="bi bi-check-lg"></i></button>
                                </form>
                                <form method="post" action="{{ path('admin_invest_offer_reject', {id: offer.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('offer_action_' ~ offer.id) }}">
                                    <button class="btn btn-sm btn-outline-danger" title="Rejeter"><i class="bi bi-x-lg"></i></button>
                                </form>
                                {% endif %}
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="5" class="text-muted text-center">Aucune offre</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4" style="border-radius:1rem">
            <h6 class="fw-bold mb-3">Informations</h6>
            <ul class="list-unstyled">
                <li class="mb-2"><strong>Projet:</strong> {{ opportunity.project ? opportunity.project.titre : 'N/A' }}</li>
                <li class="mb-2"><strong>Deadline:</strong> {{ opportunity.deadline ? opportunity.deadline|date('d/m/Y') : '-' }}
                    {% if opportunity.deadline %}
                        {% set days_left = (opportunity.deadline|date('U') - 'now'|date('U')) / 86400 %}
                        {% if days_left > 0 and days_left < 30 %}
                            <span class="badge bg-warning text-dark">{{ days_left|round(0, 'floor') }}j</span>
                        {% elseif days_left <= 0 %}
                            <span class="badge bg-danger">Expiré</span>
                        {% endif %}
                    {% endif %}
                </li>
                <li class="mb-2"><strong>Créée le:</strong> {{ opportunity.createdAt|date('d/m/Y H:i') }}</li>
                {% if opportunity.riskScore %}<li class="mb-2"><strong>Risque:</strong> {{ opportunity.riskScore|number_format(1) }} ({{ opportunity.riskLabel }})</li>{% endif %}
            </ul>
        </div>
    </div>
</div>
{% endblock %}
