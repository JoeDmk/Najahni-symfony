{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion Investissements - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2"></i>Opportunités d'investissement</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_invest_offers') }}" class="btn btn-outline-primary"><i class="bi bi-list-check me-1"></i>Toutes les offres</a>
        <a href="{{ path('admin_invest_create') }}" class="btn btn-nj"><i class="bi bi-plus-lg me-1"></i>Créer</a>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

{# Statistics cards #}
<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold" style="color:var(--nj-accent)">{{ totalOpportunities }}</div>
            <small class="text-muted">Total opportunités</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-success">{{ openCount }}</div>
            <small class="text-muted">Ouvertes</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-primary">{{ fundedCount }}</div>
            <small class="text-muted">Financées</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold" style="color:var(--nj-accent)">{{ totalOffers }}</div>
            <small class="text-muted">Total offres</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-warning">{{ pendingOffers }}</div>
            <small class="text-muted">En attente</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-success">{{ totalRaised|number_format(0, ',', ' ') }}</div>
            <small class="text-muted">DT levés</small>
        </div>
    </div>
</div>

{# Search / filter bar #}
<div class="card border-0 shadow-sm mb-4 p-3" style="border-radius:.75rem">
    <form method="get" action="{{ path('admin_invest_opportunities') }}" class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label small fw-semibold mb-1">Rechercher</label>
            <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Nom du projet...">
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold mb-1">Statut</label>
            <select name="status" class="form-select">
                <option value="">Tous</option>
                <option value="OPEN" {{ statusFilter == 'OPEN' ? 'selected' }}>OPEN</option>
                <option value="CLOSED" {{ statusFilter == 'CLOSED' ? 'selected' }}>CLOSED</option>
                <option value="FUNDED" {{ statusFilter == 'FUNDED' ? 'selected' }}>FUNDED</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-nj w-100"><i class="bi bi-search me-1"></i>Filtrer</button>
        </div>
        <div class="col-md-2">
            <a href="{{ path('admin_invest_opportunities') }}" class="btn btn-outline-secondary w-100">Réinitialiser</a>
        </div>
    </form>
</div>

<div id="liveResults">
<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-nj mb-0">
                <thead>
                    <tr><th>Projet</th><th>Montant cible</th><th>Financé</th><th>Statut</th><th>Deadline</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    {% for opp in pagination %}
                    <tr>
                        <td class="fw-semibold">{{ opp.project ? opp.project.titre : 'N/A' }}</td>
                        <td>{{ opp.targetAmount|number_format(0, ',', ' ') }} DT</td>
                        <td>
                            <div class="progress" style="height:6px;width:80px;display:inline-block;vertical-align:middle">
                                <div class="progress-bar" style="width:{{ opp.fundingPercentage }}%;background:var(--nj-gradient)"></div>
                            </div>
                            <small class="ms-1">{{ opp.fundingPercentage|number_format(0) }}%</small>
                        </td>
                        <td><span class="badge bg-{{ opp.status == 'OPEN' ? 'success' : (opp.status == 'FUNDED' ? 'primary' : 'secondary') }}">{{ opp.status }}</span></td>
                        <td>{{ opp.deadline ? opp.deadline|date('d/m/Y') : '-' }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('admin_invest_show', {id: opp.id}) }}" class="btn btn-outline-primary"><i class="bi bi-eye"></i></a>
                                {% if opp.status == 'OPEN' %}
                                <form method="post" action="{{ path('admin_invest_close', {id: opp.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('close_opportunity_' ~ opp.id) }}">
                                    <button class="btn btn-outline-warning" title="Fermer"><i class="bi bi-x-circle"></i></button>
                                </form>
                                {% endif %}
                                <form method="post" action="{{ path('admin_invest_delete', {id: opp.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette opportunité ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_opportunity_' ~ opp.id) }}">
                                    <button class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">Aucune opportunité trouvée.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(pagination) }}</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
    const form = document.querySelector('form[action*="invest"]');
    if (!form) return;
    let timer;
    function liveSearch() {
        clearTimeout(timer);
        timer = setTimeout(function() {
            const params = new URLSearchParams(new FormData(form)).toString();
            const url = form.action + '?' + params;
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function(r) { return r.text(); })
                .then(function(html) {
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    const nr = doc.getElementById('liveResults');
                    const cur = document.getElementById('liveResults');
                    if (nr && cur) cur.innerHTML = nr.innerHTML;
                });
        }, 300);
    }
    form.querySelectorAll('input[name="q"]').forEach(function(el) {
        el.addEventListener('input', liveSearch);
    });
    form.querySelectorAll('select').forEach(function(el) {
        el.addEventListener('change', liveSearch);
    });
    form.addEventListener('submit', function(e) { e.preventDefault(); liveSearch(); });
})();
</script>
{% endblock %}
