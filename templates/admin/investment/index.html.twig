{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion Investissements - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-cash-stack me-2"></i>Opportunités d'investissement</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_invest_offers') }}" class="btn btn-outline-primary"><i class="bi bi-list-check me-1"></i>Toutes les offres</a>
        <a href="{{ path('admin_invest_create') }}" class="btn btn-nj"><i class="bi bi-plus-lg me-1"></i>Créer</a>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

{# Statistics cards #}
<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold" style="color:var(--nj-accent)">{{ totalOpportunities }}</div>
            <small class="text-muted">Total opportunités</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-success">{{ openCount }}</div>
            <small class="text-muted">Ouvertes</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-primary">{{ fundedCount }}</div>
            <small class="text-muted">Financées</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold" style="color:var(--nj-accent)">{{ totalOffers }}</div>
            <small class="text-muted">Total offres</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-warning">{{ pendingOffers }}</div>
            <small class="text-muted">En attente</small>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center p-3" style="border-radius:.75rem">
            <div class="fs-3 fw-bold text-success">{{ totalRaised|number_format(0, ',', ' ') }}</div>
            <small class="text-muted">DT levés</small>
        </div>
    </div>
</div>

{# Search / filter bar #}
<div class="card border-0 shadow-sm mb-4 p-3" style="border-radius:.75rem">
    <form method="get" action="{{ path('admin_invest_opportunities') }}" class="row g-2 align-items-end" id="opportunityFiltersForm">
        <div class="col-md-4">
            <label class="form-label small fw-semibold mb-1">Recherche globale</label>
            <input type="search" name="q" value="{{ filters.q ?? '' }}" class="form-control" placeholder="Projet, description, entrepreneur, email...">
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold mb-1">Statut</label>
            <select name="status" class="form-select">
                <option value="">Tous</option>
                <option value="OPEN" {{ (filters.status ?? '') == 'OPEN' ? 'selected' }}>OPEN</option>
                <option value="CLOSED" {{ (filters.status ?? '') == 'CLOSED' ? 'selected' }}>CLOSED</option>
                <option value="FUNDED" {{ (filters.status ?? '') == 'FUNDED' ? 'selected' }}>FUNDED</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold mb-1">Entrepreneur</label>
            <input type="text" name="entrepreneur" value="{{ filters.entrepreneur ?? '' }}" class="form-control" placeholder="Nom, email ou société">
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold mb-1">Secteur</label>
            <input type="text" name="sector" value="{{ filters.sector ?? '' }}" class="form-control" placeholder="EdTech, SaaS, FinTech...">
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold mb-1">Deadline</label>
            <select name="deadline_state" class="form-select">
                <option value="">Toutes</option>
                <option value="active" {{ (filters.deadline_state ?? '') == 'active' ? 'selected' }}>Actives</option>
                <option value="expiring" {{ (filters.deadline_state ?? '') == 'expiring' ? 'selected' }}>Sous 30 jours</option>
                <option value="expired" {{ (filters.deadline_state ?? '') == 'expired' ? 'selected' }}>Expirées</option>
                <option value="none" {{ (filters.deadline_state ?? '') == 'none' ? 'selected' }}>Sans deadline</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold mb-1">Montant min</label>
            <input type="number" min="0" step="1" name="amount_min" value="{{ filters.amount_min ?? '' }}" class="form-control" placeholder="0">
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold mb-1">Montant max</label>
            <input type="number" min="0" step="1" name="amount_max" value="{{ filters.amount_max ?? '' }}" class="form-control" placeholder="500000">
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold mb-1">Tri</label>
            <select name="order" class="form-select">
                <option value="recent" {{ (filters.order ?? 'recent') == 'recent' ? 'selected' }}>Plus récentes</option>
                <option value="oldest" {{ (filters.order ?? '') == 'oldest' ? 'selected' }}>Plus anciennes</option>
                <option value="amount_desc" {{ (filters.order ?? '') == 'amount_desc' ? 'selected' }}>Montant décroissant</option>
                <option value="amount_asc" {{ (filters.order ?? '') == 'amount_asc' ? 'selected' }}>Montant croissant</option>
                <option value="deadline_asc" {{ (filters.order ?? '') == 'deadline_asc' ? 'selected' }}>Deadline proche</option>
                <option value="deadline_desc" {{ (filters.order ?? '') == 'deadline_desc' ? 'selected' }}>Deadline lointaine</option>
                <option value="project_asc" {{ (filters.order ?? '') == 'project_asc' ? 'selected' }}>Projet A-Z</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-nj w-100"><i class="bi bi-search me-1"></i>Appliquer</button>
        </div>
        <div class="col-md-2">
            <a href="{{ path('admin_invest_opportunities') }}" class="btn btn-outline-secondary w-100">Réinitialiser</a>
        </div>
        <div class="col-12">
            <div class="small text-muted">Mise à jour en direct pendant la saisie. Les filtres avancés permettent d'isoler les opportunités par entrepreneur, secteur, montant cible et état de deadline.</div>
        </div>
    </form>
</div>

<div id="opportunityResultsContainer">
    {% include 'admin/investment/_opportunities_results.html.twig' with {pagination: pagination} %}
</div>

<script>
(function() {
    var form = document.getElementById('opportunityFiltersForm');
    var results = document.getElementById('opportunityResultsContainer');
    var debounceTimer;
    var requestController;

    if (!form || !results) {
        return;
    }

    function setLoading(isLoading) {
        results.style.opacity = isLoading ? '0.55' : '1';
        results.style.transition = 'opacity .18s ease';
    }

    function buildUrl(baseUrl) {
        var url = new URL(baseUrl || form.action, window.location.origin);
        url.search = new URLSearchParams(new FormData(form)).toString();
        return url;
    }

    function fetchResults(url) {
        if (requestController) {
            requestController.abort();
        }

        requestController = new AbortController();
        setLoading(true);

        fetch(url.toString(), {
            headers: {'X-Requested-With': 'XMLHttpRequest'},
            signal: requestController.signal
        })
            .then(function(response) { return response.text(); })
            .then(function(html) {
                results.innerHTML = html;
                history.replaceState({}, '', window.location.pathname + '?' + url.searchParams.toString());
                setLoading(false);
            })
            .catch(function(error) {
                if (error.name !== 'AbortError') {
                    setLoading(false);
                }
            });
    }

    function queueFetch() {
        window.clearTimeout(debounceTimer);
        debounceTimer = window.setTimeout(function() {
            fetchResults(buildUrl());
        }, 250);
    }

    form.addEventListener('submit', function(event) {
        event.preventDefault();
        fetchResults(buildUrl());
    });

    form.addEventListener('input', function(event) {
        if (event.target.matches('input[type="search"], input[type="text"], input[type="number"]')) {
            queueFetch();
        }
    });

    form.addEventListener('change', function() {
        queueFetch();
    });

    results.addEventListener('click', function(event) {
        var link = event.target.closest('.pagination a');
        if (!link) {
            return;
        }

        event.preventDefault();
        fetchResults(link.href);
    });
})();
</script>
{% endblock %}
