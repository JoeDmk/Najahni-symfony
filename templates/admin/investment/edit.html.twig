{% extends 'admin/layout.html.twig' %}

{% block title %}Modifier opportunité - Admin Najahni{% endblock %}

{% block main %}
<a href="{{ path('admin_invest_show', {id: opportunity.id}) }}" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Retour</a>
<h2 class="fw-bold mt-3 mb-4">Modifier l'opportunité</h2>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-4">
        <form method="post" id="adminEditForm" novalidate>
            {% set e = fieldErrors|default({}) %}
            <input type="hidden" name="_token" value="{{ csrf_token('admin_edit_opportunity_' ~ opportunity.id) }}">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="target_amount" class="form-label fw-semibold">Montant cible (DT) <span class="text-danger">*</span></label>
                    <input type="number" step="0.01" min="100" name="target_amount" id="target_amount" class="form-control {{ e.target_amount is defined ? 'is-invalid' }}" value="{{ opportunity.targetAmount }}" required>
                    <div class="invalid-feedback {{ e.target_amount is defined ? 'd-block' }}">{{ e.target_amount|default('Le montant doit être au minimum 100 DT.') }}</div>
                </div>
                <div class="col-md-4">
                    <label for="deadline" class="form-label fw-semibold">Deadline <span class="text-danger">*</span></label>
                    <input type="date" name="deadline" id="deadline" class="form-control {{ e.deadline is defined ? 'is-invalid' }}" value="{{ opportunity.deadline ? opportunity.deadline|date('Y-m-d') : '' }}" required>
                    <div class="invalid-feedback {{ e.deadline is defined ? 'd-block' }}">{{ e.deadline|default('La date est obligatoire.') }}</div>
                </div>
                <div class="col-md-4">
                    <label for="status" class="form-label fw-semibold">Statut</label>
                    <select name="status" id="status" class="form-select">
                        <option value="OPEN" {{ opportunity.status == 'OPEN' ? 'selected' }}>OPEN</option>
                        <option value="CLOSED" {{ opportunity.status == 'CLOSED' ? 'selected' }}>CLOSED</option>
                        <option value="FUNDED" {{ opportunity.status == 'FUNDED' ? 'selected' }}>FUNDED</option>
                    </select>
                </div>
            </div>
            <div class="mb-3 mt-3">
                <label for="description" class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                <textarea name="description" id="description" class="form-control {{ e.description is defined ? 'is-invalid' }}" rows="4" minlength="10" maxlength="2000" required>{{ opportunity.description }}</textarea>
                <div class="d-flex justify-content-between">
                    <div class="invalid-feedback {{ e.description is defined ? 'd-block' }}">{{ e.description|default('La description doit contenir au moins 10 caractères.') }}</div>
                    <small class="text-muted mt-1" id="editCharCount">{{ opportunity.description|length }} / 2000</small>
                </div>
            </div>
            <button type="submit" class="btn btn-nj btn-lg"><i class="bi bi-check-lg me-2"></i>Enregistrer</button>
        </form>
        <script>
        (function() {
            var desc = document.getElementById('description');
            var counter = document.getElementById('editCharCount');
            if (desc && counter) {
                desc.addEventListener('input', function() { counter.textContent = desc.value.length + ' / 2000'; });
            }
        })();
        </script>
    </div>
</div>
{% endblock %}
