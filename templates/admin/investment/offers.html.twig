{% extends 'admin/layout.html.twig' %}

{% block title %}Toutes les offres - Admin Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-list-check me-2"></i>Toutes les offres</h2>
    <a href="{{ path('admin_invest_opportunities') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Opportunités</a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

{# Status filter #}
<div class="card border-0 shadow-sm mb-4 p-3" style="border-radius:.75rem">
    <form method="get" action="{{ path('admin_invest_offers') }}" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small fw-semibold mb-1">Filtrer par statut</label>
            <select name="status" class="form-select">
                <option value="">Tous les statuts</option>
                <option value="PENDING" {{ statusFilter == 'PENDING' ? 'selected' }}>En attente</option>
                <option value="ACCEPTED" {{ statusFilter == 'ACCEPTED' ? 'selected' }}>Acceptées</option>
                <option value="REJECTED" {{ statusFilter == 'REJECTED' ? 'selected' }}>Rejetées</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-nj w-100"><i class="bi bi-funnel me-1"></i>Filtrer</button>
        </div>
        <div class="col-md-2">
            <a href="{{ path('admin_invest_offers') }}" class="btn btn-outline-secondary w-100">Réinitialiser</a>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-nj mb-0">
                <thead>
                    <tr><th>Investisseur</th><th>Projet</th><th>Montant</th><th>Statut</th><th>Date</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    {% for offer in pagination %}
                    <tr>
                        <td>{{ offer.investor.firstname }} {{ offer.investor.lastname }}</td>
                        <td>{{ offer.opportunity.project ? offer.opportunity.project.titre : 'N/A' }}</td>
                        <td class="fw-semibold">{{ offer.proposedAmount|number_format(0, ',', ' ') }} DT</td>
                        <td><span class="badge bg-{{ offer.status == 'ACCEPTED' ? 'success' : (offer.status == 'REJECTED' ? 'danger' : 'warning text-dark') }}">{{ offer.status }}</span></td>
                        <td class="text-muted small">{{ offer.createdAt|date('d/m/Y H:i') }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('admin_invest_show', {id: offer.opportunity.id}) }}" class="btn btn-outline-primary" title="Voir opportunité"><i class="bi bi-eye"></i></a>
                                {% if offer.status == 'PENDING' %}
                                <form method="post" action="{{ path('admin_invest_offer_accept', {id: offer.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('offer_action_' ~ offer.id) }}">
                                    <button class="btn btn-sm btn-outline-success" title="Accepter"><i class="bi bi-check-lg"></i></button>
                                </form>
                                <form method="post" action="{{ path('admin_invest_offer_reject', {id: offer.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('offer_action_' ~ offer.id) }}">
                                    <button class="btn btn-sm btn-outline-danger" title="Rejeter"><i class="bi bi-x-lg"></i></button>
                                </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">Aucune offre trouvée.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(pagination) }}</div>
{% endblock %}
