<div class="card border-0 shadow-sm mb-4" style="border-radius:1rem">
    <div class="card-body p-3 d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <div class="fw-semibold">Espace Communauté</div>
            <div class="small text-muted">Choisissez le contenu à gérer et supprimez n importe quel groupe, événement ou post.</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_community_dashboard') }}" class="btn btn-sm {{ section == 'overview' ? 'btn-nj' : 'btn-outline-primary' }}">Vue d ensemble</a>
            <a href="{{ path('admin_community_groups') }}" class="btn btn-sm {{ section == 'groups' ? 'btn-nj' : 'btn-outline-primary' }}">Groupes <span class="badge text-bg-light ms-1">{{ communityTotals.groups }}</span></a>
            <a href="{{ path('admin_community_events') }}" class="btn btn-sm {{ section == 'events' ? 'btn-nj' : 'btn-outline-primary' }}">Evenements <span class="badge text-bg-light ms-1">{{ communityTotals.events }}</span></a>
            <a href="{{ path('admin_community_posts') }}" class="btn btn-sm {{ section == 'posts' ? 'btn-nj' : 'btn-outline-primary' }}">Posts <span class="badge text-bg-light ms-1">{{ communityTotals.posts }}</span></a>
        </div>
    </div>
</div>