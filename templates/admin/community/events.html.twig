{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion Événements - Najahni{% endblock %}

{% block main %}
{% include 'admin/community/_nav.html.twig' with {section: section, communityTotals: communityTotals} %}

<h2 class="fw-bold mb-4"><i class="bi bi-calendar-event me-2"></i>Événements</h2>

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="small text-muted mb-1">Total Evenements</div>
                <div class="fw-bold fs-3">{{ stats.total }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="small text-muted mb-1">A Venir</div>
                <div class="fw-bold fs-3">{{ stats.upcoming }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="small text-muted mb-1">Avec Capacite</div>
                <div class="fw-bold fs-3">{{ stats.limited }}</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm" style="border-radius:1rem">
            <div class="card-body p-4">
                <div class="small text-muted mb-1">Inscriptions</div>
                <div class="fw-bold fs-3">{{ stats.registrations }}</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-nj mb-0">
                <thead><tr><th>Titre</th><th>Organisateur</th><th>Date</th><th>Capacité</th><th>Inscrits</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                    {% for event in pagination %}
                    <tr>
                        <td class="fw-semibold">{{ event.title }}</td>
                        <td>{{ event.createdBy.firstname }} {{ event.createdBy.lastname }}</td>
                        <td>{{ event.eventDate|date('d/m/Y H:i') }}</td>
                        <td>{{ event.capacity }}</td>
                        <td>{{ event.participantsCount }}</td>
                        <td class="text-end">
                            <a href="{{ path('app_community_event_show', {id: event.id}) }}" class="btn btn-sm btn-outline-primary">Ouvrir</a>
                            <form method="post" action="{{ path('admin_community_events_delete', {id: event.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">Aucun événement.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(pagination) }}</div>
{% endblock %}
