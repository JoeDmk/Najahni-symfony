{% extends 'admin/layout.html.twig' %}

{% block title %}{{ user ? 'Modifier' : 'Ajouter' }} un utilisateur - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-person-{{ user ? 'gear' : 'plus' }} me-2"></i>{{ user ? 'Modifier' : 'Ajouter' }} un utilisateur</h2>
    <a href="{{ path('admin_users') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-4">
        <form method="post" novalidate>
            {% set e = fieldErrors|default({}) %}
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Prénom</label>
                    <input type="text" name="firstname" class="form-control {{ e.firstname is defined ? 'is-invalid' }}" value="{{ user ? user.firstname }}" required minlength="2" maxlength="100">
                    {% if e.firstname is defined %}<div class="invalid-feedback d-block">{{ e.firstname }}</div>{% endif %}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Nom</label>
                    <input type="text" name="lastname" class="form-control {{ e.lastname is defined ? 'is-invalid' }}" value="{{ user ? user.lastname }}" required minlength="2" maxlength="100">
                    {% if e.lastname is defined %}<div class="invalid-feedback d-block">{{ e.lastname }}</div>{% endif %}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" name="email" class="form-control {{ e.email is defined ? 'is-invalid' }}" value="{{ user ? user.email }}" required maxlength="255">
                    {% if e.email is defined %}<div class="invalid-feedback d-block">{{ e.email }}</div>{% endif %}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Téléphone</label>
                    <input type="tel" name="phone" class="form-control {{ e.phone is defined ? 'is-invalid' }}" value="{{ user ? user.phone }}" pattern="^\+?[0-9\s\-]{7,20}$" maxlength="20" title="Numéro de téléphone valide (7-20 chiffres)">
                    {% if e.phone is defined %}<div class="invalid-feedback d-block">{{ e.phone }}</div>{% endif %}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Rôle</label>
                    <select name="role" class="form-select" required>
                        {% for r in ['ADMIN', 'ENTREPRENEUR', 'MENTOR', 'INVESTISSEUR'] %}
                            <option value="{{ r }}" {{ user and user.role == r ? 'selected' }}>{{ r }}</option>
                        {% endfor %}
                    </select>
                </div>
                {% if not user %}
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Mot de passe</label>
                    <input type="password" name="password" class="form-control" value="najahni123">
                    <small class="text-muted">Par défaut : najahni123</small>
                </div>
                {% endif %}
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Entreprise</label>
                    <input type="text" name="company_name" class="form-control {{ e.companyName is defined ? 'is-invalid' }}" value="{{ user ? user.companyName }}" maxlength="200">
                    {% if e.companyName is defined %}<div class="invalid-feedback d-block">{{ e.companyName }}</div>{% endif %}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Adresse</label>
                    <input type="text" name="address" class="form-control {{ e.address is defined ? 'is-invalid' }}" value="{{ user ? user.address }}" maxlength="300">
                    {% if e.address is defined %}<div class="invalid-feedback d-block">{{ e.address }}</div>{% endif %}
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Bio</label>
                    <textarea name="bio" class="form-control {{ e.bio is defined ? 'is-invalid' }}" rows="3" maxlength="1000">{{ user ? user.bio }}</textarea>
                    {% if e.bio is defined %}<div class="invalid-feedback d-block">{{ e.bio }}</div>{% endif %}
                </div>
            </div>
            <button type="submit" class="btn btn-nj mt-4"><i class="bi bi-check-lg me-2"></i>{{ user ? 'Enregistrer' : 'Créer' }}</button>
        </form>
    </div>
</div>
{% endblock %}
