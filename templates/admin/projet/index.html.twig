{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion des projets - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-rocket-takeoff me-2"></i>Projets</h2>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius:1rem">
    <div class="card-body p-3">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="q" class="form-control" placeholder="Rechercher par titre, secteur..." value="{{ search }}">
            <button class="btn btn-nj px-4"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-nj mb-0">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Entrepreneur</th>
                        <th>Secteur</th>
                        <th>Statut</th>
                        <th>Score</th>
                        <th>Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for projet in pagination %}
                    <tr>
                        <td class="fw-semibold">{{ projet.titre }}</td>
                        <td>{{ projet.user ? projet.user.firstname ~ ' ' ~ projet.user.lastname : 'N/A' }}</td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary">{{ projet.secteur }}</span></td>
                        <td>
                            <span class="badge {{ projet.statutProjet == 'EVALUE' ? 'bg-success' : (projet.statutProjet == 'SOUMIS' ? 'bg-warning text-dark' : 'bg-secondary') }}">
                                {{ projet.statutProjet }}
                            </span>
                        </td>
                        <td>{{ projet.scoreGlobal ? projet.scoreGlobal|number_format(1) : '-' }}</td>
                        <td>{{ projet.dateCreation|date('d/m/Y') }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('admin_projets_show', {id: projet.id}) }}" class="btn btn-outline-primary"><i class="bi bi-eye"></i></a>
                                <form method="post" action="{{ path('admin_projets_delete', {id: projet.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                                    <button class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="7" class="text-center text-muted py-4">Aucun projet trouvé.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(pagination) }}</div>
{% endblock %}
