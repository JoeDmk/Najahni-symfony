{% extends 'admin/layout.html.twig' %}

{% block title %}{{ cours ? 'Modifier' : 'Ajouter' }} un cours - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-book me-2"></i>{{ cours ? 'Modifier' : 'Ajouter' }} un cours</h2>
    <a href="{{ path('admin_cours') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-4">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Titre</label>
                    <input type="text" name="titre" class="form-control" value="{{ cours ? cours.titre }}" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Catégorie</label>
                    <input type="text" name="categorie" class="form-control" value="{{ cours ? cours.categorie }}">
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea name="description" class="form-control" rows="4">{{ cours ? cours.description }}</textarea>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Niveau</label>
                    <select name="niveau_difficulte" class="form-select">
                        {% for n in ['DEBUTANT', 'INTERMEDIAIRE', 'AVANCE', 'EXPERT'] %}
                            <option value="{{ n }}" {{ cours and cours.niveauDifficulte == n ? 'selected' }}>{{ n }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Points XP</label>
                    <input type="number" name="points_xp" class="form-control" value="{{ cours ? cours.pointsXp : 0 }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Durée (min)</label>
                    <input type="number" name="duree_estimee" class="form-control" value="{{ cours ? cours.dureeEstimee : 0 }}">
                </div>
                <div class="col-md-3">
                    <div class="mt-4 pt-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="certification" value="1" id="cert" {{ cours and cours.certification ? 'checked' }}>
                            <label class="form-check-label" for="cert">Certifiant</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="actif" value="1" id="actif" {{ (not cours) or cours.actif ? 'checked' }}>
                            <label class="form-check-label" for="actif">Actif</label>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Image URL</label>
                    <input type="url" name="image_url" class="form-control" value="{{ cours ? cours.imageUrl }}">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Vidéo URL</label>
                    <input type="url" name="video_url" class="form-control" value="{{ cours ? cours.videoUrl }}">
                </div>
            </div>
            <button type="submit" class="btn btn-nj mt-4"><i class="bi bi-check-lg me-2"></i>{{ cours ? 'Enregistrer' : 'Créer' }}</button>
        </form>
    </div>
</div>
{% endblock %}
