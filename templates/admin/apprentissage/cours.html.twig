{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion des Cours - Najahni{% endblock %}

{% block main %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-book me-2"></i>Cours</h2>
    <a href="{{ path('admin_cours_new') }}" class="btn btn-nj"><i class="bi bi-plus-lg me-2"></i>Ajouter</a>
</div>

<div class="card border-0 shadow-sm" style="border-radius:1rem">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-nj mb-0">
                <thead><tr><th>Titre</th><th>Catégorie</th><th>Niveau</th><th>XP</th><th>Certifiant</th><th>Actif</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                    {% for c in pagination %}
                    <tr>
                        <td class="fw-semibold">{{ c.titre }}</td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary">{{ c.categorie }}</span></td>
                        <td>{{ c.niveauDifficulte }}</td>
                        <td>{{ c.pointsXp }}</td>
                        <td>{{ c.certification ? '✅' : '❌' }}</td>
                        <td>{{ c.actif ? '✅' : '❌' }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('admin_cours_edit', {id: c.id}) }}" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="{{ path('admin_cours_delete', {id: c.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ?')">
                                    <button class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="7" class="text-center text-muted py-4">Aucun cours.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(pagination) }}</div>
{% endblock %}
