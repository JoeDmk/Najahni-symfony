{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Najahni{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center" style="background:var(--nj-gradient)">
    <div class="card shadow-lg border-0" style="width:440px;border-radius:1.5rem">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width:80px;height:80px;background:rgba(67,97,238,.1)">
                    <i class="bi bi-key" style="font-size:2.5rem;color:var(--nj-primary)"></i>
                </div>
                <h3 class="fw-bold">Mot de passe oublié ?</h3>
                <p class="text-muted">Entrez votre adresse email et nous vous enverrons un code de réinitialisation.</p>
            </div>

            <form method="post">
                <div class="mb-4">
                    <label class="form-label fw-semibold">Adresse email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                        <input type="email" name="email" class="form-control border-start-0 ps-0" placeholder="votre@email.com" required autofocus>
                    </div>
                </div>
                <button type="submit" class="btn btn-nj w-100 py-2 mb-3">
                    <i class="bi bi-send me-2"></i>Envoyer le code
                </button>
            </form>

            <p class="text-center mb-0">
                <a href="{{ path('app_login') }}" class="text-decoration-none" style="color:var(--nj-primary)">
                    <i class="bi bi-arrow-left me-1"></i>Retour à la connexion
                </a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
