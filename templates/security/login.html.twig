{% extends 'base.html.twig' %}

{% set recaptcha_enabled = recaptcha_site_key is not empty and recaptcha_site_key not in ['your_recaptcha_site_key', 'your_recaptcha_secret_key'] %}

{% block title %}Connexion - Najahni{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center py-4" style="background:var(--nj-gradient)">
    <div class="card shadow-lg border-0 overflow-hidden" style="max-width:900px;width:95%;border-radius:1.5rem">
        <div class="row g-0">
            {# LEFT — Branding Panel #}
            <div class="col-md-5 d-none d-md-flex flex-column justify-content-center align-items-center text-white p-5 position-relative" style="background:linear-gradient(160deg,var(--nj-secondary),var(--nj-accent));min-height:540px">
                <div class="position-absolute top-0 start-0 w-100 h-100" style="background:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 200 200%22><circle cx=%2230%22 cy=%2240%22 r=%2260%22 fill=%22rgba(255,255,255,0.04)%22/><circle cx=%22170%22 cy=%22160%22 r=%2280%22 fill=%22rgba(255,255,255,0.03)%22/><circle cx=%22140%22 cy=%2230%22 r=%2240%22 fill=%22rgba(255,255,255,0.05)%22/></svg>');background-size:cover"></div>
                <div class="text-center position-relative" style="z-index:1">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4" style="width:80px;height:80px;background:rgba(255,255,255,.15);backdrop-filter:blur(10px)">
                        <i class="bi bi-rocket-takeoff" style="font-size:2.5rem"></i>
                    </div>
                    <h2 class="fw-bold mb-3" style="font-size:1.8rem">Najahni</h2>
                    <p class="mb-4 opacity-90" style="font-size:.95rem;line-height:1.6">Votre plateforme d'innovation tunisienne. Connectez-vous avec des mentors, investisseurs et entrepreneurs.</p>
                    <div class="d-flex flex-column gap-3 text-start mx-auto" style="max-width:250px">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;min-width:32px;background:rgba(255,255,255,.15)">
                                <i class="bi bi-lightbulb" style="font-size:.85rem"></i>
                            </div>
                            <small class="opacity-90">Lancez vos projets innovants</small>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;min-width:32px;background:rgba(255,255,255,.15)">
                                <i class="bi bi-people" style="font-size:.85rem"></i>
                            </div>
                            <small class="opacity-90">Trouvez mentors & investisseurs</small>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;min-width:32px;background:rgba(255,255,255,.15)">
                                <i class="bi bi-graph-up-arrow" style="font-size:.85rem"></i>
                            </div>
                            <small class="opacity-90">Développez votre business</small>
                        </div>
                    </div>
                </div>
            </div>

            {# RIGHT — Login Form #}
            <div class="col-md-7">
                <div class="p-4 p-md-5">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold" style="font-size:1.75rem">Connexion</h3>
                        <p class="text-muted small">Accédez à votre espace Najahni</p>
                    </div>

                    {% if error %}
                        <div class="alert alert-danger d-flex align-items-center rounded-3 py-2" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div class="small">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        </div>
                    {% endif %}

                    <form method="post" id="loginForm" novalidate>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                                <input type="email" name="_username" class="form-control border-start-0 ps-0" value="{{ last_username }}" placeholder="votre@email.com" required autofocus>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Mot de passe</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock"></i></span>
                                <input type="password" name="_password" id="loginPassword" class="form-control border-start-0 border-end-0 ps-0" placeholder="••••••••" required>
                                <button class="btn btn-outline-secondary border-start-0" type="button" onclick="togglePw()">
                                    <i class="bi bi-eye" id="pwIcon"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                                <label class="form-check-label small" for="rememberMe">Se souvenir de moi</label>
                            </div>
                            <a href="{{ path('app_forgot_password') }}" class="small text-decoration-none" style="color:var(--nj-primary)">Mot de passe oublié ?</a>
                        </div>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        {% if recaptcha_enabled %}
                        <div class="d-flex justify-content-center mb-3">
                            <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
                        </div>
                        {% endif %}
                        <button type="submit" class="btn btn-nj w-100 py-2 mb-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                        </button>
                    </form>

                    {% if recaptcha_enabled %}
                    <div class="text-center mb-2">
                        <small class="text-muted"><i class="bi bi-shield-check text-success"></i> Protégé par reCAPTCHA</small>
                    </div>
                    {% endif %}

                    <div class="d-flex align-items-center my-3">
                        <hr class="flex-grow-1"><span class="px-3 text-muted small">ou</span><hr class="flex-grow-1">
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        <a href="{{ path('app_google_connect') }}" class="btn btn-outline-secondary py-2 d-flex align-items-center justify-content-center" style="border-radius:.75rem">
                            <svg width="18" height="18" viewBox="0 0 24 24" class="me-2">
                                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                            </svg>
                            Continuer avec Google
                        </a>
                        <a href="{{ path('app_face_login') }}" class="btn btn-outline-secondary py-2 d-flex align-items-center justify-content-center" style="border-radius:.75rem">
                            <i class="bi bi-person-bounding-box me-2" style="font-size:1.1rem"></i>
                            Connexion Face ID
                        </a>
                    </div>

                    <p class="text-center text-muted small mb-0">Pas encore de compte ?
                        <a href="{{ path('app_register') }}" class="fw-semibold text-decoration-none" style="color:var(--nj-primary)">S'inscrire</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function togglePw() {
    const inp = document.getElementById('loginPassword');
    const icon = document.getElementById('pwIcon');
    if (inp.type === 'password') { inp.type = 'text'; icon.className = 'bi bi-eye-slash'; }
    else { inp.type = 'password'; icon.className = 'bi bi-eye'; }
}
</script>
{% if recaptcha_enabled %}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
{% endif %}
{% endblock %}
